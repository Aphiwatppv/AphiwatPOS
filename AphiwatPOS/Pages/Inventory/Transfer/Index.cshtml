@page
@model AphiwatPOS.Pages.Inventory.Transfer.IndexModel
@using AphiwatPOS.Pages.Inventory
@{
    ViewData["Title"] = "Stock Transfer";
    ViewData["Subtitle"] = "Move products between locations and track sent and received quantities.";
    var rows = Model.Transfers.Items.ToArray();
    var totalPages = InventoryUi.TotalPages(Model.Transfers.TotalCount, Model.Transfers.PageSize);
}
<partial name="_ProductToast" model="(Model.StatusMessage, Model.ErrorMessage)" />
<div class="page-header d-flex align-items-start justify-content-between gap-3"><div><h1>Stock Transfer</h1><p>Move products between locations and track sent and received quantities.</p></div><button class="btn btn-primary @(Model.Permissions.CanCreate ? "" : "disabled")" data-bs-toggle="modal" data-bs-target="#createTransferModal" type="button"><i class="bi bi-plus-lg me-1"></i>Create Transfer</button></div>
<div class="summary-grid"><div class="summary-card"><span class="metric-icon"><i class="bi bi-pencil-square"></i></span><div><div class="metric-label">Draft transfers</div><div class="metric-value">@rows.Count(x => x.Status == "Draft")</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-truck"></i></span><div><div class="metric-label">Sent transfers</div><div class="metric-value">@rows.Count(x => x.Status == "Sent")</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-check-circle"></i></span><div><div class="metric-label">Received transfers</div><div class="metric-value">@rows.Count(x => x.Status == "Received")</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-slash-circle"></i></span><div><div class="metric-label">Cancelled transfers</div><div class="metric-value">@rows.Count(x => x.Status == "Cancelled")</div></div></div></div>
<form method="get" class="filter-card mb-3"><div class="row g-3 align-items-end"><div class="col-lg-3"><label class="form-label">Search transfer</label><input asp-for="SearchText" class="form-control" placeholder="Transfer number" /></div><div class="col-lg-2"><label class="form-label">From location</label><select asp-for="SourceLocationId" class="form-select"><option value="">All</option>@foreach (var item in Model.Locations) { <option value="@item.LocationId">@item.LocationName</option> }</select></div><div class="col-lg-2"><label class="form-label">To location</label><select asp-for="DestinationLocationId" class="form-select"><option value="">All</option>@foreach (var item in Model.Locations) { <option value="@item.LocationId">@item.LocationName</option> }</select></div><div class="col-lg-2"><label class="form-label">Status</label><select asp-for="Status" class="form-select"><option value="">All</option><option>Draft</option><option>Sent</option><option>Received</option><option>Cancelled</option></select></div><div class="col-lg-1"><label class="form-label">From</label><input asp-for="FromDate" type="date" class="form-control" /></div><div class="col-lg-1"><label class="form-label">To</label><input asp-for="ToDate" type="date" class="form-control" /></div><div class="col-lg-1 d-flex gap-2"><button class="btn btn-primary w-100" type="submit"><i class="bi bi-search"></i></button><a class="btn btn-outline-secondary" asp-page="./Index"><i class="bi bi-x-lg"></i></a></div></div></form>
<section class="data-card"><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Transfer No</th><th>From Location</th><th>To Location</th><th>Status</th><th>Total Items</th><th>Created By</th><th>Created Date</th><th class="text-end">Action</th></tr></thead><tbody>@if (!rows.Any()) { <tr><td colspan="8"><div class="empty-state"><i class="bi bi-truck"></i><div class="fw-semibold">No stock transfers found</div><div>Create a transfer to move products between locations with movement audit records.</div></div></td></tr> } @foreach (var item in rows) { <tr><td><span class="code-badge mono">@item.TransferNo</span></td><td>@item.SourceLocationName</td><td>@item.DestinationLocationName</td><td><span class="badge status-badge @InventoryUi.StatusBadge(item.Status)">@item.Status</span></td><td>@item.Items.Count</td><td>@(item.CreatedByUserId?.ToString() ?? "-")</td><td>@item.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td><td class="text-end"><div class="dropdown"><button class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" type="button">Action</button><div class="dropdown-menu dropdown-menu-end action-menu"><button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#transferView-@item.StockTransferId" type="button"><i class="bi bi-eye"></i>View</button><button class="dropdown-item @(item.Status == "Draft" && Model.Permissions.CanUpdate ? "" : "disabled")" type="button"><i class="bi bi-pencil"></i>Edit if Draft</button><button class="dropdown-item @(item.Status == "Draft" && Model.Permissions.CanApprove ? "" : "disabled")" data-bs-toggle="modal" data-bs-target="#sendTransfer-@item.StockTransferId" type="button"><i class="bi bi-send"></i>Send</button><button class="dropdown-item @(item.Status == "Sent" ? "" : "disabled")" data-bs-toggle="modal" data-bs-target="#receiveTransfer-@item.StockTransferId" type="button"><i class="bi bi-box-arrow-in-down"></i>Receive</button><button class="dropdown-item text-danger @(item.Status is "Draft" or "Sent" && Model.Permissions.CanCancel ? "" : "disabled")" data-bs-toggle="modal" data-bs-target="#cancelTransfer-@item.StockTransferId" type="button"><i class="bi bi-slash-circle"></i>Cancel</button></div></div></td></tr> }</tbody></table></div><div class="d-flex justify-content-between align-items-center border-top pt-3 mt-3"><span class="text-muted">Total transfers: @Model.Transfers.TotalCount</span><div class="btn-group btn-group-sm"><a class="btn btn-outline-secondary @(Model.PageNumber <= 1 ? "disabled" : "")" asp-route-SearchText="@Model.SearchText" asp-route-SourceLocationId="@Model.SourceLocationId" asp-route-DestinationLocationId="@Model.DestinationLocationId" asp-route-Status="@Model.Status" asp-route-PageNumber="@(Model.PageNumber - 1)">Previous</a><span class="btn btn-outline-secondary disabled">@Model.PageNumber / @totalPages</span><a class="btn btn-outline-secondary @(Model.PageNumber >= totalPages ? "disabled" : "")" asp-route-SearchText="@Model.SearchText" asp-route-SourceLocationId="@Model.SourceLocationId" asp-route-DestinationLocationId="@Model.DestinationLocationId" asp-route-Status="@Model.Status" asp-route-PageNumber="@(Model.PageNumber + 1)">Next</a></div></div></section>
<div class="modal fade app-modal" id="createTransferModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable"><form method="post" asp-page-handler="Create" class="modal-content"><div class="modal-header"><div><h2 class="modal-title h5">Create Transfer</h2><p class="modal-subtitle">Sending creates TransferOut movements; receiving creates TransferIn movements.</p></div><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><div class="row g-3 mb-3"><div class="col-md-4"><label class="form-label required">From location</label><select name="Input.SourceLocationId" class="form-select" required data-stock-location-source data-stock-handler="?handler=ProductStock"><option value="">Select source</option>@foreach (var item in Model.Locations) { <option value="@item.LocationId">@item.LocationName</option> }</select></div><div class="col-md-4"><label class="form-label required">To location</label><select name="Input.DestinationLocationId" class="form-select" required><option value="">Select destination</option>@foreach (var item in Model.Locations) { <option value="@item.LocationId">@item.LocationName</option> }</select></div><div class="col-md-4"><label class="form-label">Description</label><input name="Input.Remarks" class="form-control" /></div></div><div class="table-responsive"><table class="table align-middle inventory-edit-table" data-transfer-table><thead><tr><th>Product</th><th>Available Qty</th><th>Transfer Qty</th><th>Unit</th><th></th></tr></thead><tbody>@for (var i = 0; i < 6; i++) { <tr><td><select name="Input.Items[@i].ProductId" class="form-select" data-product-select><option value="">Select product</option>@foreach (var p in Model.Products) { <option value="@p.ProductId" data-stock="@(Model.StockByProduct.GetValueOrDefault(p.ProductId))" data-cost="@p.CostPrice" data-unit="@p.UnitName">@p.ProductName</option> }</select><input type="hidden" name="Input.Items[@i].UnitCost" data-unit-cost /></td><td><input class="form-control" readonly data-available-qty value="0.00" /></td><td><input name="Input.Items[@i].Quantity" class="form-control" type="number" min="0" step="0.01" data-transfer-qty /></td><td><span class="text-muted" data-unit-label>-</span></td><td><button class="btn btn-outline-secondary btn-sm" type="button" data-clear-row><i class="bi bi-trash"></i></button></td></tr> }</tbody></table></div><div class="text-muted small">Transfer quantity cannot exceed available quantity unless an authorized backend flow explicitly allows it.</div></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-primary" type="submit">Save Draft</button></div></form></div></div>
@foreach (var item in rows) { <div class="modal fade app-modal" id="transferView-@item.StockTransferId" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content"><div class="modal-header"><div><h2 class="modal-title h5">Transfer Detail</h2><p class="modal-subtitle">@item.TransferNo</p></div><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><dl class="row detail-list"><dt class="col-4">From</dt><dd class="col-8">@item.SourceLocationName</dd><dt class="col-4">To</dt><dd class="col-8">@item.DestinationLocationName</dd><dt class="col-4">Status</dt><dd class="col-8"><span class="badge status-badge @InventoryUi.StatusBadge(item.Status)">@item.Status</span></dd></dl></div></div></div></div><div class="modal fade app-modal" id="sendTransfer-@item.StockTransferId" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="Send" class="modal-content"><input type="hidden" name="Action.Id" value="@item.StockTransferId" /><div class="modal-header"><h2 class="modal-title h5">Send Transfer</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body">Sending this transfer will create TransferOut movements from the source location.</div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-warning" type="submit">Send Transfer</button></div></form></div></div><div class="modal fade app-modal" id="receiveTransfer-@item.StockTransferId" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="Receive" class="modal-content"><input type="hidden" name="Action.Id" value="@item.StockTransferId" /><div class="modal-header"><h2 class="modal-title h5">Receive Transfer</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body">Receiving this transfer will create TransferIn movements at the destination location.</div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-primary" type="submit">Receive Transfer</button></div></form></div></div><div class="modal fade app-modal" id="cancelTransfer-@item.StockTransferId" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="Cancel" class="modal-content"><input type="hidden" name="Action.Id" value="@item.StockTransferId" /><div class="modal-header"><h2 class="modal-title h5">Cancel Transfer</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><label class="form-label required">Cancel reason</label><textarea name="Action.Reason" class="form-control" required></textarea></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Keep</button><button class="btn btn-outline-danger" type="submit">Cancel</button></div></form></div></div> }

