@page
@model AphiwatPOS.Pages.Inventory.Adjustment.IndexModel
@using AphiwatPOS.Pages.Inventory
@{
    ViewData["Title"] = "Stock Adjustment";
    ViewData["Subtitle"] = "Create, review, approve, reject, or cancel stock adjustments with reason tracking.";
    var rows = Model.Adjustments.Items.ToArray();
    var totalPages = InventoryUi.TotalPages(Model.Adjustments.TotalCount, Model.Adjustments.PageSize);
}

<partial name="_ProductToast" model="(Model.StatusMessage, Model.ErrorMessage)" />
<div class="page-header d-flex align-items-start justify-content-between gap-3" data-auto-open-scan-modal="#createAdjustmentModal" data-auto-open-scan-input="#createAdjustmentModal [data-barcode-scan-input]"><div><h1>Stock Adjustment</h1><p>Create, review, approve, reject, or cancel stock adjustments with reason tracking.</p><div class="text-muted small mt-1"><i class="bi bi-upc-scan me-1"></i>Scan a product barcode on this page to open Create Adjustment automatically.</div></div><button class="btn btn-primary @(Model.Permissions.CanCreate ? "" : "disabled")" data-bs-toggle="modal" data-bs-target="#createAdjustmentModal" type="button"><i class="bi bi-plus-lg me-1"></i>Create Adjustment</button></div>

<div class="summary-grid">
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-pencil-square"></i></span><div><div class="metric-label">Draft adjustments</div><div class="metric-value">@rows.Count(x => x.Status == "Draft")</div><div class="metric-helper">Waiting for review</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-hourglass-split"></i></span><div><div class="metric-label">Pending approval</div><div class="metric-value">@rows.Count(x => x.Status == "Draft")</div><div class="metric-helper">Drafts can be approved</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-check-circle"></i></span><div><div class="metric-label">Approved adjustments</div><div class="metric-value">@rows.Count(x => x.Status == "Approved")</div><div class="metric-helper">Movements created</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-slash-circle"></i></span><div><div class="metric-label">Cancelled/rejected</div><div class="metric-value">@rows.Count(x => x.Status is "Cancelled" or "Rejected")</div><div class="metric-helper">No stock impact</div></div></div>
</div>

<form method="get" class="filter-card mb-3"><div class="row g-3 align-items-end">
    <div class="col-lg-3"><label class="form-label">Search adjustment</label><input asp-for="SearchText" class="form-control" placeholder="Adjustment number or reason" /></div>
    <div class="col-lg-2"><label class="form-label">Location</label><select asp-for="LocationId" class="form-select"><option value="">All</option>@foreach (var item in Model.Locations) { <option value="@item.LocationId">@item.LocationName</option> }</select></div>
    <div class="col-lg-2"><label class="form-label">Status</label><select asp-for="Status" class="form-select"><option value="">All</option><option>Draft</option><option>Pending</option><option>Approved</option><option>Rejected</option><option>Cancelled</option></select></div>
    <div class="col-lg-2"><label class="form-label">Date from</label><input asp-for="FromDate" type="date" class="form-control" /></div>
    <div class="col-lg-2"><label class="form-label">Date to</label><input asp-for="ToDate" type="date" class="form-control" /></div>
    <div class="col-lg-1 d-flex gap-2"><button class="btn btn-primary w-100" type="submit"><i class="bi bi-search"></i></button><a class="btn btn-outline-secondary" asp-page="./Index"><i class="bi bi-x-lg"></i></a></div>
</div></form>

<section class="data-card"><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Adjustment No</th><th>Location</th><th>Reason</th><th>Status</th><th>Total Items</th><th>Created By</th><th>Created Date</th><th class="text-end">Action</th></tr></thead><tbody>
@if (!rows.Any()) { <tr><td colspan="8"><div class="empty-state"><i class="bi bi-sliders"></i><div class="fw-semibold">No stock adjustments found</div><div>Create a draft adjustment to correct stock with an audit trail.</div></div></td></tr> }
@foreach (var item in rows)
{
    <tr><td><span class="code-badge mono">@item.AdjustmentNo</span></td><td>@item.LocationName</td><td class="text-truncate" style="max-width:260px">@item.Reason</td><td><span class="badge status-badge @InventoryUi.StatusBadge(item.Status)">@item.Status</span></td><td>@item.Items.Count</td><td>@(item.CreatedByUserId?.ToString() ?? "-")</td><td>@item.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td><td class="text-end"><div class="dropdown"><button class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" type="button">Action</button><div class="dropdown-menu dropdown-menu-end action-menu"><button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#adjustmentView-@item.StockAdjustmentId" type="button"><i class="bi bi-eye"></i>View</button><button class="dropdown-item @(item.Status == "Draft" && Model.Permissions.CanUpdate ? "" : "disabled")" type="button"><i class="bi bi-pencil"></i>Edit if Draft</button><button class="dropdown-item @(item.Status == "Draft" && Model.Permissions.CanApprove ? "" : "disabled")" data-bs-toggle="modal" data-bs-target="#approveAdjustment-@item.StockAdjustmentId" type="button"><i class="bi bi-check2-circle"></i>Approve</button><button class="dropdown-item @(item.Status == "Draft" && Model.Permissions.CanCancel ? "" : "disabled")" data-bs-toggle="modal" data-bs-target="#rejectAdjustment-@item.StockAdjustmentId" type="button"><i class="bi bi-x-circle"></i>Reject</button><button class="dropdown-item text-danger @(item.Status == "Draft" && Model.Permissions.CanCancel ? "" : "disabled")" data-bs-toggle="modal" data-bs-target="#cancelAdjustment-@item.StockAdjustmentId" type="button"><i class="bi bi-slash-circle"></i>Cancel</button></div></div></td></tr>
}
</tbody></table></div><div class="d-flex justify-content-between align-items-center border-top pt-3 mt-3"><span class="text-muted">Total adjustments: @Model.Adjustments.TotalCount</span><div class="btn-group btn-group-sm"><a class="btn btn-outline-secondary @(Model.PageNumber <= 1 ? "disabled" : "")" asp-route-SearchText="@Model.SearchText" asp-route-LocationId="@Model.LocationId" asp-route-Status="@Model.Status" asp-route-PageNumber="@(Model.PageNumber - 1)">Previous</a><span class="btn btn-outline-secondary disabled">@Model.PageNumber / @totalPages</span><a class="btn btn-outline-secondary @(Model.PageNumber >= totalPages ? "disabled" : "")" asp-route-SearchText="@Model.SearchText" asp-route-LocationId="@Model.LocationId" asp-route-Status="@Model.Status" asp-route-PageNumber="@(Model.PageNumber + 1)">Next</a></div></div></section>

<div class="modal fade app-modal" id="createAdjustmentModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable"><form method="post" asp-page-handler="Create" class="modal-content" data-inventory-form><div class="modal-header"><div><h2 class="modal-title h5">Create Adjustment</h2><p class="modal-subtitle">Approving this adjustment will create inventory movement records.</p></div><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body">
    <div class="row g-3 mb-3"><div class="col-md-4"><label class="form-label required">Location</label><select name="Input.LocationId" class="form-select" required data-stock-location-source data-stock-handler="?handler=ProductStock"><option value="">Select location</option>@foreach (var item in Model.Locations) { <option value="@item.LocationId">@item.LocationName</option> }</select></div><div class="col-md-8"><label class="form-label required">Adjustment reason</label><textarea name="Input.Reason" class="form-control" rows="2" required></textarea></div><div class="col-md-5"><label class="form-label">Scan barcode / SKU / code</label><div class="input-group"><span class="input-group-text"><i class="bi bi-upc-scan"></i></span><input class="form-control" data-barcode-scan-input data-scan-target="[data-adjustment-table]" placeholder="Scan barcode then press Enter" autocomplete="off" /></div><div class="text-muted small mt-1" data-scan-feedback>Scanner input will add the product to the first empty row.</div></div><div class="col-md-7"><label class="form-label">Remarks</label><textarea name="Input.Remarks" class="form-control" rows="2"></textarea></div></div>
    <div class="section-label">Items</div><div class="table-responsive"><table class="table align-middle inventory-edit-table" data-adjustment-table><thead><tr><th>Product</th><th>Current Qty</th><th>Type</th><th>Adjustment Qty</th><th>New Qty</th><th>Item Reason</th><th></th></tr></thead><tbody>@for (var i = 0; i < 5; i++) { <tr><td><select name="Input.Items[@i].ProductId" class="form-select" data-product-select><option value="">Select product</option>@foreach (var p in Model.Products) { <option value="@p.ProductId" data-stock="@(Model.StockByProduct.GetValueOrDefault(p.ProductId))" data-cost="@p.CostPrice" data-barcode="@p.Barcode" data-sku="@p.SKU" data-code="@p.ProductCode">@p.ProductName</option> }</select><input type="hidden" name="Input.Items[@i].UnitCost" data-unit-cost /></td><td><input class="form-control" readonly data-current-qty value="0.00" /></td><td><select name="Input.Items[@i].AdjustmentType" class="form-select" data-adjustment-type><option>Increase</option><option>Decrease</option></select></td><td><input name="Input.Items[@i].Quantity" class="form-control" type="number" min="0" step="0.01" data-adjustment-qty /></td><td><input class="form-control" readonly data-new-qty /></td><td><input name="Input.Items[@i].Reason" class="form-control" placeholder="Reason" /></td><td><button class="btn btn-outline-secondary btn-sm" type="button" data-clear-row><i class="bi bi-trash"></i></button></td></tr> }</tbody></table></div>
    <div class="text-muted small">Reason is required and adjustment quantity must be greater than zero for saved rows. Decreases that would create negative stock are rejected by the inventory movement procedure.</div>
</div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-outline-secondary" type="submit" name="Input.SubmitForApproval" value="false">Save Draft</button><button class="btn btn-primary" type="submit" name="Input.SubmitForApproval" value="true">Submit for Approval</button></div></form></div></div>

@foreach (var item in rows)
{
    <div class="modal fade app-modal" id="adjustmentView-@item.StockAdjustmentId" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content"><div class="modal-header"><div><h2 class="modal-title h5">Adjustment Detail</h2><p class="modal-subtitle">@item.AdjustmentNo</p></div><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><dl class="row detail-list"><dt class="col-4">Location</dt><dd class="col-8">@item.LocationName</dd><dt class="col-4">Reason</dt><dd class="col-8">@item.Reason</dd><dt class="col-4">Status</dt><dd class="col-8"><span class="badge status-badge @InventoryUi.StatusBadge(item.Status)">@item.Status</span></dd></dl></div></div></div></div>
    <div class="modal fade app-modal" id="approveAdjustment-@item.StockAdjustmentId" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="Approve" class="modal-content"><input type="hidden" name="Action.Id" value="@item.StockAdjustmentId" /><div class="modal-header"><h2 class="modal-title h5">Approve Adjustment</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><p>Approving this adjustment will create inventory movement records.</p><strong>@item.AdjustmentNo</strong></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-primary" type="submit">Approve</button></div></form></div></div>
    <div class="modal fade app-modal" id="rejectAdjustment-@item.StockAdjustmentId" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="Reject" class="modal-content"><input type="hidden" name="Action.Id" value="@item.StockAdjustmentId" /><div class="modal-header"><h2 class="modal-title h5">Reject Adjustment</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><label class="form-label required">Reject reason</label><textarea name="Action.Reason" class="form-control" required></textarea></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-outline-danger" type="submit">Reject</button></div></form></div></div>
    <div class="modal fade app-modal" id="cancelAdjustment-@item.StockAdjustmentId" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="Cancel" class="modal-content"><input type="hidden" name="Action.Id" value="@item.StockAdjustmentId" /><div class="modal-header"><h2 class="modal-title h5">Cancel Adjustment</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><label class="form-label required">Cancel reason</label><textarea name="Action.Reason" class="form-control" required></textarea></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Keep Draft</button><button class="btn btn-outline-danger" type="submit">Cancel</button></div></form></div></div>
}
