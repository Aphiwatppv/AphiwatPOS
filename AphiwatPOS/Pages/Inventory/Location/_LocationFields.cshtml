@model InventoryEngine.Models.InventoryLocationModel?
@{
    var generatedLocationCode = ViewData["GeneratedLocationCode"] as string;
    var locationCode = Model?.LocationCode ?? generatedLocationCode ?? string.Empty;
}
<input type="hidden" name="Input.LocationId" value="@(Model?.LocationId ?? 0)" />
<div class="modal-form-grid">
    <div>
        <label class="form-label required">Location Code</label>
        <input class="form-control" name="Input.LocationCode" value="@locationCode" readonly required />
        <div class="form-text">Created automatically by the system.</div>
    </div>
    <div><label class="form-label required">Location Name</label><input class="form-control" name="Input.LocationName" value="@Model?.LocationName" required /></div>
    <div class="span-2"><label class="form-label">Description</label><textarea class="form-control" name="Input.Description" rows="3">@Model?.Description</textarea></div>
    <div class="span-2 d-flex gap-3">
        <label class="form-check form-switch"><input class="form-check-input" name="Input.IsDefault" type="checkbox" value="true" checked="@(Model?.IsDefault ?? false)" /><input type="hidden" name="Input.IsDefault" value="false" /><span class="form-check-label">Default Location</span></label>
        <label class="form-check form-switch"><input class="form-check-input" name="Input.IsActive" type="checkbox" value="true" checked="@(Model?.IsActive ?? true)" /><input type="hidden" name="Input.IsActive" value="false" /><span class="form-check-label">Active</span></label>
    </div>
</div>
