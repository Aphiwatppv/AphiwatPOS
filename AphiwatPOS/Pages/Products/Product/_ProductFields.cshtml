@model ProductEngine.Models.ProductModel?
@{
    var categories = ViewData["Categories"] as IReadOnlyCollection<ProductEngine.Models.ProductCategoryModel> ?? Array.Empty<ProductEngine.Models.ProductCategoryModel>();
    var brands = ViewData["Brands"] as IReadOnlyCollection<ProductEngine.Models.ProductBrandModel> ?? Array.Empty<ProductEngine.Models.ProductBrandModel>();
    var units = ViewData["Units"] as IReadOnlyCollection<ProductEngine.Models.ProductUnitModel> ?? Array.Empty<ProductEngine.Models.ProductUnitModel>();
    var productCode = Model?.ProductCode ?? ViewData["NextProductCode"] as string ?? string.Empty;
    var barcode = Model?.Barcode ?? ViewData["PrefillBarcode"] as string;
    var wholesaleMinQty = Model is not null && Model.WholesaleMinQty > 0 ? Model.WholesaleMinQty : 1;
}
<input type="hidden" name="ProductInput.ProductId" value="@(Model?.ProductId ?? 0)" />
<input type="hidden" name="ProductInput.ExistingImageUrl" value="@Model?.ProductImageUrl" />
<div class="modal-form-grid">
    <div><label class="form-label">Product Code</label><input class="form-control" name="ProductInput.ProductCode" value="@productCode" readonly required /><div class="text-muted small mt-1">Generated automatically.</div></div>
    <div><label class="form-label">Product Name</label><input class="form-control" name="ProductInput.ProductName" value="@Model?.ProductName" required data-product-name-input /></div>
    <div><label class="form-label">SKU</label><input class="form-control" name="ProductInput.SKU" value="@Model?.SKU" /></div>
    <div><label class="form-label">Barcode</label><input class="form-control" name="ProductInput.Barcode" value="@barcode" /></div>
    <div><label class="form-label">Category</label><select class="form-select" name="ProductInput.CategoryId" required><option value="">Select category</option>@foreach (var item in categories) { <option value="@item.CategoryId" selected="@(Model?.CategoryId == item.CategoryId)">@item.CategoryName</option> }</select></div>
    <div><label class="form-label">Brand</label><select class="form-select" name="ProductInput.BrandId"><option value="">No brand</option>@foreach (var item in brands) { <option value="@item.BrandId" selected="@(Model?.BrandId == item.BrandId)">@item.BrandName</option> }</select></div>
    <div><label class="form-label">Unit</label><select class="form-select" name="ProductInput.UnitId" required><option value="">Select unit</option>@foreach (var item in units) { <option value="@item.UnitId" selected="@(Model?.UnitId == item.UnitId)">@item.UnitName</option> }</select></div>
    <div><label class="form-label">Status</label><select class="form-select" name="ProductInput.Status"><option selected="@(Model?.Status == "Active" || Model is null)">Active</option><option selected="@(Model?.Status == "Inactive")">Inactive</option><option selected="@(Model?.Status == "Discontinued")">Discontinued</option><option selected="@(Model?.Status == "Draft")">Draft</option></select></div>
    <div><label class="form-label">Cost Price</label><input class="form-control" name="ProductInput.CostPrice" type="number" step="0.01" min="0" value="@(Model?.CostPrice ?? 0)" /></div>
    <div><label class="form-label">Selling Price</label><input class="form-control" name="ProductInput.SellingPrice" type="number" step="0.01" min="0" value="@(Model?.SellingPrice ?? 0)" /></div>
    <div><label class="form-label">Wholesale Price</label><input class="form-control" name="ProductInput.WholesalePrice" type="number" step="0.01" min="0" value="@(Model?.WholesalePrice ?? 0)" /></div>
    <div><label class="form-label">Wholesale Min Qty</label><input class="form-control" name="ProductInput.WholesaleMinQty" type="number" step="0.01" min="0" value="@wholesaleMinQty" /></div>
    <div><label class="form-label">Tax Rate</label><input class="form-control" name="ProductInput.TaxRate" type="number" step="0.01" min="0" max="100" value="@(Model?.TaxRate ?? 0)" /></div>
    <div><label class="form-label">Minimum Stock Level</label><input class="form-control" name="ProductInput.MinimumStockLevel" type="number" step="0.01" min="0" value="@(Model?.MinimumStockLevel ?? 0)" /></div>
    <div class="d-flex align-items-end gap-3"><label class="form-check form-switch"><input class="form-check-input" name="ProductInput.DiscountAllowed" type="checkbox" value="true" checked="@(Model?.DiscountAllowed ?? true)" /><input type="hidden" name="ProductInput.DiscountAllowed" value="false" /><span class="form-check-label">Discount Allowed</span></label><label class="form-check form-switch"><input class="form-check-input" name="ProductInput.IsStockTracked" type="checkbox" value="true" checked="@(Model?.IsStockTracked ?? true)" /><input type="hidden" name="ProductInput.IsStockTracked" value="false" /><span class="form-check-label">Stock Tracked</span></label></div>
    <div class="span-2"><div class="alert alert-success py-2 mb-0"><i class="bi bi-shield-check me-1"></i>Stock quantity is managed from Inventory through stock movements, adjustments, counts, and transfers.</div></div>
    <div class="span-2"><label class="form-label">Product Image</label><div class="d-flex gap-3 align-items-center"><div class="image-preview-box" data-image-preview="product-@(Model?.ProductId ?? 0)">@if (!string.IsNullOrWhiteSpace(Model?.ProductImageUrl)) { <img src="@Model.ProductImageUrl" alt="@Model.ProductName" /> } else { <i class="bi bi-image"></i> }</div><input class="form-control" name="ProductInput.ProductImage" type="file" accept=".jpg,.jpeg,.png,.webp" data-image-input="product-@(Model?.ProductId ?? 0)" /></div></div>
    <div class="span-2"><label class="form-label">Description</label><textarea class="form-control" name="ProductInput.Description" rows="3">@Model?.Description</textarea></div>
    <div class="span-2"><label class="form-check form-switch"><input class="form-check-input" name="ProductInput.IsActive" type="checkbox" value="true" checked="@(Model?.IsActive ?? true)" /><input type="hidden" name="ProductInput.IsActive" value="false" /><span class="form-check-label">Active</span></label></div>
</div>
<div class="alert alert-danger py-2 mt-3 d-none" data-validation-area>Validation messages appear here.</div>
