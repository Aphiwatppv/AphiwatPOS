@model ValueTuple<string?, string?>
@{
    var status = Model.Item1;
    var error = Model.Item2;
}
<div class="toast-container position-fixed top-0 end-0 p-3">
    @if (!string.IsNullOrWhiteSpace(status))
    {
        <div class="toast show align-items-center border-0 alert-success" role="status">
            <div class="d-flex"><div class="toast-body"><i class="bi bi-check-circle me-2"></i>@status</div><button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button></div>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="toast show align-items-center border-0 alert-danger" role="alert">
            <div class="d-flex"><div class="toast-body"><i class="bi bi-exclamation-triangle me-2"></i>@error</div><button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button></div>
        </div>
    }
</div>
