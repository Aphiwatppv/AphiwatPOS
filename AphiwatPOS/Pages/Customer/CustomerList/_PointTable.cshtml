@model IEnumerable<CustomerEngine.Models.CustomerPointHistoryModel>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Created</th><th>Type</th><th>Points In</th><th>Points Out</th><th>Balance</th><th>Reference</th><th>Remark</th></tr></thead><tbody>@if (!Model.Any()) { <tr><td colspan="7"><div class="empty-state"><i class="bi bi-stars"></i><div class="fw-semibold">No point history</div></div></td></tr> } @foreach (var x in Model) { <tr><td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.DateTimeText(x.CreatedDate)</td><td><partial name="/Pages/Customer/Shared/_PointMovementBadge.cshtml" model="x.MovementType" /></td><td class="text-success">@x.PointsIn.ToString("N2")</td><td class="text-danger">@x.PointsOut.ToString("N2")</td><td>@x.BalanceAfter.ToString("N2")</td><td>@x.ReferenceNo</td><td>@x.Remark</td></tr> }</tbody></table></div>
