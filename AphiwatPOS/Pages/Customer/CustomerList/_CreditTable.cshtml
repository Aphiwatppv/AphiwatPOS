@model IEnumerable<CustomerEngine.Models.CustomerCreditHistoryModel>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Created</th><th>Type</th><th>Amount</th><th>Due</th><th>Paid</th><th>Status</th><th>Reference</th><th>Remark</th></tr></thead><tbody>@if (!Model.Any()) { <tr><td colspan="8"><div class="empty-state"><i class="bi bi-credit-card"></i><div class="fw-semibold">No credit history</div></div></td></tr> } @foreach (var x in Model) { <tr><td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.DateTimeText(x.CreatedDate)</td><td>@x.TransactionType</td><td>@x.Amount.ToString("N2")</td><td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.Date(x.DueDate)</td><td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.DateTimeText(x.PaidDate)</td><td>@x.Status</td><td>@x.ReferenceNo</td><td>@x.Remark</td></tr> }</tbody></table></div>
