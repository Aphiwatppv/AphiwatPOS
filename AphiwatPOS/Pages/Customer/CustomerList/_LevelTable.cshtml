@model IEnumerable<CustomerEngine.Models.CustomerLevelHistoryModel>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Changed Date</th><th>Old Level</th><th>New Level</th><th>Reason</th><th>Changed By</th></tr></thead><tbody>@if (!Model.Any()) { <tr><td colspan="5"><div class="empty-state"><i class="bi bi-gem"></i><div class="fw-semibold">No level history</div></div></td></tr> } @foreach (var x in Model) { <tr><td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.DateTimeText(x.ChangedDate)</td><td>@x.OldMemberLevelName</td><td>@x.NewMemberLevelName</td><td>@x.ChangeReason</td><td>@x.ChangedByName</td></tr> }</tbody></table></div>
