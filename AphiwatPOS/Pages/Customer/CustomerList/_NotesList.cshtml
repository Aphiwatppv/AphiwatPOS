@model IEnumerable<CustomerEngine.Models.CustomerNoteModel>
<div class="row g-3">@if (!Model.Any()) { <div class="col-12"><div class="empty-state"><i class="bi bi-sticky"></i><div class="fw-semibold">No notes</div></div></div> } @foreach (var x in Model.OrderByDescending(n => n.IsImportant).ThenByDescending(n => n.CreatedDate)) { <div class="col-md-6"><div class="filter-card h-100 @(x.IsImportant ? "border-warning" : "")"><div class="d-flex justify-content-between"><span class="badge status-badge @(x.IsImportant ? "badge-warning" : "badge-muted")">@x.NoteType</span><small class="text-muted">@AphiwatPOS.Pages.Customer.CustomerPageHelpers.DateTimeText(x.CreatedDate)</small></div><p class="mt-2 mb-1">@x.NoteText</p><small class="text-muted">Created by @x.CreatedByUserId</small></div></div> }</div>
