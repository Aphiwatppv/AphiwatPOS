@model IEnumerable<CustomerEngine.Models.CustomerPurchaseHistoryModel>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Sale No</th><th>Sale Date</th><th>Total</th><th>Discount</th><th>Net</th><th>Payment</th><th>Status</th><th>Created By</th></tr></thead><tbody>@if (!Model.Any()) { <tr><td colspan="8"><div class="empty-state"><i class="bi bi-receipt"></i><div class="fw-semibold">No purchase history</div></div></td></tr> } @foreach (var x in Model) { <tr><td>@x.SaleNo</td><td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.DateTimeText(x.SaleDate)</td><td>@x.TotalAmount.ToString("N2")</td><td>@x.DiscountAmount.ToString("N2")</td><td>@x.NetAmount.ToString("N2")</td><td>@x.PaymentStatus</td><td>@x.SaleStatus</td><td>@x.CreatedByName</td></tr> }</tbody></table></div>
