@model IEnumerable<CustomerEngine.Models.CustomerTimelineModel>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Date</th><th>Type</th><th>Reference</th><th>Title</th><th>Description</th><th>Amount</th><th>Points</th><th>Status</th><th>Created By</th></tr></thead><tbody>@if (!Model.Any()) { <tr><td colspan="9"><div class="empty-state"><i class="bi bi-clock-history"></i><div class="fw-semibold">No activity found</div></div></td></tr> } @foreach (var x in Model) { <tr><td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.DateTimeText(x.ActivityDate)</td><td><span class="badge status-badge badge-muted">@x.HistoryType</span></td><td>@(x.ReferenceNo ?? "-")</td><td>@x.Title</td><td>@x.Description</td><td>@(x.Amount?.ToString("N2") ?? "-")</td><td>@(x.Points?.ToString("N2") ?? "-")</td><td>@(x.Status ?? "-")</td><td>@x.CreatedByName</td></tr> }</tbody></table></div>
