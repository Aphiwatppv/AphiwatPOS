@model IEnumerable<CustomerEngine.Models.CustomerPaymentHistoryModel>
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Payment Date</th><th>Sale No</th><th>Method</th><th>Amount</th><th>Reference</th><th>Status</th><th>Created By</th></tr></thead><tbody>@if (!Model.Any()) { <tr><td colspan="7"><div class="empty-state"><i class="bi bi-wallet2"></i><div class="fw-semibold">No payment history</div></div></td></tr> } @foreach (var x in Model) { <tr><td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.DateTimeText(x.PaymentDate)</td><td>@x.SaleNo</td><td>@x.PaymentMethod</td><td>@x.Amount.ToString("N2")</td><td>@x.ReferenceNo</td><td>@x.PaymentStatus</td><td>@x.CreatedByName</td></tr> }</tbody></table></div>
