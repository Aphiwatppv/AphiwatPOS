@page
@model AphiwatPOS.Pages.Customer.CustomerList.IndexModel
@using CustomerEngine.Models
@{
    ViewData["Title"] = "Customer List";
    ViewData["Subtitle"] = "Manage customers, membership, points, and credit status.";
    ViewData["MemberLevels"] = Model.MemberLevels;
    var rows = Model.Customers.Customers.ToArray();
    string q(int page) => Url.Page("./Index", new { Model.SearchText, Model.MemberLevelId, Model.CreditStatus, Model.IsActive, PageNumber = page }) ?? "#";
}
<partial name="/Pages/Customer/Shared/_TempDataAlert.cshtml" model="(Model.StatusMessage, Model.ErrorMessage)" />
<div class="page-header d-flex align-items-start justify-content-between gap-3">
    <div><h1>Customer List</h1><p>Manage customers, membership, points, and credit status.</p></div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#customerAddModal" type="button"><i class="bi bi-person-plus me-1"></i>Add Customer</button>
</div>
<div class="summary-grid">
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-people"></i></span><div><div class="metric-label">Total Customers</div><div class="metric-value">@Model.Summary.TotalCustomers</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-check-circle"></i></span><div><div class="metric-label">Active Customers</div><div class="metric-value">@Model.Summary.ActiveCustomers</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-gem"></i></span><div><div class="metric-label">VIP Customers</div><div class="metric-value">@rows.Count(x => string.Equals(x.MemberLevelName, "VIP", StringComparison.OrdinalIgnoreCase))</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-stars"></i></span><div><div class="metric-label">Available Points</div><div class="metric-value">@Model.Summary.TotalAvailablePoints.ToString("N2")</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-credit-card"></i></span><div><div class="metric-label">Outstanding Credit</div><div class="metric-value">@CustomerPageHelpers.Money(Model.Summary.TotalOutstandingCredit)</div></div></div>
</div>
<form method="get" class="filter-card mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-lg-4"><label class="form-label">Search customer</label><input asp-for="SearchText" class="form-control" placeholder="Code, name, phone, email" /></div>
        <div class="col-lg-2"><label class="form-label">Member Level</label><select asp-for="MemberLevelId" class="form-select"><option value="">All</option>@foreach (var level in Model.MemberLevels) { <option value="@level.MemberLevelId">@level.LevelName</option> }</select></div>
        <div class="col-lg-2"><label class="form-label">Credit Status</label><select asp-for="CreditStatus" class="form-select"><option value="">All</option><option>Good</option><option>Hold</option><option>Blocked</option></select></div>
        <div class="col-lg-2"><label class="form-label">Active Status</label><select asp-for="IsActive" class="form-select"><option value="">All</option><option value="true">Active</option><option value="false">Inactive</option></select></div>
        <div class="col-lg-2 d-flex gap-2"><button class="btn btn-primary w-100" type="submit"><i class="bi bi-search"></i></button><a class="btn btn-outline-secondary" asp-page="./Index"><i class="bi bi-arrow-counterclockwise"></i></a></div>
    </div>
</form>
<section class="data-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead><tr><th>Customer</th><th>Phone</th><th>Email</th><th>Level</th><th>Points</th><th>Credit Limit</th><th>Used</th><th>Available</th><th>Credit</th><th>Total Spending</th><th>Last Purchase</th><th>Status</th><th class="text-end">Action</th></tr></thead>
            <tbody>
            @if (!rows.Any()) { <tr><td colspan="13"><div class="empty-state"><i class="bi bi-people"></i><div class="fw-semibold">No customers found</div><div>Try another filter or add a customer.</div></div></td></tr> }
            @foreach (var item in rows)
            {
                <tr>
                    <td><span class="fw-semibold d-block">@item.CustomerName</span><span class="text-muted small">@item.CustomerCode</span></td>
                    <td>@item.PhoneNumber</td><td>@(item.Email ?? "-")</td>
                    <td><partial name="/Pages/Customer/Shared/_MemberLevelBadge.cshtml" model="@(item.MemberLevelName ?? "Normal")" /></td>
                    <td class="text-success fw-semibold">@item.AvailablePoints.ToString("N2")</td>
                    <td>@item.CreditLimit.ToString("N2")</td><td class="text-danger">@item.CurrentOutstandingAmount.ToString("N2")</td><td>@item.AvailableCredit.ToString("N2")</td>
                    <td><partial name="/Pages/Customer/Shared/_CreditStatusBadge.cshtml" model="item.CreditStatus" /></td>
                    <td>@item.TotalSpending.ToString("N2")</td><td>@CustomerPageHelpers.Date(item.LastPurchaseDate)</td>
                    <td><partial name="/Pages/Customer/Shared/_CustomerStatusBadge.cshtml" model="item.IsActive" /></td>
                    <td class="text-end">
                        <div class="dropdown"><button class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" type="button">Action</button>
                            <div class="dropdown-menu dropdown-menu-end action-menu">
                                <a class="dropdown-item" asp-page="./Detail" asp-route-customerId="@item.CustomerId"><i class="bi bi-eye"></i>View Detail</a>
                                <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#customerEdit-@item.CustomerId" type="button"><i class="bi bi-pencil"></i>Edit Customer</button>
                                <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#creditSet-@item.CustomerId" type="button"><i class="bi bi-credit-card"></i>Set Credit</button>
                                <a class="dropdown-item" asp-page="/Customer/CustomerHistory/Index" asp-route-CustomerId="@item.CustomerId"><i class="bi bi-clock-history"></i>View History</a>
                                <a class="dropdown-item" asp-page="/Customer/LoyaltyPoints/Index" asp-route-CustomerId="@item.CustomerId"><i class="bi bi-stars"></i>View Points</a>
                                <form method="post" asp-page-handler="ToggleActive" asp-route-customerId="@item.CustomerId" asp-route-isActive="@(!item.IsActive)"><button class="dropdown-item @(item.IsActive ? "text-danger" : "text-success")" type="submit"><i class="bi bi-power"></i>@(item.IsActive ? "Deactivate" : "Activate")</button></form>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="/Pages/Customer/Shared/_Pagination.cshtml" model="new AphiwatPOS.Pages.Customer.Shared.CustomerPaginationModel { PageNumber = Model.Customers.PageNumber, PageSize = Model.Customers.PageSize, TotalCount = Model.Customers.TotalCount, PageUrl = q }" />
</section>

<div class="modal fade app-modal" id="customerAddModal" tabindex="-1"><div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable"><form method="post" asp-page-handler="Create" class="modal-content"><div class="modal-header"><div><h2 class="modal-title h5">Add Customer</h2><p class="modal-subtitle">Customer code may be auto-generated.</p></div><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><partial name="_CustomerForm" model="null" /></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-primary" type="submit">Save Customer</button></div></form></div></div>
@foreach (var item in rows)
{
    <div class="modal fade app-modal" id="customerEdit-@item.CustomerId" tabindex="-1"><div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable"><form method="post" asp-page-handler="Update" class="modal-content"><div class="modal-header"><div><h2 class="modal-title h5">Edit Customer</h2><p class="modal-subtitle">@item.CustomerCode</p></div><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><partial name="_CustomerForm" model="item" /></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-primary" type="submit">Save Changes</button></div></form></div></div>
    <div class="modal fade app-modal" id="creditSet-@item.CustomerId" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="SetCredit" class="modal-content"><div class="modal-header"><h2 class="modal-title h5">Set Credit</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><input type="hidden" name="CreditInput.CustomerId" value="@item.CustomerId" /><div class="form-check form-switch mb-3"><input class="form-check-input" name="CreditInput.AllowCredit" value="true" type="checkbox" checked="@(item.CreditLimit > 0)" /><input type="hidden" name="CreditInput.AllowCredit" value="false" /><label class="form-check-label">Allow Credit</label></div><div class="row g-3"><div class="col-md-6"><label class="form-label">Credit Limit</label><input class="form-control" name="CreditInput.CreditLimit" type="number" step="0.01" min="0" value="@item.CreditLimit" /></div><div class="col-md-6"><label class="form-label">Credit Term Days</label><input class="form-control" name="CreditInput.CreditTermDays" type="number" min="0" value="0" /></div><div class="col-md-6"><label class="form-label">Credit Status</label><select class="form-select" name="CreditInput.CreditStatus"><option selected="@(item.CreditStatus=="Good")">Good</option><option selected="@(item.CreditStatus=="Hold")">Hold</option><option selected="@(item.CreditStatus=="Blocked")">Blocked</option></select></div><div class="col-md-6 d-flex align-items-end"><label class="form-check"><input class="form-check-input" name="CreditInput.RequireManagerApproval" value="true" type="checkbox" /><input type="hidden" name="CreditInput.RequireManagerApproval" value="false" /> Require Manager Approval</label></div><div class="col-12"><label class="form-label">Remark</label><textarea class="form-control" name="CreditInput.Remark" rows="3"></textarea></div></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-primary" type="submit">Save Credit</button></div></form></div></div>
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
