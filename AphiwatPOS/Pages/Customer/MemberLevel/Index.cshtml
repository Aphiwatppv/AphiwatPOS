@page
@model AphiwatPOS.Pages.Customer.MemberLevel.IndexModel
@{
    ViewData["Title"] = "Member Level";
    ViewData["Subtitle"] = "Configure customer tiers, discounts, points, credit, and upgrade conditions.";
    var rows = Model.Levels.OrderBy(x => x.DisplayOrder).ToArray();
    var rules = Model.Rules.ToDictionary(x => x.FromMemberLevelId);
}
<partial name="/Pages/Customer/Shared/_TempDataAlert.cshtml" model="(Model.StatusMessage, Model.ErrorMessage)" />
<div class="page-header d-flex align-items-start justify-content-between gap-3"><div><h1>Member Level</h1><p>Configure customer tiers, discounts, points, credit, and upgrade conditions.</p></div><button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#levelAddModal"><i class="bi bi-plus-lg"></i> Add Level</button></div>
<div class="summary-grid">
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-layers"></i></span><div><div class="metric-label">Total Levels</div><div class="metric-value">@rows.Length</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-check-circle"></i></span><div><div class="metric-label">Active Levels</div><div class="metric-value">@rows.Count(x => x.IsActive)</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-credit-card"></i></span><div><div class="metric-label">Credit Enabled</div><div class="metric-value">@rows.Count(x => x.AllowCredit)</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-percent"></i></span><div><div class="metric-label">Highest Discount</div><div class="metric-value">@rows.Select(x => x.DiscountPercent).DefaultIfEmpty().Max().ToString("N2")%</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-cash-stack"></i></span><div><div class="metric-label">Highest Credit</div><div class="metric-value">@rows.Select(x => x.DefaultCreditLimit).DefaultIfEmpty().Max().ToString("N2")</div></div></div>
</div>
<section class="data-card"><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Order</th><th>Code</th><th>Name</th><th>Min Spending</th><th>Discount</th><th>Point Rule</th><th>Multiplier</th><th>Credit</th><th>Limit</th><th>Term</th><th>Approval</th><th>Status</th><th class="text-end">Action</th></tr></thead><tbody>@foreach (var x in rows) { <tr><td>@x.DisplayOrder</td><td>@x.LevelCode</td><td><partial name="/Pages/Customer/Shared/_MemberLevelBadge.cshtml" model="x.LevelName" /></td><td>@x.MinSpendingAmount.ToString("N2")</td><td>@x.DiscountPercent.ToString("N2")%</td><td>@x.PointEarnPoint.ToString("N2") / @x.PointEarnAmount.ToString("N2")</td><td>@x.PointMultiplier.ToString("N2")x</td><td>@(x.AllowCredit ? "Yes" : "No")</td><td>@x.DefaultCreditLimit.ToString("N2")</td><td>@x.DefaultCreditTermDays days</td><td>@(x.RequireManagerApprovalForCredit ? "Required" : "-")</td><td><partial name="/Pages/Customer/Shared/_CustomerStatusBadge.cshtml" model="x.IsActive" /></td><td class="text-end"><div class="dropdown"><button class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">Action</button><div class="dropdown-menu dropdown-menu-end action-menu"><button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#levelEdit-@x.MemberLevelId"><i class="bi bi-pencil"></i>Edit Level</button><button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#rule-@x.MemberLevelId"><i class="bi bi-arrow-up-circle"></i>Set Upgrade Rule</button><form method="post" asp-page-handler="ToggleActive" asp-route-memberLevelId="@x.MemberLevelId" asp-route-isActive="@(!x.IsActive)"><button class="dropdown-item" type="submit"><i class="bi bi-power"></i>@(x.IsActive ? "Deactivate" : "Activate")</button></form></div></div></td></tr> }</tbody></table></div></section>
<partial name="_LevelModal" model="null" />
@foreach (var x in rows)
{
    <partial name="_LevelModal" model="x" />
    var rule = rules.GetValueOrDefault(x.MemberLevelId);
    <div class="modal fade app-modal" id="rule-@x.MemberLevelId" tabindex="-1"><div class="modal-dialog modal-lg modal-dialog-centered"><form method="post" asp-page-handler="CreateOrUpdateUpgradeRule" class="modal-content"><div class="modal-header"><h2 class="modal-title h5">Upgrade Rule</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><input type="hidden" name="RuleInput.FromMemberLevelId" value="@x.MemberLevelId" /><div class="row g-3"><div class="col-md-6"><label class="form-label">From Member Level</label><input class="form-control" value="@x.LevelName" readonly /></div><div class="col-md-6"><label class="form-label">To Member Level</label><select class="form-select" name="RuleInput.ToMemberLevelId" required>@foreach (var target in rows.Where(t => t.MemberLevelId != x.MemberLevelId)) { <option value="@target.MemberLevelId" selected="@(rule?.ToMemberLevelId == target.MemberLevelId)">@target.LevelName</option> }</select></div><div class="col-md-4"><label class="form-label">Required Spending</label><input class="form-control" name="RuleInput.RequiredTotalSpending" type="number" step="0.01" min="0" value="@(rule?.RequiredTotalSpending ?? 0)" /></div><div class="col-md-4"><label class="form-label">Purchase Count</label><input class="form-control" name="RuleInput.RequiredPurchaseCount" type="number" min="0" value="@(rule?.RequiredPurchaseCount ?? 0)" /></div><div class="col-md-4"><label class="form-label">Membership Days</label><input class="form-control" name="RuleInput.RequiredMembershipDays" type="number" min="0" value="@(rule?.RequiredMembershipDays ?? 0)" /></div><div class="col-md-4"><label class="form-check"><input class="form-check-input" name="RuleInput.RequireNoOverduePayment" value="true" type="checkbox" checked="@(rule?.RequireNoOverduePayment ?? true)" /><input type="hidden" name="RuleInput.RequireNoOverduePayment" value="false" /> No overdue payment</label></div><div class="col-md-4"><label class="form-check"><input class="form-check-input" name="RuleInput.RequireManagerApproval" value="true" type="checkbox" checked="@(rule?.RequireManagerApproval ?? false)" /><input type="hidden" name="RuleInput.RequireManagerApproval" value="false" /> Manager approval</label></div><div class="col-md-4"><label class="form-check"><input class="form-check-input" name="RuleInput.IsActive" value="true" type="checkbox" checked="@(rule?.IsActive ?? true)" /><input type="hidden" name="RuleInput.IsActive" value="false" /> Active</label></div></div></div><div class="modal-footer"><button class="btn btn-primary">Save Rule</button></div></form></div></div>
}
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.querySelectorAll('[data-credit-toggle]').forEach(cb=>{const sync=()=>cb.closest('.modal-form-grid')?.querySelectorAll('[data-credit-field]').forEach(x=>x.disabled=!cb.checked);cb.addEventListener('change',sync);sync();});</script> }
