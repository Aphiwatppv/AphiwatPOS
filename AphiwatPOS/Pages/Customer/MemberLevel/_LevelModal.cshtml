@model CustomerEngine.Models.MemberLevelModel?
@{
    var id = Model is null ? "levelAddModal" : $"levelEdit-{Model.MemberLevelId}";
    var handler = Model is null ? "Create" : "Update";
}
<div class="modal fade app-modal" id="@id" tabindex="-1"><div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable"><form method="post" asp-page-handler="@handler" class="modal-content"><div class="modal-header"><div><h2 class="modal-title h5">@(Model is null ? "Add Level" : "Edit Level")</h2><p class="modal-subtitle">Configure benefits, points, credit, and upgrade behavior.</p></div><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><input type="hidden" name="LevelInput.MemberLevelId" value="@(Model?.MemberLevelId ?? 0)" /><div class="modal-form-grid"><div class="span-2"><h3 class="h6">Basic Information</h3></div><div><label class="form-label">Level Code</label><input class="form-control" name="LevelInput.LevelCode" value="@Model?.LevelCode" required /></div><div><label class="form-label">Level Name</label><input class="form-control" name="LevelInput.LevelName" value="@Model?.LevelName" required /></div><div><label class="form-label">Display Order</label><input class="form-control" name="LevelInput.DisplayOrder" type="number" value="@(Model?.DisplayOrder ?? 0)" /></div><div class="d-flex align-items-end"><label class="form-check"><input class="form-check-input" name="LevelInput.IsActive" value="true" type="checkbox" checked="@(Model?.IsActive ?? true)" /><input type="hidden" name="LevelInput.IsActive" value="false" /> Active</label></div><div class="span-2"><label class="form-label">Description</label><textarea class="form-control" name="LevelInput.Description">@Model?.Description</textarea></div><div class="span-2"><h3 class="h6">Benefit Rules</h3></div><div><label class="form-label">Min Spending</label><input class="form-control" name="LevelInput.MinSpendingAmount" type="number" step="0.01" min="0" value="@(Model?.MinSpendingAmount ?? 0)" /></div><div><label class="form-label">Discount Percent</label><input class="form-control" name="LevelInput.DiscountPercent" type="number" step="0.01" min="0" max="100" value="@(Model?.DiscountPercent ?? 0)" /></div><div><label class="form-label">Point Earn Amount</label><input class="form-control" name="LevelInput.PointEarnAmount" type="number" step="0.01" min="0.01" value="@(Model?.PointEarnAmount ?? 100)" /></div><div><label class="form-label">Point Earn Point</label><input class="form-control" name="LevelInput.PointEarnPoint" type="number" step="0.01" min="0" value="@(Model?.PointEarnPoint ?? 1)" /></div><div><label class="form-label">Point Multiplier</label><input class="form-control" name="LevelInput.PointMultiplier" type="number" step="0.01" min="0.01" value="@(Model?.PointMultiplier ?? 1)" /></div><div class="span-2"><h3 class="h6">Credit Settings</h3></div><div><label class="form-check form-switch"><input class="form-check-input" data-credit-toggle name="LevelInput.AllowCredit" value="true" type="checkbox" checked="@(Model?.AllowCredit ?? false)" /><input type="hidden" name="LevelInput.AllowCredit" value="false" /> Allow Credit</label></div><div><label class="form-check"><input class="form-check-input" name="LevelInput.RequireManagerApprovalForCredit" value="true" type="checkbox" checked="@(Model?.RequireManagerApprovalForCredit ?? false)" /><input type="hidden" name="LevelInput.RequireManagerApprovalForCredit" value="false" /> Manager Approval</label></div><div><label class="form-label">Default Credit Limit</label><input data-credit-field class="form-control" name="LevelInput.DefaultCreditLimit" type="number" step="0.01" min="0" value="@(Model?.DefaultCreditLimit ?? 0)" /></div><div><label class="form-label">Credit Term Days</label><input data-credit-field class="form-control" name="LevelInput.DefaultCreditTermDays" type="number" min="0" value="@(Model?.DefaultCreditTermDays ?? 0)" /></div><div><label class="form-label">Max Overdue Days</label><input data-credit-field class="form-control" name="LevelInput.MaxOverdueDaysAllowed" type="number" min="0" value="@(Model?.MaxOverdueDaysAllowed ?? 0)" /></div></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-primary">Save Level</button></div></form></div></div>
