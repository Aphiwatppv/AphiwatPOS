@page
@model AphiwatPOS.Pages.Customer.CustomerHistory.IndexModel
@{
    ViewData["Title"] = "Customer History";
    ViewData["Subtitle"] = "View customer purchases, payments, credit, points, level changes, refunds, and notes.";
    var s = Model.Summary;
}
<partial name="/Pages/Customer/Shared/_TempDataAlert.cshtml" model="(Model.StatusMessage, Model.ErrorMessage)" />
<div class="page-header d-flex align-items-start justify-content-between gap-3"><div><h1>Customer History</h1><p>View customer purchases, payments, credit, points, level changes, refunds, and notes.</p></div><button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#noteModal" @(Model.CustomerId is null ? "disabled" : "")><i class="bi bi-sticky"></i> Add Note</button></div>
<form method="get" class="filter-card mb-3"><div class="row g-3 align-items-end"><div class="col-lg-4"><label class="form-label">Search customer</label><input asp-for="SearchText" class="form-control" placeholder="Code, name, phone" /></div><div class="col-lg-4"><label class="form-label">Select customer</label><select asp-for="CustomerId" class="form-select"><option value="">Select customer</option>@foreach (var c in Model.Customers) { <option value="@c.CustomerId">@c.CustomerCode - @c.CustomerName (@c.PhoneNumber)</option> }</select></div><div class="col-lg-2"><label class="form-label">Date From</label><input asp-for="DateFrom" class="form-control" type="date" /></div><div class="col-lg-2"><label class="form-label">Date To</label><input asp-for="DateTo" class="form-control" type="date" /></div><div class="col-12 d-flex justify-content-end gap-2"><button class="btn btn-primary"><i class="bi bi-search"></i> Load History</button><a class="btn btn-outline-secondary" asp-page="./Index">Reset</a></div></div></form>
@if (Model.CustomerId is null)
{
    <section class="data-card"><div class="empty-state"><i class="bi bi-person-search"></i><div class="fw-semibold">Select a customer before viewing history</div><div>Search by customer code, name, or phone.</div></div></section>
}
else
{
    <div class="summary-grid"><div class="summary-card"><span class="metric-icon"><i class="bi bi-cash-stack"></i></span><div><div class="metric-label">Total Spending</div><div class="metric-value">@CustomerPageHelpers.Money(s?.TotalSpending ?? 0)</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-receipt"></i></span><div><div class="metric-label">Purchase Count</div><div class="metric-value">@(s?.TotalPurchaseCount ?? 0)</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-stars"></i></span><div><div class="metric-label">Available Points</div><div class="metric-value">@((s?.AvailablePoints ?? 0).ToString("N2"))</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-credit-card"></i></span><div><div class="metric-label">Outstanding Credit</div><div class="metric-value">@((s?.CurrentOutstandingAmount ?? 0).ToString("N2"))</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-wallet2"></i></span><div><div class="metric-label">Available Credit</div><div class="metric-value">@((s?.AvailableCredit ?? 0).ToString("N2"))</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-exclamation-triangle"></i></span><div><div class="metric-label">Overdue Amount</div><div class="metric-value">@((s?.OverdueAmount ?? 0).ToString("N2"))</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-pin-angle"></i></span><div><div class="metric-label">Important Notes</div><div class="metric-value">@(s?.ImportantNoteCount ?? 0)</div></div></div></div>
    <section class="data-card"><ul class="nav nav-tabs"><li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#timeline" type="button">Timeline</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#purchase" type="button">Purchase History</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#payment" type="button">Payment History</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#credit" type="button">Credit History</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#points" type="button">Loyalty Point History</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#level" type="button">Member Level History</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#refund" type="button">Refund History</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#notes" type="button">Notes</button></li></ul><div class="tab-content pt-3"><div class="tab-pane fade show active" id="timeline"><partial name="/Pages/Customer/CustomerList/_TimelineTable.cshtml" model="Model.Timeline.Items" /></div><div class="tab-pane fade" id="purchase"><partial name="/Pages/Customer/CustomerList/_PurchaseTable.cshtml" model="Model.Purchases.Items" /></div><div class="tab-pane fade" id="payment"><partial name="/Pages/Customer/CustomerList/_PaymentTable.cshtml" model="Model.Payments.Items" /></div><div class="tab-pane fade" id="credit"><partial name="/Pages/Customer/CustomerList/_CreditTable.cshtml" model="Model.CreditHistory.Items" /></div><div class="tab-pane fade" id="points"><partial name="/Pages/Customer/CustomerList/_PointTable.cshtml" model="Model.PointHistory.Items" /></div><div class="tab-pane fade" id="level"><partial name="/Pages/Customer/CustomerList/_LevelTable.cshtml" model="Model.LevelHistory.Items" /></div><div class="tab-pane fade" id="refund"><div class="table-responsive"><table class="table table-hover"><thead><tr><th>Refund No</th><th>Sale No</th><th>Refund Date</th><th>Amount</th><th>Reason</th><th>Status</th><th>Created By</th></tr></thead><tbody>@if (!Model.Refunds.Items.Any()) { <tr><td colspan="7"><div class="empty-state"><i class="bi bi-arrow-counterclockwise"></i><div class="fw-semibold">No refund history</div></div></td></tr> } @foreach (var x in Model.Refunds.Items) { <tr><td>@x.RefundId</td><td>@x.SaleNo</td><td>@CustomerPageHelpers.DateTimeText(x.RefundDate)</td><td>@x.RefundAmount.ToString("N2")</td><td>@x.RefundReason</td><td>@x.RefundStatus</td><td>@x.CreatedByName</td></tr> }</tbody></table></div></div><div class="tab-pane fade" id="notes"><div class="row g-3">@foreach (var n in Model.Notes.Notes.OrderByDescending(x => x.IsImportant)) { <div class="col-lg-6"><div class="filter-card h-100 @(n.IsImportant ? "border-warning" : "")"><div class="d-flex justify-content-between"><span class="badge status-badge @(n.IsImportant ? "badge-warning" : "badge-muted")">@n.NoteType</span><small>@CustomerPageHelpers.DateTimeText(n.CreatedDate)</small></div><p class="my-2">@n.NoteText</p><div class="d-flex gap-2"><button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#noteEdit-@n.CustomerNoteId">Edit note</button><form method="post" asp-page-handler="ToggleNoteActive" asp-route-customerNoteId="@n.CustomerNoteId" asp-route-customerId="@n.CustomerId" asp-route-isActive="false"><button class="btn btn-outline-danger btn-sm">Hide note</button></form></div></div></div><div class="modal fade app-modal" id="noteEdit-@n.CustomerNoteId" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="UpdateNote" class="modal-content"><div class="modal-header"><h2 class="modal-title h5">Edit Note</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><input type="hidden" name="NoteInput.CustomerId" value="@n.CustomerId" /><input type="hidden" name="NoteInput.CustomerNoteId" value="@n.CustomerNoteId" /><select class="form-select mb-3" name="NoteInput.NoteType"><option selected="@(n.NoteType=="General")">General</option><option selected="@(n.NoteType=="Warning")">Warning</option><option selected="@(n.NoteType=="Credit")">Credit</option><option selected="@(n.NoteType=="Service")">Service</option><option selected="@(n.NoteType=="Complaint")">Complaint</option><option selected="@(n.NoteType=="FollowUp")">FollowUp</option><option selected="@(n.NoteType=="Other")">Other</option></select><textarea class="form-control mb-3" name="NoteInput.NoteText" rows="4">@n.NoteText</textarea><label class="form-check"><input class="form-check-input" name="NoteInput.IsImportant" value="true" type="checkbox" checked="@n.IsImportant" /><input type="hidden" name="NoteInput.IsImportant" value="false" /> Important</label></div><div class="modal-footer"><button class="btn btn-primary">Save Note</button></div></form></div></div> }</div></div></div></section>
    <div class="modal fade app-modal" id="noteModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="AddNote" class="modal-content"><div class="modal-header"><h2 class="modal-title h5">Add Note</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><input type="hidden" name="NoteInput.CustomerId" value="@Model.CustomerId" /><label class="form-label">Note Type</label><select class="form-select mb-3" name="NoteInput.NoteType"><option>General</option><option>Warning</option><option>Credit</option><option>Service</option><option>Complaint</option><option>FollowUp</option><option>Other</option></select><label class="form-label">Note Text</label><textarea class="form-control mb-3" name="NoteInput.NoteText" rows="4" required></textarea><label class="form-check"><input class="form-check-input" name="NoteInput.IsImportant" value="true" type="checkbox" /><input type="hidden" name="NoteInput.IsImportant" value="false" /> Important</label></div><div class="modal-footer"><button class="btn btn-primary">Add Note</button></div></form></div></div>
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
