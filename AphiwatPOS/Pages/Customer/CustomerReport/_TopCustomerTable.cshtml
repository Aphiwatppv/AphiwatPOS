@model Tuple<IReadOnlyCollection<CustomerEngine.Models.TopCustomerModel>, string>
@{ var rows = Model.Item1; var mode = Model.Item2; }
<div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Rank</th><th>Customer Code</th><th>Customer Name</th><th>Member Level</th><th>@(mode == "Visit" ? "Visit Count" : "Total Spending")</th><th>@(mode == "Visit" ? "Total Spending" : "Purchase Count")</th><th>Last Purchase</th></tr></thead><tbody>@if (!rows.Any()) { <tr><td colspan="7"><div class="empty-state"><i class="bi bi-bar-chart"></i><div class="fw-semibold">No report data</div></div></td></tr> } @{ var i = 0; } @foreach (var x in rows) { i++; <tr><td><span class="rank-badge @(i <= 3 ? "rank-top" : "")">@i</span></td><td>@x.CustomerCode</td><td>@x.CustomerName</td><td>@x.MemberLevelName</td>@if (mode == "Visit") { <td>@x.TotalPurchaseCount</td><td>@x.TotalSpending.ToString("N2")</td> } else { <td>@x.TotalSpending.ToString("N2")</td><td>@x.TotalPurchaseCount</td> }<td>@AphiwatPOS.Pages.Customer.CustomerPageHelpers.Date(x.LastPurchaseDate)</td></tr> }</tbody></table></div>
