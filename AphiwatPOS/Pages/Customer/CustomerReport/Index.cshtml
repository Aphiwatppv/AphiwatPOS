@page
@model AphiwatPOS.Pages.Customer.CustomerReport.IndexModel
@{
    ViewData["Title"] = "Customer Report";
    ViewData["Subtitle"] = "Analyze customer spending, visits, loyalty points, and credit risk.";
}
<partial name="/Pages/Customer/Shared/_TempDataAlert.cshtml" model="((string?)null, Model.ErrorMessage)" />
<div class="page-header"><h1>Customer Report</h1><p>Analyze customer spending, visits, loyalty points, and credit risk.</p></div>
<form method="get" class="filter-card mb-3"><div class="row g-3 align-items-end"><div class="col-lg-2"><label class="form-label">Date From</label><input asp-for="DateFrom" class="form-control" type="date" /></div><div class="col-lg-2"><label class="form-label">Date To</label><input asp-for="DateTo" class="form-control" type="date" /></div><div class="col-lg-3"><label class="form-label">Member Level</label><select asp-for="MemberLevelId" class="form-select"><option value="">All</option>@foreach (var level in Model.MemberLevels) { <option value="@level.MemberLevelId">@level.LevelName</option> }</select></div><div class="col-lg-2"><label class="form-label">Customer Status</label><select asp-for="IsActive" class="form-select"><option value="">All</option><option value="true">Active</option><option value="false">Inactive</option></select></div><div class="col-lg-2"><label class="form-label">No Purchase After</label><input asp-for="NoPurchaseAfterDate" class="form-control" type="date" /></div><div class="col-lg-1 d-flex gap-2"><button class="btn btn-primary w-100"><i class="bi bi-funnel"></i></button><a class="btn btn-outline-secondary" asp-page="./Index"><i class="bi bi-arrow-counterclockwise"></i></a></div></div></form>
<div class="summary-grid"><div class="summary-card"><span class="metric-icon"><i class="bi bi-people"></i></span><div><div class="metric-label">Total Customers</div><div class="metric-value">@Model.Summary.TotalCustomers</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-check-circle"></i></span><div><div class="metric-label">Active Customers</div><div class="metric-value">@Model.Summary.ActiveCustomers</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-person-plus"></i></span><div><div class="metric-label">New Customers</div><div class="metric-value">@Model.Summary.NewCustomers</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-cash-stack"></i></span><div><div class="metric-label">Customer Spending</div><div class="metric-value">@CustomerPageHelpers.Money(Model.Summary.TotalCustomerSpending)</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-credit-card"></i></span><div><div class="metric-label">Outstanding Credit</div><div class="metric-value">@CustomerPageHelpers.Money(Model.Summary.TotalOutstandingCredit)</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-stars"></i></span><div><div class="metric-label">Available Points</div><div class="metric-value">@Model.Summary.TotalAvailablePoints.ToString("N2")</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-wallet2"></i></span><div><div class="metric-label">Credit Customers</div><div class="metric-value">@Model.Summary.TotalCreditCustomers</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-exclamation-triangle"></i></span><div><div class="metric-label">Overdue Customers</div><div class="metric-value">@Model.Summary.TotalOverdueCustomers</div></div></div></div>
<div class="dashboard-table-grid">
    <section class="data-card"><div class="card-heading"><h2>Top Customers by Spending</h2></div><partial name="_TopCustomerTable" model="@(Tuple.Create(Model.TopSpending, "Spending"))" /></section>
    <section class="data-card"><div class="card-heading"><h2>Top Customers by Visit Count</h2></div><partial name="_TopCustomerTable" model="@(Tuple.Create(Model.TopVisits, "Visit"))" /></section>
</div>
<div class="dashboard-table-grid mt-3">
    <section class="data-card"><div class="card-heading"><h2>Member Level Summary</h2></div><div class="table-responsive"><table class="table table-hover"><thead><tr><th>Member Level</th><th>Customer Count</th><th>Total Spending</th><th>Outstanding Credit</th></tr></thead><tbody>@foreach (var x in Model.LevelSummary) { <tr><td>@x.MemberLevelName</td><td>@x.CustomerCount</td><td>@x.TotalSpending.ToString("N2")</td><td>@x.TotalOutstandingCredit.ToString("N2")</td></tr> }</tbody></table></div></section>
    <section class="data-card"><div class="card-heading"><h2>Loyalty Point Summary</h2></div><div class="table-responsive"><table class="table table-hover"><tbody><tr><th>Total Earned Points</th><td>@Model.LoyaltySummary.TotalEarnedPoints.ToString("N2")</td></tr><tr><th>Total Redeemed Points</th><td>@Model.LoyaltySummary.TotalRedeemedPoints.ToString("N2")</td></tr><tr><th>Total Available Points</th><td>@Model.LoyaltySummary.TotalAvailablePoints.ToString("N2")</td></tr><tr><th>Total Expired Points</th><td>@Model.LoyaltySummary.TotalExpiredPoints.ToString("N2")</td></tr></tbody></table></div></section>
</div>
<div class="dashboard-table-grid mt-3">
    <section class="data-card"><div class="card-heading"><h2>Credit Summary</h2></div><div class="table-responsive"><table class="table table-hover"><tbody><tr><th>Total Credit Limit</th><td>@Model.CreditSummary.TotalCreditLimit.ToString("N2")</td></tr><tr><th>Total Outstanding Amount</th><td>@Model.CreditSummary.TotalOutstandingAmount.ToString("N2")</td></tr><tr><th>Total Available Credit</th><td>@Model.CreditSummary.TotalAvailableCredit.ToString("N2")</td></tr><tr><th>Overdue Amount</th><td>@Model.CreditSummary.OverdueAmount.ToString("N2")</td></tr><tr><th>Overdue Count</th><td>@Model.CreditSummary.OverdueCount</td></tr><tr><th>Blocked Customers</th><td>@Model.CreditSummary.BlockedCustomerCount</td></tr></tbody></table></div></section>
    <section class="data-card"><div class="card-heading"><h2>Inactive Customers</h2></div><div class="table-responsive"><table class="table table-hover"><thead><tr><th>Code</th><th>Name</th><th>Phone</th><th>Last Purchase</th><th>Total Spending</th><th>Level</th></tr></thead><tbody>@foreach (var x in Model.InactiveCustomers) { <tr><td>@x.CustomerCode</td><td>@x.CustomerName</td><td>@x.PhoneNumber</td><td>@CustomerPageHelpers.Date(x.LastPurchaseDate)</td><td>@x.TotalSpending.ToString("N2")</td><td>@x.MemberLevelName</td></tr> }</tbody></table></div></section>
</div>
