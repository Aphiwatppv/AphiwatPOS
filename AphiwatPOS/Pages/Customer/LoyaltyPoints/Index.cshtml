@page
@model AphiwatPOS.Pages.Customer.LoyaltyPoints.IndexModel
@{
    ViewData["Title"] = "Loyalty Points";
    ViewData["Subtitle"] = "Track earned, redeemed, adjusted, expired, and reversed customer points.";
    var rows = Model.Movements.Movements.ToArray();
    string q(int page) => Url.Page("./Index", new { Model.CustomerId, Model.SearchText, Model.MovementType, Model.DateFrom, Model.DateTo, PageNumber = page }) ?? "#";
}
<partial name="/Pages/Customer/Shared/_TempDataAlert.cshtml" model="(Model.StatusMessage, Model.ErrorMessage)" />
<div class="page-header d-flex align-items-start justify-content-between gap-3"><div><h1>Loyalty Points</h1><p>Track earned, redeemed, adjusted, expired, and reversed customer points.</p></div><div class="d-flex gap-2"><button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#adjustModal" @(Model.CustomerId is null ? "disabled" : "")><i class="bi bi-sliders"></i> Adjust Points</button><form method="post" asp-page-handler="ExpirePoints"><button class="btn btn-primary"><i class="bi bi-calendar-x"></i> Expire Points</button></form></div></div>
<div class="summary-grid"><div class="summary-card"><span class="metric-icon"><i class="bi bi-stars"></i></span><div><div class="metric-label">Available Points</div><div class="metric-value">@Model.Summary.TotalAvailablePoints.ToString("N2")</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-plus-circle"></i></span><div><div class="metric-label">Lifetime Earned</div><div class="metric-value">@Model.Summary.TotalEarnedPoints.ToString("N2")</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-dash-circle"></i></span><div><div class="metric-label">Lifetime Redeemed</div><div class="metric-value">@Model.Summary.TotalRedeemedPoints.ToString("N2")</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-calendar-x"></i></span><div><div class="metric-label">Expired Points</div><div class="metric-value">@Model.Summary.TotalExpiredPoints.ToString("N2")</div></div></div><div class="summary-card"><span class="metric-icon"><i class="bi bi-sliders"></i></span><div><div class="metric-label">Adjusted Points</div><div class="metric-value">@rows.Where(x => x.MovementType.StartsWith("Adjust")).Sum(x => x.PointsIn - x.PointsOut).ToString("N2")</div></div></div></div>
<form method="get" class="filter-card mb-3"><div class="row g-3 align-items-end"><div class="col-lg-3"><label class="form-label">Search customer</label><input asp-for="SearchText" class="form-control" placeholder="Code, name, phone" /></div><div class="col-lg-3"><label class="form-label">Select customer</label><select asp-for="CustomerId" class="form-select"><option value="">Select customer</option>@foreach (var c in Model.Customers) { <option value="@c.CustomerId">@c.CustomerCode - @c.CustomerName (@c.PhoneNumber)</option> }</select></div><div class="col-lg-2"><label class="form-label">Movement Type</label><select asp-for="MovementType" class="form-select"><option value="">All</option><option>Earn</option><option>Redeem</option><option>AdjustIn</option><option>AdjustOut</option><option>Expire</option><option>Reverse</option></select></div><div class="col-lg-2"><label class="form-label">Date From</label><input asp-for="DateFrom" class="form-control" type="date" /></div><div class="col-lg-2"><label class="form-label">Date To</label><input asp-for="DateTo" class="form-control" type="date" /></div><div class="col-12 d-flex justify-content-end gap-2"><button class="btn btn-primary"><i class="bi bi-search"></i> Search</button><a class="btn btn-outline-secondary" asp-page="./Index">Reset</a></div></div></form>
<section class="data-card"><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Date</th><th>Customer Code</th><th>Customer Name</th><th>Movement</th><th>Points In</th><th>Points Out</th><th>Balance</th><th>Reference Type</th><th>Reference No</th><th>Expiry</th><th>Remark</th><th>Created By</th></tr></thead><tbody>@if (Model.CustomerId is null) { <tr><td colspan="12"><div class="empty-state"><i class="bi bi-person-search"></i><div class="fw-semibold">Select a customer to view loyalty movements</div></div></td></tr> } else if (!rows.Any()) { <tr><td colspan="12"><div class="empty-state"><i class="bi bi-stars"></i><div class="fw-semibold">No point movements found</div></div></td></tr> } @foreach (var x in rows) { <tr><td>@CustomerPageHelpers.DateTimeText(x.CreatedDate)</td><td>@Model.SelectedCustomer?.CustomerCode</td><td>@Model.SelectedCustomer?.CustomerName</td><td><partial name="/Pages/Customer/Shared/_PointMovementBadge.cshtml" model="x.MovementType" /></td><td class="text-success">@(x.PointsIn > 0 ? "+" : "")@x.PointsIn.ToString("N2")</td><td class="text-danger">@(x.PointsOut > 0 ? "-" : "")@x.PointsOut.ToString("N2")</td><td>@x.BalanceAfter.ToString("N2")</td><td>@x.ReferenceType</td><td>@x.ReferenceNo</td><td>@CustomerPageHelpers.Date(x.ExpiryDate)</td><td>@x.Remark</td><td>@x.CreatedByUserId</td></tr> }</tbody></table></div>@if (Model.CustomerId is not null) { <partial name="/Pages/Customer/Shared/_Pagination.cshtml" model="new AphiwatPOS.Pages.Customer.Shared.CustomerPaginationModel { PageNumber = Model.Movements.PageNumber, PageSize = Model.Movements.PageSize, TotalCount = Model.Movements.TotalCount, PageUrl = q }" /> }</section>
<div class="modal fade app-modal" id="adjustModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><form method="post" asp-page-handler="AdjustPoints" class="modal-content"><div class="modal-header"><h2 class="modal-title h5">Adjust Points</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><input type="hidden" name="AdjustInput.CustomerId" value="@Model.CustomerId" /><label class="form-label">Customer</label><input class="form-control mb-3" value="@Model.SelectedCustomer?.CustomerName" readonly /><label class="form-label">Adjustment Type</label><select class="form-select mb-3" name="AdjustInput.AdjustmentType"><option>AdjustIn</option><option>AdjustOut</option></select><label class="form-label">Points</label><input class="form-control mb-3" name="AdjustInput.Points" type="number" min="0.01" step="0.01" required /><label class="form-label">Reason / Remark</label><textarea class="form-control" name="AdjustInput.Remark" required rows="3"></textarea></div><div class="modal-footer"><button class="btn btn-primary">Save Adjustment</button></div></form></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
