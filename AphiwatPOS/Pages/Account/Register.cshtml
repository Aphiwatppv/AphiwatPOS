@page
@model AphiwatPOS.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="page-header d-flex align-items-start justify-content-between gap-3">
    <div>
        <h1>Create Account</h1>
        <p>Register a POS employee and assign secure access roles.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Employees/Employee/Index">Back</a>
</div>

<form method="post" enctype="multipart/form-data" class="form-card">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

    <div class="row g-4">
        <div class="col-lg-8">
            <h2 class="h6 fw-bold mb-3">Account Information</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.Username" class="form-label fw-semibold"></label>
                    <input asp-for="Input.Username" class="form-control" autocomplete="off" placeholder="cashier01" />
                    <span asp-validation-for="Input.Username" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.DisplayName" class="form-label fw-semibold"></label>
                    <input asp-for="Input.DisplayName" class="form-control" placeholder="May Cashier" />
                    <span asp-validation-for="Input.DisplayName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                    <input asp-for="Input.Email" class="form-control" placeholder="employee@aphiwatpos.local" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.ProfileImage" class="form-label fw-semibold">Profile Image</label>
                    <div class="d-flex gap-2">
                        <input asp-for="Input.ProfileImage" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp" />
                    </div>
                    <span asp-validation-for="Input.ProfileImage" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                    <input asp-for="Input.Password" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    <div class="password-meter mt-2"><span></span></div>
                    <div class="text-muted small mt-1">Use at least 8 characters.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="permission-module-card h-100">
                <h2 class="h6 fw-bold mb-3">Role Selection</h2>
                <div class="d-grid gap-2">
                    @foreach (var role in Model.Roles)
                    {
                        <label class="form-check border p-3">
                            <input class="form-check-input" type="checkbox" name="Input.SelectedRoles" value="@role.RoleCode" />
                            <span class="form-check-label fw-semibold">@role.RoleName</span>
                            <span class="d-block text-muted small">@role.Description</span>
                        </label>
                    }
                </div>
                <span asp-validation-for="Input.SelectedRoles" class="text-danger small"></span>
                <hr />
                <label class="form-check form-switch">
                    <input asp-for="Input.IsActive" class="form-check-input" />
                    <span class="form-check-label fw-semibold">Active account</span>
                </label>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 border-top mt-4 pt-3">
        <a class="btn btn-outline-secondary" asp-page="/Employees/Employee/Index">Cancel</a>
        <button type="submit" class="btn btn-primary">Create Account</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
