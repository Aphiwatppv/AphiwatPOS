  function showProductNotFound(barcode) {
    const barcodeTarget = document.querySelector('[data-global-missing-barcode]');
    const createLink = document.querySelector('[data-global-create-product]');
    if (barcodeTarget && createLink) {
      barcodeTarget.textContent = barcode;
      createLink.href = `/Products/Product/Index?mode=create&barcode=${encodeURIComponent(barcode)}`;
      bootstrap.Modal.getOrCreateInstance(document.querySelector('#globalProductNotFoundModal')).show();
    } else {
      alert('Product not found for this barcode.');
