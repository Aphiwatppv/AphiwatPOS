  async function lookupBarcode(value) {
    const response = await fetch(`?handler=CheckBarcode&barcode=${encodeURIComponent(value)}&locationId=${encodeURIComponent(by('[data-location-id]').value || 1)}`);
    if (response.ok) return await response.json();
    if (response.status === 404) return null;
    const error = await response.json().catch(() => ({ message:'Barcode lookup failed.' }));
    throw new Error(error.message || 'Barcode lookup failed.');
  }
  let barcodeLookupBusy = false;
  async function scanBarcode(value) {
    const barcode = (value || '').trim();
    if (!barcode || barcodeLookupBusy) return;
    ensureCustomerDisplayOpen(false);
    barcodeLookupBusy = true;
    const input = by('[data-barcode-input]');
    input.disabled = true;
    try {
      const match = products.find(p => (p.dataset.barcode || '').toLowerCase() === barcode.toLowerCase() || p.dataset.code.toLowerCase() === barcode.toLowerCase());
      if (match) addProduct(match);
      else {
        const product = await lookupBarcode(barcode);
        if (product) addProduct(product);
        else showProductNotFound(barcode);
      }
    } catch (error) {
      showProductWarning(error.message || 'Barcode lookup failed.');
    } finally {
      barcodeLookupBusy = false;
      input.disabled = false;
      input.value = '';
      input.focus();
    }
  }
