    setTimeout(() => { delete document.body.dataset.printMode; }, 500);
  }
  products.forEach(card => card.onclick = () => addProduct(card));
  by('[data-barcode-input]').addEventListener('keydown', e => { if (e.key !== 'Enter') return; e.preventDefault(); scanBarcode(e.target.value); });
  by('[data-product-search]').addEventListener('input', e => { const q = e.target.value.toLowerCase(); products.forEach(p => p.hidden = !(p.dataset.name.toLowerCase().includes(q) || p.dataset.code.toLowerCase().includes(q) || (p.dataset.barcode || '').toLowerCase().includes(q))); });
  document.querySelectorAll('[data-stock-filter]').forEach(btn => btn.onclick = () => { document.querySelectorAll('[data-stock-filter]').forEach(x => x.classList.remove('active')); btn.classList.add('active'); products.forEach(p => p.hidden = btn.dataset.stockFilter !== 'all' && p.dataset.stockStatus !== btn.dataset.stockFilter); });
  by('[data-order-discount]').oninput = totals; by('[data-tax-amount]').oninput = totals;
  by('[data-payment-amount]').addEventListener('input', () => { ensureCustomerDisplayOpen(); clearPromptPay(); totals(); });
  by('[data-payment-ref]').addEventListener('input', totals);
  by('[data-open-customer-display]')?.addEventListener('click', openCustomerDisplay);
  by('[data-generate-promptpay]')?.addEventListener('click', generatePromptPayQr);
  by('[data-add-payment]').onclick = () => { ensureCustomerDisplayOpen(); const pending = pendingPayment(); if (!pending) return; if (activeMethod.dataset.requireRef === 'true' && !pending.referenceNo) return alert('Reference number is required.'); payments.push(pending); by('[data-payment-amount]').value = ''; by('[data-payment-ref]').value = ''; clearPromptPay(); totals(); };
  by('[data-use-credit]').onclick = applyCustomerCredit;
  by('[data-use-partial-credit]').onclick = () => { bootstrap.Modal.getOrCreateInstance(by('#insufficientCreditModal')).hide(); applyCustomerCredit(false); };
  by('[data-confirm-pay]').onclick = () => {
    const pending = pendingPayment();
    const finalPayments = pending ? [...payments, pending] : payments;
    const t = totals();
    const err = by('[data-payment-error]');
    err.classList.add('d-none');
    const creditInfo = selectedCreditInfo();
    const creditTotal = finalPayments.filter(p => document.querySelector(`[data-payment-method="${p.paymentMethodId}"]`)?.dataset.isCredit === 'true').reduce((s,p) => s + p.paymentAmount, 0);
    if (!wholesaleCustomerVerified) { err.textContent = 'Customer/member must be verified before wholesale checkout.'; err.classList.remove('d-none'); failPayment(err.textContent, t); return; }
    if (!selectedCustomerOption()?.value && by('[data-member-yes]').checked) { err.textContent = 'Select a verified customer or continue as walk-in wholesale customer.'; err.classList.remove('d-none'); failPayment(err.textContent, t); return; }
    const selectedCustomer = selectedCustomerOption();
    if (selectedCustomer?.value && selectedCustomer.dataset.wholesaleAllowed !== 'true' && !confirm('Customer is not marked for wholesale pricing. Continue with manager review?')) { err.textContent = 'Wholesale permission warning was not accepted.'; err.classList.remove('d-none'); failPayment(err.textContent, t); return; }
    if (!cart.length) { err.textContent = 'Cart is empty.'; err.classList.remove('d-none'); failPayment(err.textContent, t); return; }
    if (pending && activeMethod.dataset.requireRef === 'true' && !pending.referenceNo) { err.textContent = 'Reference number is required.'; err.classList.remove('d-none'); failPayment(err.textContent, t); return; }
    if (creditTotal > 0 && !creditInfo.hasCustomer) { err.textContent = 'Customer credit payment requires a selected member customer.'; err.classList.remove('d-none'); failPayment(err.textContent, t); return; }
    if (creditTotal > creditInfo.availableCredit) { err.textContent = 'Customer credit is not enough for this payment.'; err.classList.remove('d-none'); failPayment(err.textContent, t); return; }
    if (t.paid < t.net) { err.textContent = 'Payment amount must be greater than or equal to net amount.'; err.classList.remove('d-none'); failPayment(err.textContent, t); return; }
    const snapshot = receiptSnapshot(finalPayments, t);
    sessionStorage.setItem('aphiwatpos:last-sale-print', JSON.stringify(snapshot));
    by('[data-post-customer]').value = by('[data-customer-id]').value || '';
    by('[data-post-discount]').value = t.orderDiscount;
    by('[data-post-tax]').value = Number(by('[data-tax-amount]').value || 0);
    by('[data-post-items]').value = JSON.stringify(cart);
    by('[data-post-payments]').value = JSON.stringify(finalPayments.map(({name, pending, ...p}) => p));
    publishCustomerDisplay({ type:'sale-update', event:'PaymentProcessing', displayState:'ProcessingPayment', status:'Processing payment...', ...customerDisplaySnapshot(t), updatedAt:new Date().toISOString() });
    by('[data-complete-form]').submit();
  };
  by('[data-confirm-hold]').onclick = () => { const t = totals(); if (!wholesaleCustomerVerified) return showProductWarning('Customer/member must be verified before holding a wholesale sale.'); if (!cart.length) return; by('[data-hold-customer]').value = by('[data-customer-id]').value || ''; by('[data-hold-tax]').value = Number(by('[data-tax-amount]').value || 0); by('[data-hold-items]').value = JSON.stringify(cart); by('[data-hold-note]').value = by('[data-hold-note-input]').value; by('[data-hold-form]').submit(); };
  by('[data-clear-cart]').onclick = () => { cart = []; payments = []; clearPromptPay(); bootstrap.Modal.getOrCreateInstance(by('#clearCartModal')).hide(); render(); publishLiveDisplay('Scanning Items'); };
  by('[data-mobile-cart]').onclick = () => cartPanel.classList.toggle('open');
  by('[data-customer-search]').addEventListener('input', filterCustomers);
  by('[data-customer-search]').addEventListener('keydown', e => { if (e.key !== 'Enter') return; e.preventDefault(); selectFirstCustomerMatch(); });
  by('[data-member-yes]').addEventListener('change', () => { by('[data-member-lookup]').classList.remove('d-none'); by('[data-customer-id]').classList.remove('d-none'); by('[data-customer-search]').focus(); filterCustomers(); syncCustomerCredit(); });
  by('[data-member-no]').addEventListener('change', () => { by('[data-customer-search]').value = ''; by('[data-customer-id]').value = ''; by('[data-member-lookup]').classList.add('d-none'); by('[data-customer-id]').classList.add('d-none'); filterCustomers(); syncCustomerCredit(); });
  by('[data-customer-id]').addEventListener('change', () => { syncSelectedCustomer(); syncCustomerCredit(); });
  document.querySelectorAll('[data-gate-customer]').forEach(btn => btn.onclick = () => selectGateCustomer(btn));
  by('[data-gate-search]')?.addEventListener('click', searchGateCustomers);
  by('[data-gate-customer-search]')?.addEventListener('keydown', e => { if (e.key !== 'Enter') return; e.preventDefault(); searchGateCustomers(); });
  by('[data-gate-customer-search]')?.addEventListener('input', e => { if (!e.target.value.trim()) renderGateResults([...document.querySelectorAll('[data-customer-id] option[value]')].filter(o => o.value).slice(0, 8).map(o => ({ customerId:+o.value, customerName:o.dataset.name, phoneNumber:o.dataset.phone, memberCode:o.dataset.code, memberLevel:o.dataset.level, customerType:o.dataset.type, isWholesaleAllowed:o.dataset.wholesaleAllowed === 'true', creditLimit:+(o.dataset.creditLimit || 0), availableCredit:+(o.dataset.availableCredit || 0), outstandingBalance:+(o.dataset.usedCredit || 0), paymentTerms:o.dataset.paymentTerms, discountCondition:o.dataset.discountCondition, taxId:o.dataset.taxId, address:o.dataset.address, creditStatus:o.dataset.creditStatus }))); });
  by('[data-gate-continue]')?.addEventListener('click', () => { if (selectedGateCustomer) continueWithGateCustomer(selectedGateCustomer); });
  by('[data-gate-walkin]')?.addEventListener('click', continueAsWalkInWholesale);
  by('[data-print-receipt]').addEventListener('click', () => printDocument('receipt'));
  by('[data-print-invoice]').addEventListener('click', () => printDocument('invoice'));
  by('[data-result-print-invoice]').addEventListener('click', () => printDocument('invoice'));
  startDisplayHub();
  syncCustomerCredit();
  render();
  by('[data-gate-customer-search]')?.focus();
  if (initialBarcode && wholesaleCustomerVerified) scanBarcode(initialBarcode);
  if (lastSaleNo) {
    const rawSnapshot = sessionStorage.getItem('aphiwatpos:last-sale-print');
    if (rawSnapshot) {
      try {
        const snapshot = JSON.parse(rawSnapshot);
        snapshot.saleNo = lastSaleNo;
        snapshot.receiptNo = lastSaleNo;
        snapshot.invoiceNo = lastSaleNo;
        renderReceiptPreview(snapshot);
        showSaleResult('success', `Sale ${lastSaleNo} completed successfully.`, snapshot.totals, lastSaleNo);
        by('[data-result-customer]').textContent = snapshot.customer?.name || 'Walk-in Customer';
        by('[data-result-payment-method]').textContent = (snapshot.payments || []).map(p => p.name || 'Payment').join(', ') || '-';
        by('[data-result-items]').textContent = String((snapshot.items || []).reduce((sum, item) => sum + Number(item.quantity || 0), 0));
        publishCustomerDisplay(paymentResultFromSnapshot('success', `Sale ${lastSaleNo} completed successfully.`, snapshot, lastSaleNo));
        bootstrap.Modal.getOrCreateInstance(by('#receiptPreviewModal')).show();
      } finally {
        sessionStorage.removeItem('aphiwatpos:last-sale-print');
      }
    }
  }
  if (serverErrorMessage) {
    const rawSnapshot = sessionStorage.getItem('aphiwatpos:last-sale-print');
    let totalsSnapshot = totals();
    let handledSnapshot = false;
    if (rawSnapshot) {
      try {
        const snapshot = JSON.parse(rawSnapshot);
        totalsSnapshot = snapshot.totals || totalsSnapshot;
        showSaleResult('fail', serverErrorMessage, totalsSnapshot);
        by('[data-result-customer]').textContent = snapshot.customer?.name || 'Walk-in Customer';
        by('[data-result-payment-method]').textContent = (snapshot.payments || []).map(p => p.name || 'Payment').join(', ') || '-';
        by('[data-result-items]').textContent = String((snapshot.items || []).reduce((sum, item) => sum + Number(item.quantity || 0), 0));
        publishCustomerDisplay(paymentResultFromSnapshot('fail', serverErrorMessage, snapshot));
        handledSnapshot = true;
      } catch {}
      sessionStorage.removeItem('aphiwatpos:last-sale-print');
    }
    if (!handledSnapshot) failPayment(serverErrorMessage, totalsSnapshot);
  }
})();
</script>
}
