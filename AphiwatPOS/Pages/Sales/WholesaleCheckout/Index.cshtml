  function showStock(item, requested) { by('[data-stock-product]').textContent = item.productName; by('[data-stock-current]').textContent = item.currentStock; by('[data-stock-requested]').textContent = requested; bootstrap.Modal.getOrCreateInstance(by('#insufficientStockModal')).show(); }
  function updateQty(index, qty) { const item = cart[index]; const minQty = Math.max(1, Number(item.wholesaleMinQty || 1)); if (item.isStockTracked !== false && qty > Number(item.currentStock || 0)) return showStock(item, qty); if (qty < minQty) showProductWarning(`Wholesale minimum for ${item.productName} is ${minQty}.`); item.quantity = Math.max(minQty, qty); render(); }
  function showProductWarning(message) {
    const toast = document.querySelector('.toast-container');
    if (toast) toast.insertAdjacentHTML('beforeend', `<div class="toast align-items-center text-bg-warning border-0 show" role="alert"><div class="d-flex"><div class="toast-body">${message}</div><button class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" type="button"></button></div></div>`);
