      payment: { method:payments.map(p => p.name || 'Payment').join(', ') || '-', paidAmount:totals.paid || 0, changeAmount:totals.change || 0, creditUsed:totals.creditUsed || 0, remainingCredit:snapshot?.availableCreditAfter || 0 },
