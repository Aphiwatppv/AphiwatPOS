@page
@model AphiwatPOS.Pages.Sales.WholesaleCheckout.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Wholesale Checkout";
    ViewData["Subtitle"] = "Scan products, sell wholesale quantities, accept payment, and complete sales.";
    var products = Model.Products.ToArray();
    var paymentMethods = Model.PaymentMethods.ToArray();
    var wholesaleCustomers = Model.WholesaleCustomers.ToArray();
    var creditMethod = Model.CreditPaymentMethod;
    var promptPayQrUrl = Url.Page("./Index", "PromptPayQr");
    var customerSearchUrl = Url.Page("./Index", "SearchCustomers");
    var customerValidateUrl = Url.Page("./Index", "ValidateCustomer");
    var customerDisplayUrl = Url.Page("/Sales/CustomerDisplay/Index");
    var heldItems = Model.HeldSale?.Items.Select(item => new { item.ProductId, LocationId = Model.LocationId, item.Quantity, item.UnitPrice, item.ItemDiscountAmount, item.TaxAmount, ProductName = item.ProductNameSnapshot, ProductCode = item.ProductCodeSnapshot, UnitSymbol = item.UnitSymbolSnapshot, CurrentStock = 999999m, ProductImageUrl = string.Empty, WholesaleMinQty = 1m }).ToArray() ?? Array.Empty<object>();
    var lastSaleNo = TempData["LastSaleNo"] as string;
    var cashierName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "Cashier";
    var serverErrorMessage = Model.ErrorMessage;
}

<partial name="_ProductToast" model="(Model.StatusMessage, Model.ErrorMessage)" />

<div class="page-header d-flex align-items-start justify-content-between gap-3">
    <div><h1>Wholesale Checkout</h1><p>Verify customer/member first, then scan products and complete wholesale sale.</p></div>
    <a class="btn btn-outline-secondary" asp-page="/Sales/HeldSales/Index"><i class="bi bi-pause-circle me-1"></i>Held Sales</a>
</div>

<section class="wholesale-verify-panel" data-wholesale-gate>
    <div class="verify-main">
        <span class="verify-step">Step 1</span>
        <h2>Select customer/member</h2>
        <p>Ask for phone number, member code, customer name, tax ID, or company/shop name before starting the wholesale cart.</p>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-person-search"></i></span>
            <input class="form-control" data-gate-customer-search placeholder="Phone, member code, customer name, tax ID, or company/shop name" autocomplete="off" />
            <button class="btn btn-outline-primary" type="button" data-gate-search>Search</button>
        </div>
        <div class="verify-results" data-gate-results>
            @foreach (var customer in wholesaleCustomers.Take(8))
            {
                <button class="verify-result-card" type="button"
                        data-gate-customer="@customer.CustomerId"
                        data-name="@customer.CustomerName"
                        data-phone="@customer.PhoneNumber"
                        data-code="@customer.MemberCode"
                        data-level="@customer.MemberLevel"
                        data-type="@customer.CustomerType"
                        data-wholesale-allowed="@customer.IsWholesaleAllowed.ToString().ToLowerInvariant()"
                        data-credit-limit="@customer.CreditLimit"
                        data-available-credit="@customer.AvailableCredit"
                        data-outstanding="@customer.OutstandingBalance"
                        data-payment-terms="@customer.PaymentTerms"
                        data-discount-condition="@customer.DiscountCondition"
                        data-tax-id="@customer.TaxId"
                        data-address="@customer.Address"
                        data-credit-status="@customer.CreditStatus">
                    <span><strong>@customer.CustomerName</strong><small>@customer.PhoneNumber | @customer.MemberCode</small></span>
                    <span class="status-badge @(customer.IsWholesaleAllowed ? "badge-success" : "badge-warning")">@customer.CustomerType</span>
                </button>
            }
        </div>
        <div class="verify-not-found d-none" data-gate-not-found>
            <strong>No customer found</strong>
            <div class="verify-actions mt-2">
                <a class="btn btn-primary" asp-page="/Customer/CustomerList/Index" asp-route-mode="create"><i class="bi bi-person-plus me-1"></i>Register New Wholesale Customer</a>
                @if (Model.AllowWalkInWholesale)
                {
                    <button class="btn btn-outline-warning" type="button" data-gate-walkin><i class="bi bi-shop me-1"></i>Continue as Walk-in Wholesale Customer</button>
                }
                <a class="btn btn-outline-secondary" asp-page="/Index">Cancel</a>
            </div>
        </div>
    </div>
    <aside class="verify-detail" data-gate-detail>
        <span class="verify-step">Selected customer</span>
        <h3 data-gate-detail-name>No customer selected</h3>
        <div class="verify-detail-grid">
            <div><span>Phone</span><strong data-gate-detail-phone>-</strong></div>
            <div><span>Member level</span><strong data-gate-detail-level>-</strong></div>
            <div><span>Customer type</span><strong data-gate-detail-type>-</strong></div>
            <div><span>Wholesale permission</span><strong data-gate-detail-permission>-</strong></div>
            <div><span>Available credit</span><strong data-gate-detail-credit>0.00</strong></div>
            <div><span>Outstanding balance</span><strong data-gate-detail-outstanding>0.00</strong></div>
            <div><span>Payment terms</span><strong data-gate-detail-terms>-</strong></div>
            <div><span>Discount</span><strong data-gate-detail-discount>-</strong></div>
            <div><span>Tax ID</span><strong data-gate-detail-tax>-</strong></div>
            <div><span>Address</span><strong data-gate-detail-address>-</strong></div>
        </div>
        <div class="alert alert-warning d-none mt-3 mb-0" data-gate-warning></div>
        <button class="btn btn-primary w-100 mt-3" type="button" data-gate-continue disabled><i class="bi bi-arrow-right-circle me-1"></i>Continue to Wholesale Sale</button>
    </aside>
</section>

<div class="pos-shell wholesale-pos-locked" data-pos-root>
    <section class="pos-products">
        <div class="filter-card pos-scan-card">
            <div class="row g-3 align-items-end">
                <div class="col-lg-6">
                    <label class="form-label">Barcode scan</label>
                    <div class="input-group"><span class="input-group-text"><i class="bi bi-upc-scan"></i></span><input class="form-control" data-barcode-input autofocus placeholder="Scan barcode and press Enter" /></div>
                </div>
                <div class="col-lg-6">
                    <label class="form-label">Product search</label>
                    <input class="form-control" value="@Model.SearchText" data-product-search placeholder="Search name, code, or barcode" />
                </div>
                <input value="@Model.LocationId" data-location-id type="hidden" />
            </div>
            <div class="chip-row mt-3">
                <button class="filter-chip active" type="button" data-stock-filter="all">All</button>
                <button class="filter-chip" type="button" data-stock-filter="in">In stock</button>
                <button class="filter-chip" type="button" data-stock-filter="low">Low stock</button>
                <button class="filter-chip" type="button" data-stock-filter="out">Out of stock</button>
            </div>
        </div>

        <div class="product-grid mt-3" data-product-grid>
            @if (!products.Any())
            {
                <div class="data-card empty-state pos-empty"><i class="bi bi-search"></i><div class="fw-semibold">No products found</div><div>Try a different scan or search term.</div></div>
            }
            @foreach (var product in products)
            {
                var stockStatus = !product.IsStockTracked ? "service" : product.CurrentStock <= 0 ? "out" : product.CurrentStock <= 5 ? "low" : "in";
                <button class="product-card @(stockStatus == "out" ? "disabled" : "")" type="button"
                        data-product-card data-stock-status="@stockStatus"
                        data-product-id="@product.ProductId" data-location-id="@Model.LocationId" data-name="@product.ProductName"
                        data-code="@product.ProductCode" data-barcode="@product.Barcode" data-price="@product.SellingPrice" data-wholesale-min="@product.WholesaleMinQty"
                        data-tax-rate="@product.TaxRate" data-unit="@product.UnitSymbol" data-stock="@product.CurrentStock" data-image="@product.ProductImageUrl"
                        data-active="@product.IsActive.ToString().ToLowerInvariant()" data-stock-tracked="@product.IsStockTracked.ToString().ToLowerInvariant()" data-status="@product.Status"
                        @(stockStatus == "out" ? "disabled" : "")>
                    <span class="product-art">
                        @if (!string.IsNullOrWhiteSpace(product.ProductImageUrl))
                        {
                            <img src="@product.ProductImageUrl" alt="@product.ProductName" />
                        }
                        else
                        {
                            <i class="bi bi-box-seam"></i>
                        }
                    </span>
                    <span class="product-name">@product.ProductName</span>
                    <span class="product-code">@product.ProductCode</span>
                    <span class="product-meta"><strong>@product.SellingPrice.ToString("N2")</strong><span>@product.UnitSymbol · Min @product.WholesaleMinQty.ToString("N0")</span></span>
                    @if (stockStatus == "out") { <span class="badge status-badge badge-danger">Out of stock</span> }
                    else if (stockStatus == "low") { <span class="badge status-badge badge-warning">Low @product.CurrentStock.ToString("N0")</span> }
                    else { <span class="badge status-badge badge-success">Stock @product.CurrentStock.ToString("N0")</span> }
                </button>
            }
        </div>
    </section>

    <aside class="cart-panel" data-cart-panel>
        <div class="cart-hero">
            <div class="cart-icon-wrap">
                <i class="bi bi-cart-check-fill"></i>
                <span class="cart-count-badge" data-cart-count>0</span>
            </div>
            <div class="min-w-0">
                <h2>Current Cart</h2>
                <p>Review items before payment</p>
            </div>
            <div class="cart-total" data-net-total>0.00</div>
        </div>

        <div class="cart-section">
            <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                <label class="form-label mb-0">Member customer?</label>
                <div class="btn-group btn-group-sm" role="group" aria-label="Member customer">
                    <input class="btn-check" id="memberNo" name="memberChoice" type="radio" checked data-member-no>
                    <label class="btn btn-outline-secondary" for="memberNo">No</label>
                    <input class="btn-check" id="memberYes" name="memberChoice" type="radio" data-member-yes>
                    <label class="btn btn-outline-secondary" for="memberYes">Yes</label>
                </div>
            </div>
            <div class="member-lookup d-none" data-member-lookup>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-person-search"></i></span>
                    <input class="form-control" data-customer-search placeholder="Enter member phone number or name" autocomplete="off" />
                </div>
                <div class="small text-muted mt-1" data-customer-match>Ask for phone number or name, then select the member.</div>
            </div>
            <select class="form-select d-none mt-2" data-customer-id>
                <option value="">Walk-in customer</option>
                @foreach (var customer in wholesaleCustomers)
                {
                    var canUseCredit = customer.CreditLimit > 0 && customer.AvailableCredit > 0 && !customer.CreditStatus.Equals("Blocked", StringComparison.OrdinalIgnoreCase);
                    <option value="@customer.CustomerId"
                            data-name="@customer.CustomerName"
                            data-phone="@customer.PhoneNumber"
                            data-code="@customer.MemberCode"
                            data-level="@customer.MemberLevel"
                            data-type="@customer.CustomerType"
                            data-wholesale-allowed="@customer.IsWholesaleAllowed.ToString().ToLowerInvariant()"
                            data-allow-credit="@canUseCredit.ToString().ToLowerInvariant()"
                            data-credit-limit="@customer.CreditLimit"
                            data-used-credit="@customer.OutstandingBalance"
                            data-available-credit="@customer.AvailableCredit"
                            data-credit-status="@customer.CreditStatus"
                            data-payment-terms="@customer.PaymentTerms"
                            data-discount-condition="@customer.DiscountCondition"
                            data-tax-id="@customer.TaxId"
                            data-address="@customer.Address"
                            data-require-approval="false">
                        @customer.CustomerName - @customer.PhoneNumber (@customer.MemberCode)
                    </option>
                }
            </select>
            <div class="selected-member-card d-none mt-2" data-selected-member>
                <span class="selected-member-icon"><i class="bi bi-person-check-fill"></i></span>
                <div class="min-w-0">
                    <strong data-selected-customer-name>Member selected</strong>
                    <div class="small text-muted" data-selected-customer-meta></div>
                </div>
            </div>
            <div class="customer-credit-panel d-none mt-2" data-credit-panel>
                <div class="summary-line"><span>Member level</span><strong data-credit-level>-</strong></div>
                <div class="summary-line"><span>Credit limit</span><strong data-credit-limit>0.00</strong></div>
                <div class="summary-line"><span>Used credit</span><strong data-credit-used>0.00</strong></div>
                <div class="summary-line"><span>Credit status</span><strong data-credit-status>Good</strong></div>
                <div class="summary-line"><span>Available credit</span><strong data-credit-available>0.00</strong></div>
                <div class="credit-progress" aria-label="Customer credit usage">
                    <span data-credit-progress></span>
                </div>
                <div class="credit-fit-message small mt-2" data-credit-fit-message>Choose a member to review credit for this sale.</div>
                <button class="btn btn-warning w-100 mt-2" type="button" data-use-credit disabled><i class="bi bi-credit-card me-1"></i>Use Credit</button>
                <div class="alert alert-warning py-2 mt-2 mb-0 d-none" data-credit-note>
                    <i class="bi bi-exclamation-triangle me-1"></i><span data-credit-note-text>This sale will increase used credit. Customer must repay this amount later.</span>
                </div>
                <div class="text-warning small d-none" data-credit-warning><i class="bi bi-exclamation-triangle me-1"></i>Manager approval may be required for this customer.</div>
            </div>
            @if (!Model.Customers.Any())
            {
                <div class="text-muted small mt-2">No active members found. Continue as walk-in customer.</div>
            }
        </div>

        <div class="cart-items" data-cart-items>
            <div class="empty-state empty-cart">
                <i class="bi bi-cart-x"></i>
                <div class="fw-semibold">Your cart is empty</div>
                <div>Scan barcode or select products to start a wholesale sale.</div>
            </div>
        </div>

        <div class="cart-section payment-summary-card">
            <div class="payment-summary-head">
                <div>
                    <div class="summary-kicker">Payment Summary</div>
                    <strong>Review totals</strong>
                </div>
                <span class="payment-status-pill due" data-cart-payment-badge>Balance Due</span>
            </div>
            <div class="summary-line"><span>Subtotal</span><strong data-subtotal>0.00</strong></div>
            <div class="summary-line"><span>Item discount</span><strong data-item-discount>0.00</strong></div>
            <div class="summary-line align-items-center"><span>Order discount</span><input class="form-control form-control-sm text-end" data-order-discount type="number" min="0" step="0.01" value="0" @(Model.CanDiscount ? "" : "disabled") /></div>
            <div class="summary-line"><span>Product VAT</span><strong data-line-tax>0.00</strong></div>
            <div class="summary-line align-items-center"><span>Additional tax</span><input class="form-control form-control-sm text-end" data-tax-amount type="number" min="0" step="0.01" value="0" /></div>
            <div class="summary-divider"></div>
            <div class="summary-line total summary-net-row"><span>Net amount</span><strong data-net>0.00</strong></div>
            <div class="summary-divider"></div>
            <div class="summary-line credit-summary-row"><span><i class="bi bi-credit-card me-1"></i>Customer credit used</span><strong data-credit-used-sale>0.00</strong></div>
            <div class="summary-line"><span>Other payment amount</span><strong data-other-paid>0.00</strong></div>
            <div class="summary-line remaining-row" data-remaining-row><span>Remaining balance</span><strong data-remaining>0.00</strong></div>
            <div class="summary-line"><span>Paid amount</span><strong data-paid>0.00</strong></div>
            <div class="summary-line change-row" data-change-row><span>Change</span><strong data-change>0.00</strong></div>
        </div>

        <div class="cart-section">
            <label class="form-label">Payment method</label>
            <div class="payment-due-callout due" data-payment-due-callout>
                <span><i class="bi bi-exclamation-circle"></i>Outstanding</span>
                <strong data-payment-outstanding>0.00</strong>
            </div>
            @if (!paymentMethods.Any())
            {
                <div class="empty-state py-3"><i class="bi bi-credit-card"></i><div>No payment methods found</div></div>
            }
            <div class="payment-method-grid">
                @foreach (var method in paymentMethods)
                {
                    var isCredit = creditMethod?.PaymentMethodId == method.PaymentMethodId;
                    var isPromptPay = method.PaymentMethodCode.Equals("QR", StringComparison.OrdinalIgnoreCase) || method.PaymentMethodName.Contains("QR", StringComparison.OrdinalIgnoreCase);
                    <button class="payment-method-card @(method.IsCash ? "active" : "") @(isCredit ? "d-none" : "")" type="button" data-payment-method="@method.PaymentMethodId" data-require-ref="@method.RequireReferenceNo.ToString().ToLowerInvariant()" data-is-cash="@method.IsCash.ToString().ToLowerInvariant()" data-is-credit="@isCredit.ToString().ToLowerInvariant()" data-is-promptpay="@isPromptPay.ToString().ToLowerInvariant()">
                        <i class="bi @(method.IsCash ? "bi-cash-stack" : isCredit ? "bi-person-vcard" : isPromptPay ? "bi-qr-code" : "bi-credit-card")"></i><span>@(isCredit ? "Use Credit" : method.PaymentMethodName)</span>
                    </button>
                }
            </div>
            <div class="row g-2 mt-2">
                <div class="col-7"><input class="form-control payment-amount-input" data-payment-amount type="number" min="0" step="0.01" placeholder="Payment amount" /></div>
                <div class="col-5"><input class="form-control" data-payment-ref placeholder="Reference no" /></div>
                <div class="col-12"><button class="btn btn-outline-secondary w-100" type="button" data-add-payment><i class="bi bi-plus-lg me-1"></i>Add Payment</button></div>
            </div>
            <div class="promptpay-panel d-none mt-3" data-promptpay-panel data-promptpay-url="@promptPayQrUrl">
                <div class="d-flex align-items-center justify-content-between gap-2">
                    <div>
                        <strong><i class="bi bi-qr-code me-1"></i>PromptPay QR</strong>
                        <div class="small text-muted">Generate QR for the remaining balance.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" type="button" data-open-customer-display>
                            Display
                        </button>
                        <button class="btn btn-sm btn-outline-primary" type="button" data-generate-promptpay>
                            Generate
                        </button>
                    </div>
                </div>
                <div class="promptpay-preview d-none" data-promptpay-preview>
                    <div class="promptpay-qr-box" data-promptpay-svg></div>
                    <img class="d-none" alt="PromptPay QR Code" data-promptpay-image />
                    <div class="promptpay-meta">
                        <strong data-promptpay-amount>0.00</strong>
                        <span data-promptpay-name>PromptPay</span>
                    </div>
                </div>
                <div class="alert alert-danger d-none py-2 mt-2 mb-0" data-promptpay-error></div>
            </div>
            <div class="payment-list mt-2" data-payment-list></div>
        </div>

        <div class="cart-actions">
            <button class="btn btn-primary btn-lg w-100" type="button" data-bs-toggle="modal" data-bs-target="#paymentConfirmModal"><i class="bi bi-bag-check me-1"></i>Pay Now</button>
            <button class="btn btn-warning w-100" type="button" data-bs-toggle="modal" data-bs-target="#holdSaleModal"><i class="bi bi-pause-circle me-1"></i>Hold Sale</button>
            <button class="btn btn-outline-danger w-100" type="button" data-bs-toggle="modal" data-bs-target="#clearCartModal"><i class="bi bi-trash me-1"></i>Clear Cart</button>
        </div>
    </aside>
</div>

<button class="floating-cart-btn" type="button" data-mobile-cart><i class="bi bi-cart4"></i><span data-cart-count-mobile>0</span></button>

<form method="post" asp-page-handler="CompleteSale" data-complete-form>
    <input type="hidden" asp-for="Input.CustomerId" data-post-customer />
    <input type="hidden" asp-for="Input.HeldSaleHeaderId" value="@Model.HeldSaleHeaderId" />
    <input type="hidden" asp-for="Input.OrderDiscountAmount" data-post-discount />
    <input type="hidden" asp-for="Input.TaxAmount" data-post-tax />
    <input type="hidden" asp-for="Input.ItemsJson" data-post-items />
    <input type="hidden" asp-for="Input.PaymentsJson" data-post-payments />
</form>
<form method="post" asp-page-handler="HoldSale" data-hold-form>
    <input type="hidden" asp-for="Input.CustomerId" data-hold-customer />
    <input type="hidden" asp-for="Input.TaxAmount" data-hold-tax />
    <input type="hidden" asp-for="Input.ItemsJson" data-hold-items />
    <input type="hidden" asp-for="Input.HoldNote" data-hold-note />
</form>

<div class="modal fade app-modal" id="paymentConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered payment-review-dialog">
        <div class="modal-content payment-review-modal">
            <div class="modal-header">
                <div>
                    <h2 class="modal-title h5">Confirm Payment</h2>
                    <p class="modal-subtitle">Review payment details before completing this sale.</p>
                </div>
                <button class="btn-close" data-bs-dismiss="modal" type="button"></button>
            </div>
            <div class="modal-body">
                <section class="payment-review-hero">
                    <div>
                        <span class="review-label">Net Amount</span>
                        <strong data-modal-net-large>THB 0.00</strong>
                        <div class="review-helper" data-modal-status-text>Waiting for payment</div>
                    </div>
                    <span class="review-status-badge due" data-payment-status-badge>Balance Due</span>
                </section>
                <div class="review-meta-grid">
                    <div><span>Customer</span><strong data-modal-customer>Walk-in</strong></div>
                    <div><span>Items</span><strong data-modal-items>0 items</strong></div>
                </div>
                <h3 class="review-section-title">Payment Breakdown</h3>
                <div class="payment-breakdown">
                    <div class="breakdown-row net"><span>Net Amount</span><strong data-modal-net>0.00</strong></div>
                    <div class="breakdown-row credit"><span><i class="bi bi-credit-card me-1"></i>Customer Credit Used</span><strong data-modal-credit>0.00</strong></div>
                    <div class="breakdown-row"><span>Other Payments</span><strong data-modal-other-paid>0.00</strong></div>
                    <div class="breakdown-row remaining" data-modal-remaining-row><span>Remaining Balance</span><strong data-modal-remaining>0.00</strong></div>
                    <div class="breakdown-row paid"><span>Paid Amount</span><strong data-modal-paid>0.00</strong></div>
                    <div class="breakdown-row change" data-modal-change-row><span>Change Amount</span><strong data-modal-change>0.00</strong></div>
                </div>
                <div class="review-info success d-none" data-credit-paid-info>
                    <i class="bi bi-credit-card"></i>
                    <span>This sale is fully paid using customer credit. No cash payment is required.</span>
                </div>
                <div class="review-info warning d-none" data-credit-debt-warning>
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>Customer credit used in this sale will become customer debt and must be repaid later.</span>
                </div>
                <div class="review-info danger d-none" data-payment-incomplete-warning>
                    <i class="bi bi-x-circle"></i>
                    <span>Payment is incomplete. Remaining balance must be paid before completing sale.</span>
                </div>
                <div class="review-info neutral">
                    <i class="bi bi-receipt"></i>
                    <span>Invoice/receipt will be available after payment confirmation.</span>
                </div>
                <div class="alert alert-danger d-none mt-3" data-payment-error></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button>
                <button class="btn btn-primary" data-confirm-pay type="button"><i class="bi bi-check-circle me-1"></i>Confirm Payment</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade app-modal" id="holdSaleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title h5">Hold Sale</h2><button class="btn-close" data-bs-dismiss="modal" type="button"></button></div><div class="modal-body"><label class="form-label">Hold note</label><textarea class="form-control" data-hold-note-input rows="3" placeholder="Customer name, reason, or pickup note"></textarea><div class="summary-line total mt-3"><span>Estimated total</span><strong data-hold-total>0.00</strong></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button><button class="btn btn-warning" data-confirm-hold type="button">Confirm Hold</button></div></div></div>
</div>
<div class="modal fade app-modal" id="clearCartModal" tabindex="-1" aria-hidden="true">
