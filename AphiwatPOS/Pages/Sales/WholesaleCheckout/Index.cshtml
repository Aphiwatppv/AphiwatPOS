    by('[data-modal-customer]').textContent = customerName;
    by('[data-modal-items]').textContent = `${count} item${count === 1 ? '' : 's'}`;
    by('[data-modal-status-text]').textContent = creditFullyPaid ? 'Fully paid by customer credit' : fullyPaid ? 'Payment covers this sale' : 'Remaining balance must be collected';
    by('[data-credit-debt-warning]').classList.toggle('d-none', creditUsed <= 0);
    by('[data-credit-paid-info]').classList.toggle('d-none', !creditFullyPaid);
    by('[data-payment-incomplete-warning]').classList.toggle('d-none', remaining <= 0);
    by('[data-confirm-pay]').disabled = remaining > 0;
    const statusBadge = by('[data-payment-status-badge]');
    statusBadge.textContent = creditUsed > 0 && fullyPaid ? 'Credit Used' : fullyPaid ? 'Fully Paid' : 'Balance Due';
    statusBadge.className = `review-status-badge ${fullyPaid ? (creditUsed > 0 ? 'credit' : 'paid') : 'due'}`;
    const cartBadge = by('[data-cart-payment-badge]');
    cartBadge.textContent = fullyPaid ? 'Paid' : 'Balance Due';
    cartBadge.className = `payment-status-pill ${fullyPaid ? 'paid' : 'due'}`;
    by('[data-remaining-row]').classList.toggle('paid', remaining <= 0);
    by('[data-remaining-row]').classList.toggle('due', remaining > 0);
    by('[data-payment-due-callout]').classList.toggle('paid', remaining <= 0);
    by('[data-payment-due-callout]').classList.toggle('due', remaining > 0);
    by('[data-modal-remaining-row]').classList.toggle('paid', remaining <= 0);
    by('[data-modal-remaining-row]').classList.toggle('due', remaining > 0);
