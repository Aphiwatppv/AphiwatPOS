  function addProduct(product, showToast = true) {
    ensureCustomerDisplayOpen(false);
    const item = product.dataset ? normalizeProduct({ productId:product.dataset.productId, locationId:product.dataset.locationId, quantity:product.dataset.wholesaleMin || 1, unitPrice:product.dataset.price, itemDiscountAmount:0, taxAmount:0, taxRate:product.dataset.taxRate, productName:product.dataset.name, productCode:product.dataset.code, unitSymbol:product.dataset.unit, currentStock:product.dataset.stock, productImageUrl:product.dataset.image, wholesaleMinQty:product.dataset.wholesaleMin, isActive:product.dataset.active === 'true', isStockTracked:product.dataset.stockTracked !== 'false', status:product.dataset.status }) : normalizeProduct(product);
    if (item.isActive === false || String(item.status || '').toLowerCase() === 'inactive') return showProductWarning('Product is inactive.');
    const existing = cart.find(x => x.productId === item.productId);
    if (existing) {
      const addQty = Math.max(1, Number(existing.wholesaleMinQty || 1));
      if (existing.isStockTracked !== false && existing.quantity + addQty > Number(existing.currentStock || 0)) return showStock(existing, existing.quantity + addQty);
      existing.quantity += addQty;
    } else {
      if (item.isStockTracked !== false && Number(item.currentStock || 0) <= 0) return showStock(item, 1);
      cart.push(item);
    }
    render();
    if (showToast) showProductAdded();
