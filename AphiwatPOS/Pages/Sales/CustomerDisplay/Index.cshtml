@page
@{
    Layout = null;
    ViewData["Title"] = "Customer Display";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Customer Display</title>
    <style>
        :root{color-scheme:light;--bg:#f3faf7;--panel:#fff;--ink:#123026;--muted:#64748b;--line:#cbd5e1;--success:#047857;--danger:#dc2626;--warning:#f59e0b;--brand:#059669;--brand-soft:#ecfdf5}
        *{box-sizing:border-box}
        html,body{height:100%;overflow:hidden;width:100%}
        body{background:var(--bg);color:var(--ink);font-family:Arial,Helvetica,sans-serif;margin:0}
        .display-shell{display:grid;gap:14px;grid-template-rows:auto minmax(0,1fr) auto;height:100vh;max-height:100vh;overflow:hidden;padding:18px;width:100vw}
        .display-shell.is-ready,.display-shell.is-success{display:block;padding:0}
        .topbar{align-items:center;background:var(--brand);color:#fff;display:flex;gap:22px;justify-content:space-between;min-height:82px;padding:16px 22px}
        .brand{font-size:clamp(2rem,3.4vw,3.7rem);font-weight:900;letter-spacing:0;line-height:1}
        .status{background:#e0f2fe;border:1px solid #7dd3fc;color:#075985;font-size:clamp(1.25rem,2.2vw,2rem);font-weight:900;min-width:320px;padding:14px 18px;text-align:center;text-transform:uppercase}
        .status.success{background:#dcfce7;border-color:#86efac;color:var(--success)}
        .status.fail{background:#fee2e2;border-color:#fca5a5;color:var(--danger)}
        .status.warning{background:#fffbeb;border-color:#fcd34d;color:#92400e}
        .main-grid{display:grid;gap:14px;grid-template-columns:minmax(0,1fr) minmax(390px,34vw);min-height:0}
        .panel{background:var(--panel);border:1px solid var(--line);box-shadow:0 14px 36px rgba(15,23,42,.08)}
        .cart-panel{display:grid;grid-template-rows:auto auto minmax(0,1fr);min-height:0}
        .panel-head{align-items:center;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;padding:14px 18px}
        .panel-title{font-size:clamp(1.35rem,2vw,2rem);font-weight:900;line-height:1}
        .panel-subtitle{color:var(--muted);font-size:clamp(1rem,1.3vw,1.35rem);font-weight:800;margin-top:4px}
        .items{display:grid;min-height:0;overflow:auto}
        .item-row,.item-header{display:grid;gap:18px;grid-template-columns:minmax(360px,1fr) 120px 170px 145px 190px;padding:15px 18px}
        .item-header{background:#f8fafc;border-bottom:1px solid var(--line);color:var(--muted);font-size:clamp(.95rem,1.15vw,1.2rem);font-weight:900;text-transform:uppercase}
        .item-row{align-items:center;border-bottom:1px solid #e2e8f0;font-size:clamp(1.2rem,1.55vw,1.65rem)}
        .item-row:last-child{border-bottom:0}
        .product-cell{align-items:center;display:grid;gap:14px;grid-template-columns:76px minmax(0,1fr)}
        .product-image{align-items:center;background:var(--brand-soft);border:1px solid #a7f3d0;color:var(--brand);display:flex;font-size:2rem;height:76px;justify-content:center;overflow:hidden;width:76px}
        .product-image img{display:block;height:100%;object-fit:cover;width:100%}
        .item-name{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
        .item-code{color:var(--muted);font-size:1rem;font-weight:800;margin-top:3px}
        .num{text-align:right}
        .muted{color:var(--muted)}
        .empty{align-content:center;color:var(--muted);display:grid;font-size:clamp(1.8rem,3.6vw,3.4rem);font-weight:900;justify-items:center;min-height:100%;text-align:center}
        .display-bottom{display:grid;gap:14px;min-height:0}
        .totals{display:grid}
        .line{align-items:center;border-bottom:1px solid #e2e8f0;display:flex;gap:16px;justify-content:space-between;padding:12px 16px}
        .line:last-child{border-bottom:0}
        .line span{color:var(--muted);font-size:clamp(1rem,1.25vw,1.3rem);font-weight:900}
        .line strong{font-size:clamp(1.15rem,1.55vw,1.65rem)}
        .line.total{background:var(--brand-soft)}
        .line.total span{color:#065f46}
        .line.total strong{color:var(--brand);font-size:clamp(2.45rem,4vw,4.6rem);line-height:1}
        .line.paid strong,.line.change strong{color:var(--success)}
        .line.remaining.due strong{color:var(--danger)}
        .info-grid{display:grid;gap:10px;padding:14px 16px}
        .info-row{display:flex;gap:12px;justify-content:space-between}
        .info-row span{color:var(--muted);font-size:clamp(.98rem,1.15vw,1.2rem);font-weight:900}
        .info-row strong{font-size:clamp(1.05rem,1.35vw,1.45rem);text-align:right}
        .payment-panel{display:grid;grid-template-rows:auto auto minmax(260px,1fr);min-height:0}
        .payment-panel .panel-head{background:var(--brand-soft)}
        .payment-panel .panel-title{color:#065f46;font-size:clamp(1.8rem,2.8vw,3rem)}
        .payment-panel .info-grid{gap:14px;padding:18px}
        .payment-panel .info-row span{font-size:clamp(1.18rem,1.6vw,1.6rem)}
        .payment-panel .info-row strong{font-size:clamp(1.4rem,2vw,2.2rem)}
        .qr-box{align-items:center;background:#fff;border:1px solid #a7f3d0;display:flex;justify-content:center;margin:0 18px 18px;min-height:260px;padding:18px}
        .qr-box svg,.qr-box img{display:block;height:min(34vh,360px);max-width:100%;width:min(34vh,360px)}
        .result-icon{align-items:center;display:flex;font-size:clamp(2.4rem,5.8vw,6.4rem);font-weight:900;height:100%;justify-content:center;min-height:260px;width:100%}
        .result-icon.success{background:#dcfce7;color:var(--success)}
        .result-icon.fail{background:#fee2e2;color:var(--danger)}
        .result-icon.idle{background:#eff6ff;color:#1d4ed8;font-size:clamp(1.5rem,3vw,3rem);padding:8px;text-align:center}
        .message-bar{background:#fff;border:1px solid var(--line);font-size:clamp(1.35rem,2.2vw,2.25rem);font-weight:900;line-height:1.15;min-height:70px;padding:14px 20px;text-align:center}
        .message-bar.success{background:#ecfdf5;border-color:#86efac;color:var(--success)}
        .message-bar.fail{background:#fef2f2;border-color:#fca5a5;color:var(--danger)}
        .message-bar.warning{background:#fffbeb;border-color:#fcd34d;color:#92400e}
        .full-state{align-items:center;background:linear-gradient(180deg,#ffffff 0%,#f3faf7 100%);display:none;height:100vh;justify-content:center;overflow:hidden;padding:clamp(28px,5vw,72px);text-align:center;width:100vw}
        .display-shell.is-ready .ready-state,.display-shell.is-success .success-state{display:flex}
        .display-shell.is-ready .topbar,.display-shell.is-ready .main-grid,.display-shell.is-ready .message-bar,.display-shell.is-success .topbar,.display-shell.is-success .main-grid,.display-shell.is-success .message-bar{display:none}
        .state-content{display:grid;gap:clamp(14px,2.4vw,28px);justify-items:center;max-width:1100px;width:min(100%,1100px)}
        .state-logo{align-items:center;background:var(--brand);color:#fff;display:flex;font-size:clamp(2.3rem,5vw,5.8rem);font-weight:900;height:clamp(110px,18vw,210px);justify-content:center;line-height:1;padding:0 clamp(28px,4vw,54px);min-width:min(82vw,620px)}
        .state-kicker{color:var(--muted);font-size:clamp(1.2rem,2vw,2.1rem);font-weight:900;text-transform:uppercase}
        .state-title{color:#123026;font-size:clamp(3.2rem,8vw,9rem);font-weight:900;letter-spacing:0;line-height:.95;margin:0}
        .state-subtitle{color:var(--muted);font-size:clamp(1.5rem,3vw,3.5rem);font-weight:900;line-height:1.1;margin:0}
        .success-icon{align-items:center;background:#dcfce7;color:var(--success);display:flex;font-size:clamp(4.2rem,9vw,10rem);font-weight:900;height:clamp(130px,18vw,230px);justify-content:center;width:clamp(130px,18vw,230px);border-radius:999px}
        .success-meta{display:grid;gap:12px;grid-template-columns:repeat(2,minmax(260px,1fr));margin-top:10px;max-width:980px;width:100%}
        .success-meta div{background:#fff;border:1px solid var(--line);display:flex;gap:18px;justify-content:space-between;padding:18px 22px;text-align:left}
        .success-meta span{color:var(--muted);font-size:clamp(1rem,1.4vw,1.5rem);font-weight:900}
        .success-meta strong{color:#0f172a;font-size:clamp(1.2rem,1.8vw,2rem);font-weight:900;text-align:right}
        .success-meta .full{grid-column:1/-1}
        .repayment-state{background:#f8fafc;display:none;height:100vh;overflow:hidden;padding:clamp(18px,2.5vw,34px);width:100vw}
        .display-shell.is-repayment{display:block;padding:0}
        .display-shell.is-repayment .repayment-state{display:grid}
        .display-shell.is-repayment .topbar,.display-shell.is-repayment .main-grid,.display-shell.is-repayment .message-bar{display:none}
        .repayment-layout{display:grid;gap:16px;grid-template-rows:auto minmax(0,1fr) auto;height:100%;min-height:0}
        .repayment-hero{align-items:center;background:#0f766e;color:#fff;display:flex;gap:18px;justify-content:space-between;padding:20px 24px}
        .repayment-hero h1{font-size:clamp(2rem,4.4vw,5rem);font-weight:900;line-height:1;margin:0}
        .repayment-hero p{font-size:clamp(1.1rem,1.8vw,2rem);font-weight:800;margin:6px 0 0;opacity:.9}
        .repayment-badge{background:#ecfdf5;color:#065f46;font-size:clamp(1rem,1.5vw,1.6rem);font-weight:900;padding:12px 16px;text-align:center;text-transform:uppercase}
        .repayment-grid{display:grid;gap:16px;grid-template-columns:minmax(0,.95fr) minmax(0,1.05fr);min-height:0}
        .repayment-card{background:#fff;border:1px solid var(--line);display:grid;min-height:0;padding:18px}
        .repayment-card h2{font-size:clamp(1.2rem,1.9vw,2rem);font-weight:900;margin:0 0 14px}
        .repayment-row{align-items:center;border-bottom:1px solid #e2e8f0;display:flex;gap:12px;justify-content:space-between;padding:11px 0}
        .repayment-row:last-child{border-bottom:0}
        .repayment-row span{color:var(--muted);font-size:clamp(.98rem,1.3vw,1.4rem);font-weight:900}
        .repayment-row strong{font-size:clamp(1.1rem,1.65vw,1.9rem);font-weight:900;text-align:right}
        .repayment-amount-panel{align-items:center;background:#ecfdf5;border:1px solid #a7f3d0;display:grid;gap:8px;justify-items:center;margin-bottom:14px;padding:22px;text-align:center}
        .repayment-amount-panel span{color:#065f46;font-size:clamp(1.1rem,1.5vw,1.6rem);font-weight:900;text-transform:uppercase}
        .repayment-amount-panel strong{color:#047857;font-size:clamp(3rem,6vw,7rem);font-weight:900;line-height:1}
        .repayment-footer{background:#fff;border:1px solid var(--line);font-size:clamp(1.2rem,2vw,2.2rem);font-weight:900;padding:16px 20px;text-align:center}
        .repayment-footer.warning{background:#fffbeb;border-color:#fcd34d;color:#92400e}
        .repayment-footer.fail{background:#fef2f2;border-color:#fca5a5;color:#b91c1c}
        @@media(max-width:1180px){.main-grid{grid-template-columns:1fr;grid-template-rows:minmax(0,1fr) auto}.payment-panel{grid-template-columns:1fr 1fr;grid-template-rows:auto 1fr}.payment-panel .panel-head{grid-column:1/-1}.qr-box{margin:14px 16px}.item-row,.item-header{grid-template-columns:minmax(280px,1fr) 90px 135px 115px 145px}}
        @@media(max-width:800px){.display-shell{gap:10px;padding:10px}.topbar{align-items:stretch;display:grid;min-height:auto}.status{min-width:0}.payment-panel{display:block}.item-header{display:none}.item-row{grid-template-columns:1fr 1fr;gap:8px}.product-cell{grid-column:1/-1}.num{text-align:left}.line.total strong{font-size:2.2rem}.success-meta{grid-template-columns:1fr}.success-meta .full{grid-column:auto}.success-meta div{display:grid;text-align:center}.success-meta strong{text-align:center}.repayment-grid{grid-template-columns:1fr}.repayment-hero{align-items:flex-start;display:grid}.repayment-state{overflow:auto}}
    </style>
</head>
<body>
    <main class="display-shell">
        <section class="full-state ready-state" aria-label="Ready">
            <div class="state-content">
                <div class="state-logo">AphiwatPOS</div>
                <div class="state-kicker" data-ready-terminal>Terminal default</div>
                <h1 class="state-title">Ready for next customer</h1>
                <p class="state-subtitle">Welcome</p>
            </div>
        </section>
        <section class="full-state success-state" aria-label="Payment Success">
            <div class="state-content">
                <div class="success-icon">&#10003;</div>
                <h1 class="state-title">Thank you for your purchase</h1>
                <p class="state-subtitle">Payment completed successfully</p>
                <div class="success-meta">
                    <div><span>Invoice No / Sale No</span><strong data-success-sale-no>-</strong></div>
                    <div><span>Grand Total</span><strong data-success-total>THB 0.00</strong></div>
                    <div><span>Payment Method</span><strong data-success-method>-</strong></div>
                    <div data-success-change-row><span>Change Amount</span><strong data-success-change>THB 0.00</strong></div>
                </div>
            </div>
        </section>
        <section class="repayment-state" aria-label="Credit Repayment">
            <div class="repayment-layout">
                <header class="repayment-hero">
                    <div>
                        <h1 data-repayment-title>Credit Repayment</h1>
                        <p data-repayment-subtitle>Please wait while we check your account.</p>
                    </div>
                    <div class="repayment-badge" data-repayment-status>Credit Repayment</div>
                </header>
                <section class="repayment-grid">
                    <div class="repayment-card">
                        <h2>Customer Information</h2>
                        <div class="repayment-row"><span>Customer name</span><strong data-repay-customer-name>-</strong></div>
                        <div class="repayment-row"><span>Member code</span><strong data-repay-member-code>-</strong></div>
                        <div class="repayment-row"><span>Phone number</span><strong data-repay-phone>-</strong></div>
                        <div class="repayment-row"><span>Member level</span><strong data-repay-level>-</strong></div>
                        <div class="repayment-row"><span>Customer type</span><strong data-repay-type>-</strong></div>
                        <div class="repayment-row"><span>Available credit</span><strong data-repay-available>THB 0.00</strong></div>
                        <div class="repayment-row"><span>Outstanding balance</span><strong data-repay-outstanding>THB 0.00</strong></div>
                    </div>
                    <div class="repayment-card">
                        <h2>Repayment Summary</h2>
                        <div class="repayment-amount-panel"><span>Repayment amount</span><strong data-repay-amount-large>THB 0.00</strong></div>
                        <div class="repayment-row"><span>Previous outstanding</span><strong data-repay-before>THB 0.00</strong></div>
                        <div class="repayment-row"><span>Remaining balance</span><strong data-repay-remaining>THB 0.00</strong></div>
                        <div class="repayment-row"><span>Payment method</span><strong data-repay-method>-</strong></div>
                        <div class="repayment-row"><span>Cash received</span><strong data-repay-cash>THB 0.00</strong></div>
                        <div class="repayment-row"><span>Change amount</span><strong data-repay-change>THB 0.00</strong></div>
                        <div class="repayment-row"><span>Overdue amount</span><strong data-repay-overdue>THB 0.00</strong></div>
                        <div class="repayment-row"><span>Unpaid invoices</span><strong data-repay-unpaid>0</strong></div>
                        <div class="repayment-row"><span>Due date</span><strong data-repay-due>-</strong></div>
                        <div class="repayment-row"><span>Last repayment</span><strong data-repay-last>-</strong></div>
                    </div>
                </section>
                <footer class="repayment-footer" data-repayment-message>Please confirm your repayment amount with the cashier.</footer>
            </div>
        </section>
        <header class="topbar">
            <div class="brand">AphiwatPOS</div>
            <div class="status" data-display-status>Scanning Items</div>
        </header>

        <section class="main-grid">
            <div class="panel cart-panel">
                <div class="panel-head">
                    <div>
                        <div class="panel-title">Current Cart</div>
                        <div class="panel-subtitle"><span data-item-count>0 items</span> | <span data-updated-at>-</span></div>
                    </div>
                    <strong data-sale-no>-</strong>
                </div>
                <div class="item-header">
                    <div>Product</div><div class="num">Qty</div><div class="num">Unit Price</div><div class="num">Discount</div><div class="num">Line Total</div>
                </div>
                <div class="items" data-items>
                    <div class="empty">Waiting for scanned items</div>
                </div>
            </div>

            <section class="display-bottom" aria-label="Payment">
                <div class="panel payment-panel">
                    <div class="panel-head"><div class="panel-title">Payment</div><strong data-customer-name>Walk-in Customer</strong></div>
                    <div class="info-grid">
                        <div class="info-row"><span>Grand Total</span><strong data-total>THB 0.00</strong></div>
                        <div class="info-row"><span>Method</span><strong data-payment-method>-</strong></div>
                        <div class="info-row"><span>Paid Amount</span><strong data-paid>THB 0.00</strong></div>
                        <div class="info-row"><span>Change Amount</span><strong data-change>THB 0.00</strong></div>
                        <div class="info-row"><span>Remaining</span><strong data-remaining>THB 0.00</strong></div>
                    </div>
                    <div class="qr-box" data-visual><div class="result-icon idle">POS</div></div>
                </div>
            </section>
        </section>

        <footer class="message-bar" data-result-message>Welcome. Your purchase details will appear here.</footer>
    </main>

    <script>
    (() => {
      const languageKey = 'aphiwatpos.language';
      const originalText = new WeakMap();
      let applying = false;
      const phrases = {
        th: {
          'AphiwatPOS': 'AphiwatPOS',
          'Change Amount': 'เงินทอน',
          'Current Cart': 'ตะกร้าปัจจุบัน',
          'Discount': 'ส่วนลด',
          'Grand Total': 'ยอดรวมสุทธิ',
          'Line Total': 'ยอดรวมรายการ',
          'Method': 'วิธีชำระเงิน',
          'Paid Amount': 'ยอดที่ชำระ',
          'Payment': 'การชำระเงิน',
          'Payment Failed': 'ชำระเงินไม่สำเร็จ',
          'Payment Successful': 'ชำระเงินสำเร็จ',
          'POS': 'POS',
          'Product': 'สินค้า',
          'Qty': 'จำนวน',
          'Ready to complete payment.': 'พร้อมรับชำระเงิน',
          'Remaining': 'คงเหลือ',
          'Scan the QR code to pay with mobile banking.': 'สแกน QR เพื่อชำระผ่านโมบายแบงก์กิ้ง',
          'Scanning Items': 'กำลังสแกนสินค้า',
          'Thank you for your purchase. Payment successful.': 'ขอบคุณสำหรับการซื้อ ชำระเงินสำเร็จ',
          'Unit Price': 'ราคาต่อหน่วย',
          'Waiting for Payment': 'รอการชำระเงิน',
          'Waiting for payment.': 'รอการชำระเงิน',
          'Waiting for scanned items': 'รอรายการสินค้าที่สแกน',
          'Walk-in Customer': 'ลูกค้าทั่วไป',
          'Welcome. Your purchase details will appear here.': 'ยินดีต้อนรับ รายละเอียดการซื้อจะแสดงที่นี่'
        }
      };
      const language = () => localStorage.getItem(languageKey) === 'th' ? 'th' : 'en';
      const translate = (value) => {
        const nextLanguage = language();
        if (nextLanguage === 'en') return value;
        const source = value.replace(/\s+/g, ' ').trim();
        if (!source) return value;
        if (phrases.th[source]) return value.replace(source, phrases.th[source]);
        const itemMatch = source.match(/^(\d+)\s+items?$/i);
        if (itemMatch) return value.replace(source, `${itemMatch[1]} รายการ`);
        const saleMatch = source.match(/^Sale\s+(.+)$/i);
        if (saleMatch) return value.replace(source, `บิล ${saleMatch[1]}`);
        return value;
      };
      window.applyCustomerDisplayLanguage = () => {
        if (!document.body) return;
        applying = true;
        document.documentElement.lang = language();
        const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
        const nodes = [];
        while (walker.nextNode()) nodes.push(walker.currentNode);
        nodes.forEach((node) => {
          if (node.parentElement?.closest('script, style, noscript')) return;
          if (!originalText.has(node)) originalText.set(node, node.nodeValue);
          const nextText = translate(originalText.get(node));
          if (node.nodeValue !== nextText) node.nodeValue = nextText;
        });
        setTimeout(() => { applying = false; }, 0);
      };
      window.addEventListener('storage', (event) => {
        if (event.key === languageKey) window.applyCustomerDisplayLanguage();
      });
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'characterData') originalText.delete(mutation.target);
        });
        if (!applying) window.applyCustomerDisplayLanguage();
      });
      observer.observe(document.body, { childList: true, characterData: true, subtree: true });
      window.applyCustomerDisplayLanguage();
    })();
    </script>

    <script>
    (() => {
      const channelName = 'aphiwatpos-customer-display';
      const storageKey = 'aphiwatpos:customer-display';
      const terminalStorageKey = 'aphiwatpos:terminal-id';
      const terminalId = new URLSearchParams(location.search).get('terminalId') || localStorage.getItem(terminalStorageKey) || 'default';
      const money = value => Number(value || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      const thb = value => `THB ${money(value)}`;
      const by = selector => document.querySelector(selector);
      const esc = value => String(value ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
      let displaySocket = null;
      let invocationId = 0;
      let successResetTimer = null;

      by('[data-ready-terminal]').textContent = `Terminal ${terminalId}`;

      const emptyTotals = () => ({ subtotal:0, itemDiscount:0, orderDiscount:0, lineTax:0, manualTax:0, tax:0, net:0, paid:0, remaining:0, change:0, creditUsed:0, otherPaid:0 });
      const readyPayload = () => ({ type:'display-state', displayState:'Ready', event:'SaleReset', status:'Ready for next customer', itemCount:0, customer:{}, payment:{}, totals:emptyTotals(), items:[], updatedAt:new Date().toISOString() });

      async function startDisplayHub() {
        if (!('WebSocket' in window) || displaySocket) return;
        try {
          const response = await fetch('/pos-display-hub/negotiate?negotiateVersion=1', { method:'POST', credentials:'same-origin' });
          const negotiate = await response.json();
          const token = encodeURIComponent(negotiate.connectionToken || negotiate.connectionId);
          const wsProtocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
          displaySocket = new WebSocket(`${wsProtocol}//${location.host}/pos-display-hub?id=${token}`);
          displaySocket.onopen = () => {
            displaySocket.send('{"protocol":"json","version":1}\u001e');
            sendInvocation('JoinDisplay', [terminalId]);
          };
          displaySocket.onmessage = event => {
            String(event.data).split('\u001e').filter(Boolean).forEach(frame => {
              const payload = JSON.parse(frame);
              if (payload.type === 1 && payload.target === 'DisplayUpdated') render(payload.arguments?.[0]);
            });
          };
          displaySocket.onclose = () => { displaySocket = null; setTimeout(startDisplayHub, 1500); };
        } catch {
          displaySocket = null;
          setTimeout(startDisplayHub, 2500);
        }
      }

      function sendInvocation(target, args) {
        if (!displaySocket || displaySocket.readyState !== WebSocket.OPEN) return;
        displaySocket.send(JSON.stringify({ type:1, invocationId:String(++invocationId), target, arguments:args }) + '\u001e');
      }

      function setStatus(text, state) {
        const status = by('[data-display-status]');
        status.textContent = text || 'Scanning Items';
        status.className = `status ${state || ''}`.trim();
      }

      function setMessage(text, state) {
        const message = by('[data-result-message]');
        message.textContent = text || 'Welcome. Your purchase details will appear here.';
        message.className = `message-bar ${state || ''}`.trim();
      }

      function normalizeState(message) {
        const raw = String(message?.displayState || message?.state || message?.status || '').replace(/\s+/g, '').toLowerCase();
        if (message?.event === 'SaleReset' || raw === 'reset' || raw === 'ready') return 'Ready';
        if (message?.event === 'CreditRepaymentCompleted' || raw === 'repaymentsuccess') return 'RepaymentSuccess';
        if (message?.event === 'CreditRepaymentFailed' || raw === 'repaymentfailed') return 'RepaymentFailed';
        if (message?.event === 'CreditRepaymentProcessing' || raw === 'processingrepayment') return 'ProcessingRepayment';
        if (message?.event === 'CreditRepaymentStarted' || raw === 'creditrepaymentstarted') return 'CreditRepaymentStarted';
        if (message?.event === 'CreditCustomerSelected' || raw === 'customerselected') return 'CustomerSelected';
        if (message?.event === 'CreditRepaymentAmountUpdated' || raw === 'amountentered') return 'AmountEntered';
        if (message?.event === 'SaleCompleted' || raw === 'paymentsuccess' || (message?.type === 'payment-result' && message?.status === 'success')) return 'PaymentSuccess';
        if (message?.event === 'SaleFailed' || raw === 'paymentfailed' || raw === 'fail' || (message?.type === 'payment-result' && message?.status === 'fail')) return 'PaymentFailed';
        if (message?.event === 'PaymentProcessing' || raw === 'processingpayment' || raw === 'paymentprocessing') return 'ProcessingPayment';
        if (raw === 'waitingforpayment' || raw === 'waitingforpayment.') return 'WaitingForPayment';
        if (message?.event === 'SaleStarted' || message?.event === 'CartUpdated' || raw === 'scanning' || raw === 'scanningitems' || raw === 'paymentready') return 'Scanning';
        return (message?.items || []).length ? 'Scanning' : 'Ready';
      }

      function setShellState(state) {
        const shell = by('.display-shell');
        shell.classList.toggle('is-ready', state === 'Ready');
        shell.classList.toggle('is-success', state === 'PaymentSuccess');
        shell.classList.toggle('is-repayment', ['CreditRepaymentStarted', 'CustomerSelected', 'AmountEntered', 'ProcessingRepayment', 'RepaymentFailed'].includes(state));
      }

      function renderReady() {
        if (successResetTimer) {
          clearTimeout(successResetTimer);
          successResetTimer = null;
        }
        setShellState('Ready');
        setStatus('Ready for next customer');
        setMessage('Welcome. Your purchase details will appear here.');
        by('[data-sale-no]').textContent = '-';
        by('[data-item-count]').textContent = '0 items';
        by('[data-updated-at]').textContent = '-';
        by('[data-total]').textContent = thb(0);
        by('[data-customer-name]').textContent = 'Walk-in Customer';
        by('[data-payment-method]').textContent = '-';
        by('[data-paid]').textContent = thb(0);
        by('[data-change]').textContent = thb(0);
        by('[data-remaining]').textContent = thb(0);
        by('[data-items]').innerHTML = '<div class="empty">Waiting for scanned items</div>';
        by('[data-visual]').innerHTML = '<div class="result-icon idle">POS</div>';
        try { localStorage.setItem(storageKey, JSON.stringify(readyPayload())); } catch {}
        window.applyCustomerDisplayLanguage?.();
      }

      function renderSuccess(message, totals, payment) {
        setShellState('PaymentSuccess');
        setStatus('Payment Successful', 'success');
        const isRepayment = normalizeState(message) === 'RepaymentSuccess';
        setMessage(message.message || (isRepayment ? 'Thank you for your payment' : 'Thank you for your purchase. Payment successful.'), 'success');
        by('.success-state .state-title').textContent = isRepayment ? 'Thank you for your payment' : 'Thank you for your purchase';
        by('.success-state .state-subtitle').textContent = isRepayment ? 'Credit repayment completed successfully' : 'Payment completed successfully';
        by('.success-meta span').textContent = isRepayment ? 'Repayment receipt number' : 'Invoice No / Sale No';
        by('[data-success-sale-no]').textContent = message.receiptNo || message.invoiceNo || message.saleNo || '-';
        by('[data-success-total]').textContent = thb(totals.net || message.amount || 0);
        by('[data-success-method]').textContent = payment.method || '-';
        by('[data-success-change]').textContent = thb(payment.changeAmount || totals.change || 0);
        by('[data-success-change-row]').style.display = Number(payment.changeAmount || totals.change || 0) > 0 ? 'flex' : 'none';
        window.applyCustomerDisplayLanguage?.();
        if (successResetTimer) clearTimeout(successResetTimer);
        successResetTimer = setTimeout(() => render(readyPayload()), Number(message.resetDelayMs || 5000));
      }

      function renderRepayment(message, state) {
        const customer = message.customer || {};
        const summary = message.creditSummary || {};
        const repayment = message.repayment || {};
        const footer = by('[data-repayment-message]');
        const fmtDate = value => value ? new Date(value).toLocaleDateString() : '-';
        setShellState(state);
        by('[data-repayment-title]').textContent = 'Credit Repayment';
        by('[data-repayment-subtitle]').textContent = state === 'CreditRepaymentStarted' ? 'Please wait while we check your account.' : state === 'ProcessingRepayment' ? 'Processing repayment...' : state === 'RepaymentFailed' ? 'Repayment failed' : 'Please confirm your repayment amount with the cashier.';
        by('[data-repayment-status]').textContent = state === 'ProcessingRepayment' ? 'Processing' : state === 'RepaymentFailed' ? 'Failed' : 'Repayment';
        by('[data-repay-customer-name]').textContent = customer.customerName || customer.name || '-';
        by('[data-repay-member-code]').textContent = customer.memberCode || customer.customerCode || '-';
        by('[data-repay-phone]').textContent = customer.phoneNumber || '-';
        by('[data-repay-level]').textContent = customer.memberLevel || '-';
        by('[data-repay-type]').textContent = customer.customerType || '-';
        by('[data-repay-available]').textContent = thb(customer.availableCreditLimit || customer.availableCredit || 0);
        by('[data-repay-outstanding]').textContent = thb(repayment.outstandingBalance || summary.totalOutstandingBalance || customer.outstandingBalance || 0);
        by('[data-repay-amount-large]').textContent = thb(repayment.repaymentAmount || 0);
        by('[data-repay-before]').textContent = thb(repayment.outstandingBalance || summary.totalOutstandingBalance || customer.outstandingBalance || 0);
        by('[data-repay-remaining]').textContent = thb(repayment.remainingBalance || 0);
        by('[data-repay-method]').textContent = repayment.paymentMethod || '-';
        by('[data-repay-cash]').textContent = thb(repayment.cashReceived || 0);
        by('[data-repay-change]').textContent = thb(repayment.changeAmount || 0);
        by('[data-repay-overdue]').textContent = thb(summary.overdueAmount || 0);
        by('[data-repay-unpaid]').textContent = String(summary.unpaidInvoiceCount || 0);
        by('[data-repay-due]').textContent = fmtDate(summary.dueDate);
        by('[data-repay-last]').textContent = fmtDate(summary.lastRepaymentDate);
        footer.textContent = message.errorMessage || message.warning || message.message || 'Please confirm your repayment amount with the cashier.';
        footer.className = `repayment-footer ${state === 'RepaymentFailed' ? 'fail' : message.warning || state === 'ProcessingRepayment' ? 'warning' : ''}`.trim();
        window.applyCustomerDisplayLanguage?.();
      }

      function renderVisual(message, totals) {
        const visual = by('[data-visual]');
        const isResult = message?.type === 'payment-result';
        const isSuccess = message?.status === 'success';
        if (isResult) {
          visual.innerHTML = `<div class="result-icon ${isSuccess ? 'success' : 'fail'}">${isSuccess ? '&#10003;' : '&#9888;'}</div>`;
          return;
        }
        if (message?.type === 'promptpay-qr' && (message.svg || message.svgDataUri)) {
          visual.innerHTML = message.svg || `<img alt="PromptPay QR Code" src="${message.svgDataUri}">`;
          return;
        }
        visual.innerHTML = `<div class="result-icon idle">${totals.net > 0 ? thb(totals.net) : 'POS'}</div>`;
      }

      function render(message) {
        if (!message) return;

        const state = normalizeState(message);
        const totals = message.totals || {};
        const items = message.items || [];
        const customer = message.customer || {};
        const payment = message.payment || {};
        const isResult = message.type === 'payment-result';
        const isSuccess = message.status === 'success';
        const isFail = message.status === 'fail';
        const isQr = message.type === 'promptpay-qr';
        const displayStatus = state === 'ProcessingPayment' ? 'Processing payment...' : isResult ? (isSuccess ? 'Payment Successful' : 'Payment Failed') : isQr ? 'Waiting for Payment' : (message.status || 'Scanning Items');

        if (state === 'Ready') {
          renderReady();
          return;
        }
        if (successResetTimer) {
          clearTimeout(successResetTimer);
          successResetTimer = null;
        }
        if (state === 'RepaymentSuccess') {
          const repayment = message.repayment || {};
          renderSuccess({
            ...message,
            amount: repayment.repaymentAmount,
            totals: { net: repayment.repaymentAmount, change: repayment.changeAmount }
          }, { net: repayment.repaymentAmount, change: repayment.changeAmount }, { method: repayment.paymentMethod, changeAmount: repayment.changeAmount });
          return;
        }
        if (['CreditRepaymentStarted', 'CustomerSelected', 'AmountEntered', 'ProcessingRepayment', 'RepaymentFailed'].includes(state)) {
          renderRepayment(message, state);
          return;
        }
        if (state === 'PaymentSuccess') {
          renderSuccess(message, totals, payment);
          return;
        }

        setShellState('');
        setStatus(displayStatus, isSuccess ? 'success' : isFail ? 'fail' : (isQr || state === 'ProcessingPayment') ? 'warning' : '');
        by('[data-sale-no]').textContent = message.saleNo ? `Sale ${message.saleNo}` : '-';
        by('[data-item-count]').textContent = `${message.itemCount || 0} item${message.itemCount === 1 ? '' : 's'}`;
        by('[data-updated-at]').textContent = message.updatedAt ? new Date(message.updatedAt).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' }) : '-';

        by('[data-total]').textContent = thb(totals.net || message.amount);

        by('[data-customer-name]').textContent = customer.name || 'Walk-in Customer';

        by('[data-payment-method]').textContent = payment.method || '-';
        by('[data-paid]').textContent = thb(payment.paidAmount || totals.paid);
        by('[data-change]').textContent = thb(payment.changeAmount || totals.change);
        by('[data-remaining]').textContent = thb(totals.remaining);

        by('[data-items]').innerHTML = items.length
          ? items.map(item => `<div class="item-row"><div class="product-cell"><div class="product-image">${item.imageUrl ? `<img alt="" src="${esc(item.imageUrl)}">` : 'POS'}</div><div><div class="item-name">${esc(item.name)}</div>${item.code ? `<div class="item-code">${esc(item.code)}</div>` : ''}</div></div><div class="num">${money(item.quantity)}</div><div class="num">${thb(item.unitPrice)}</div><div class="num">${thb(item.discount)}</div><div class="num"><strong>${thb(item.lineTotal)}</strong></div></div>`).join('')
          : '<div class="empty">Waiting for scanned items</div>';

        renderVisual(message, totals);

        if (state === 'ProcessingPayment') {
          setMessage('Processing payment...', 'warning');
        } else if (isResult) {
          setMessage(message.message || (isSuccess ? 'Thank you for your purchase. Payment successful.' : 'Payment failed.'), isSuccess ? 'success' : 'fail');
        } else if (isQr) {
          setMessage('Scan the QR code to pay with mobile banking.', 'warning');
        } else if ((totals.remaining || 0) > 0) {
          setMessage('Waiting for payment.', 'warning');
        } else if ((totals.net || 0) > 0) {
          setMessage('Ready to complete payment.', 'success');
        } else {
          setMessage('Welcome. Your purchase details will appear here.');
        }
        window.applyCustomerDisplayLanguage?.();
      }

      try {
        const saved = localStorage.getItem(storageKey);
        if (saved) render(JSON.parse(saved));
        else renderReady();
      } catch { renderReady(); }

      if ('BroadcastChannel' in window) {
        const channel = new BroadcastChannel(channelName);
        channel.onmessage = event => render(event.data);
      }

      window.addEventListener('storage', event => {
        if (event.key !== storageKey) return;
        try { if (event.newValue) render(JSON.parse(event.newValue)); } catch {}
      });

      startDisplayHub();
    })();
    </script>
</body>
</html>
