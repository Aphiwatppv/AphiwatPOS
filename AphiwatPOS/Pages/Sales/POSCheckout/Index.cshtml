</style>

@section Scripts {
<script>
(() => {
  const root = document.querySelector('[data-pos-root]');
  if (!root) return;
  const products = [...document.querySelectorAll('[data-product-card]')];
  let cart = @Html.Raw(JsonSerializer.Serialize(heldItems, new JsonSerializerOptions(JsonSerializerDefaults.Web)));
  let payments = [];
  let lastReceiptSnapshot = null;
  let activeMethod = document.querySelector('[data-payment-method].active') || document.querySelector('[data-payment-method]');
  let customerDisplayOpened = false;
  const money = v => Number(v || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const round4 = v => Math.round((Number(v || 0) + Number.EPSILON) * 10000) / 10000;
  const by = s => document.querySelector(s);
  const applyAppLanguage = () => window.AphiwatPOSLanguage?.apply(root);
  const lastSaleNo = @Html.Raw(JsonSerializer.Serialize(lastSaleNo));
  const cashierName = @Html.Raw(JsonSerializer.Serialize(cashierName));
  const initialBarcode = @Html.Raw(JsonSerializer.Serialize(Model.Barcode));
  const promptPayQrUrl = @Html.Raw(JsonSerializer.Serialize(promptPayQrUrl));
  const customerDisplayUrl = @Html.Raw(JsonSerializer.Serialize(customerDisplayUrl));
  const serverSaleResult = @Html.Raw(string.IsNullOrWhiteSpace(lastSaleResultJson) ? "null" : lastSaleResultJson);
  const customerDisplayChannelName = 'aphiwatpos-customer-display';
  const customerDisplayStorageKey = 'aphiwatpos:customer-display';
  const customerDisplayChannel = 'BroadcastChannel' in window ? new BroadcastChannel(customerDisplayChannelName) : null;
  const terminalStorageKey = 'aphiwatpos:terminal-id';
  const terminalId = (() => {
    try {
      let id = localStorage.getItem(terminalStorageKey);
      if (!id) {
        id = (crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random().toString(16).slice(2)}`);
        localStorage.setItem(terminalStorageKey, id);
      }
      return id;
    } catch {
      return 'default';
    }
  })();
  let displaySocket = null;
  let displayInvocationId = 0;
  let suppressCustomerDisplayPublish = false;
  const cartPanel = by('[data-cart-panel]');
  const serverErrorMessage = @Html.Raw(JsonSerializer.Serialize(serverErrorMessage));
  function showPaymentToast(kind, message, detail = '') {
    let container = document.querySelector('[data-payment-toast-container]');
    if (!container) {
      container = document.createElement('div');
      container.dataset.paymentToastContainer = 'true';
      container.className = 'toast-container position-fixed top-0 end-0 p-3';
      container.style.zIndex = '3000';
      document.body.appendChild(container);
    }
    const isSuccess = kind === 'success';
    const toast = document.createElement('div');
    toast.className = `toast show align-items-start border-0 text-bg-${isSuccess ? 'success' : 'danger'}`;
    toast.role = 'alert';
    toast.innerHTML = `<div class="d-flex"><div class="toast-body"><strong>${message}</strong>${detail ? `<div>${detail}</div>` : ''}</div><button class="btn-close btn-close-white me-2 mt-2" data-bs-dismiss="toast" type="button"></button></div>`;
    container.appendChild(toast);
    applyAppLanguage();
    setTimeout(() => toast.remove(), isSuccess ? 4500 : 7000);
  }
  async function postDrawerAction(url, formData) {
    const token = document.querySelector('[name="__RequestVerificationToken"]')?.value;
    const response = await fetch(url, {
      method: 'POST',
      body: formData,
      credentials: 'same-origin',
      headers: token ? { RequestVerificationToken: token, Accept: 'application/json' } : { Accept: 'application/json' }
    });
    const result = await response.json().catch(() => ({ isSuccess:false, message:'Cash drawer action failed.', errorMessage:'Server returned an invalid response.' }));
    if (!response.ok || !result.isSuccess) throw new Error(result.errorMessage || result.message || 'Cash drawer action failed.');
    return result;
  }
  async function openDrawerManually() {
    const reason = by('[data-manual-drawer-reason]')?.value || '';
    if (!reason) {
      showPaymentToast('error', 'Reason is required.', 'Select why the drawer is being opened.');
      return;
    }
    const button = by('[data-open-drawer-confirm]');
    const original = button.innerHTML;
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Opening...';
    try {
      const formData = new FormData();
      formData.append('reason', reason);
      const result = await postDrawerAction(by('[data-drawer-open-url]').dataset.drawerOpenUrl, formData);
      bootstrap.Modal.getOrCreateInstance(by('#manualDrawerModal')).hide();
      showPaymentToast('success', result.message || 'Cash drawer opened successfully.');
    } catch (error) {
      showPaymentToast('error', 'Cash drawer could not be opened.', error.message);
    } finally {
      button.disabled = false;
      button.innerHTML = original;
    }
  }
  async function testDrawer() {
    const button = by('[data-test-drawer]');
    const original = button.innerHTML;
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Testing...';
    try {
      const result = await postDrawerAction(by('[data-drawer-test-url]').dataset.drawerTestUrl, new FormData());
      showPaymentToast('success', result.message || 'Cash drawer test completed.');
    } catch (error) {
      showPaymentToast('error', 'Cash drawer test failed.', error.message);
    } finally {
      button.disabled = false;
      button.innerHTML = original;
    }
  }
  function lineTax(item) {
    if (item.taxRate === null || item.taxRate === undefined || Number.isNaN(Number(item.taxRate))) return Number(item.taxAmount || 0);
    const taxable = Math.max(0, (Number(item.quantity || 0) * Number(item.unitPrice || 0)) - Number(item.itemDiscountAmount || 0));
    const rate = Number(item.taxRate || 0);
    return rate <= 0 ? 0 : round4(taxable * (rate / (100 + rate)));
  }
  function syncLineTaxes() {
    cart.forEach(item => { item.taxAmount = lineTax(item); });
  }
  document.querySelectorAll('[data-payment-method]').forEach(btn => btn.addEventListener('click', () => {
    ensureCustomerDisplayOpen();
    document.querySelectorAll('[data-payment-method]').forEach(x => x.classList.remove('active'));
    btn.classList.add('active');
    activeMethod = btn;
    by('[data-payment-ref]').toggleAttribute('required', btn.dataset.requireRef === 'true');
    clearPromptPay();
    if (btn.dataset.isCredit === 'true') applyCustomerCredit();
    totals();
  }));
  function clearPromptPay() {
    by('[data-promptpay-preview]')?.classList.add('d-none');
    by('[data-promptpay-error]')?.classList.add('d-none');
  }
  function openCustomerDisplay(syncCurrent = true) {
    if (!customerDisplayUrl) return;
    const separator = customerDisplayUrl.includes('?') ? '&' : '?';
    window.open(`${customerDisplayUrl}${separator}terminalId=${encodeURIComponent(terminalId)}`, 'aphiwatposCustomerDisplay', 'popup=yes,width=1100,height=820');
    customerDisplayOpened = true;
    if (syncCurrent) {
      setTimeout(() => publishLiveDisplay(), 500);
      setTimeout(() => publishLiveDisplay(), 1500);
    }
  }
  function ensureCustomerDisplayOpen(syncCurrent = true) {
    if (customerDisplayOpened) {
      if (syncCurrent) publishLiveDisplay();
      return;
    }

    openCustomerDisplay(syncCurrent);
  }
  async function startDisplayHub() {
    if (!('WebSocket' in window) || displaySocket) return;
    try {
      const response = await fetch('/pos-display-hub/negotiate?negotiateVersion=1', { method:'POST', credentials:'same-origin' });
      const negotiate = await response.json();
      const token = encodeURIComponent(negotiate.connectionToken || negotiate.connectionId);
      const wsProtocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
      displaySocket = new WebSocket(`${wsProtocol}//${location.host}/pos-display-hub?id=${token}`);
      displaySocket.onopen = () => {
        displaySocket.send('{"protocol":"json","version":1}\u001e');
        sendDisplayInvocation('JoinDisplay', [terminalId]);
        publishLiveDisplay('Scanning Items');
      };
      displaySocket.onclose = () => { displaySocket = null; setTimeout(startDisplayHub, 1500); };
    } catch {
      displaySocket = null;
    }
  }
  function sendDisplayInvocation(target, args) {
    if (!displaySocket || displaySocket.readyState !== WebSocket.OPEN) return;
    displaySocket.send(JSON.stringify({ type:1, invocationId:String(++displayInvocationId), target, arguments:args }) + '\u001e');
  }
  function publishCustomerDisplay(message) {
    try {
      if (message) localStorage.setItem(customerDisplayStorageKey, JSON.stringify(message));
      else localStorage.removeItem(customerDisplayStorageKey);
    } catch {}
    customerDisplayChannel?.postMessage(message);
    if (message) sendDisplayInvocation('SendDisplayUpdate', [terminalId, message]);
  }
  function publishCustomerDisplayReliable(message) {
    publishCustomerDisplay(message);
    setTimeout(() => publishCustomerDisplay(message), 500);
    setTimeout(() => publishCustomerDisplay(message), 1500);
    setTimeout(() => publishCustomerDisplay(message), 3000);
  }
  function readyDisplayPayload() {
    return { type:'display-state', displayState:'Ready', event:'SaleReset', status:'Ready for next customer', itemCount:0, customer:{}, payment:{}, totals:{ subtotal:0, itemDiscount:0, orderDiscount:0, lineTax:0, manualTax:0, tax:0, net:0, paid:0, remaining:0, change:0, creditUsed:0, otherPaid:0 }, items:[], updatedAt:new Date().toISOString() };
  }
  function scheduleCustomerDisplayReset() {
    setTimeout(() => publishCustomerDisplay(readyDisplayPayload()), 5000);
  }
  function resetCashierSaleForNextCustomer() {
    suppressCustomerDisplayPublish = true;
    try {
      cart = [];
      payments = [];
      by('[data-payment-amount]').value = '';
      by('[data-payment-ref]').value = '';
      by('[data-order-discount]').value = 0;
      by('[data-tax-amount]').value = 0;
      by('[data-customer-search]').value = '';
      by('[data-customer-id]').value = '';
      by('[data-member-no]').checked = true;
      by('[data-member-yes]').checked = false;
      by('[data-member-lookup]').classList.add('d-none');
      by('[data-customer-id]').classList.add('d-none');
      by('[data-selected-member]').classList.add('d-none');
      by('[data-credit-panel]').classList.add('d-none');
      by('[data-credit-note]')?.classList.add('d-none');
      clearPromptPay();
      document.querySelectorAll('[data-payment-method]').forEach(x => x.classList.remove('active'));
      activeMethod = document.querySelector('[data-payment-method][data-is-cash="true"]') || document.querySelector('[data-payment-method]:not([data-is-credit="true"])') || document.querySelector('[data-payment-method]');
      activeMethod?.classList.add('active');
      syncCustomerCredit();
      render();
    } finally {
      suppressCustomerDisplayPublish = false;
    }
    by('[data-barcode-input]')?.focus();
  }
  function customerDisplaySnapshot(t) {
    const customer = selectedCustomerOption();
    const creditInfo = selectedCreditInfo();
    const creditRemaining = Math.max(0, (creditInfo.availableCredit || 0) - (t.creditUsed || 0));
    return {
      itemCount: cart.reduce((sum, item) => sum + Number(item.quantity || 0), 0),
      customer: customer?.value ? { name: customer.dataset.name || 'Customer', memberLevel: customer.dataset.level || '', availableCredit: creditInfo.availableCredit || 0, creditUsed: t.creditUsed || 0, remainingCredit: creditRemaining } : { name: 'Walk-in Customer' },
      payment: {
        method: activeMethod?.innerText.trim() || '-',
        paidAmount: t.paid,
        changeAmount: t.change,
        creditUsed: t.creditUsed,
        remainingCredit: creditRemaining
      },
      totals: {
        subtotal: t.subtotal,
        itemDiscount: t.itemDiscount,
        orderDiscount: t.orderDiscount,
        lineTax: t.lineTax,
        manualTax: t.manualTax,
        tax: t.tax,
        net: t.net,
        paid: t.paid,
        remaining: t.remaining,
        change: t.change,
        creditUsed: t.creditUsed,
        otherPaid: t.otherPaid
      },
      items: cart.map(item => ({
        name: item.productName || 'Item',
        imageUrl: item.productImageUrl || '',
        code: item.productCode || '',
        quantity: Number(item.quantity || 0),
        unitPrice: Number(item.unitPrice || 0),
        discount: Number(item.itemDiscountAmount || 0),
        lineTotal: (Number(item.quantity || 0) * Number(item.unitPrice || 0)) - Number(item.itemDiscountAmount || 0)
      }))
    };
  }
  function publishLiveDisplay(statusText) {
    if (!cart.length) {
      publishCustomerDisplay(readyDisplayPayload());
      return;
    }
    const t = totals(false);
    publishCustomerDisplay({ type:'sale-update', event:statusText ? 'SaleStarted' : 'CartUpdated', displayState:t.paid > 0 ? 'WaitingForPayment' : 'Scanning', status:statusText || (t.paid > 0 ? 'Waiting for Payment' : 'Scanning Items'), ...customerDisplaySnapshot(t), updatedAt:new Date().toISOString() });
  }
  async function generatePromptPayQr() {
    const t = totals();
    const amount = Number(by('[data-payment-amount]').value || t.remaining || t.net || 0);
