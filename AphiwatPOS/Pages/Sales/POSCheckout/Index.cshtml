  by('[data-print-invoice]').addEventListener('click', () => printDocument('invoice'));
  by('[data-result-print-invoice]').addEventListener('click', () => printDocument('invoice'));
  by('[data-open-drawer-confirm]')?.addEventListener('click', openDrawerManually);
  by('[data-test-drawer]')?.addEventListener('click', testDrawer);
  startDisplayHub();
  syncCustomerCredit();
  render();
  by('[data-barcode-input]')?.focus();
  if (initialBarcode) scanBarcode(initialBarcode);
  if (lastSaleNo) {
    const rawSnapshot = sessionStorage.getItem('aphiwatpos:last-sale-print');
    let resultSnapshot = serverSaleResult;
    if (rawSnapshot) {
      try { resultSnapshot = JSON.parse(rawSnapshot); } catch {}
    }
    if (resultSnapshot) {
      try {
        const snapshot = resultSnapshot;
        snapshot.saleNo = lastSaleNo;
        snapshot.receiptNo = lastSaleNo;
        snapshot.invoiceNo = lastSaleNo;
        renderReceiptPreview(snapshot);
        showSaleResult('success', `Sale ${lastSaleNo} completed successfully.`, snapshot.totals, lastSaleNo);
        by('[data-result-customer]').textContent = snapshot.customer?.name || 'Walk-in Customer';
        by('[data-result-payment-method]').textContent = (snapshot.payments || []).map(p => p.name || 'Payment').join(', ') || '-';
        by('[data-result-items]').textContent = String((snapshot.items || []).reduce((sum, item) => sum + Number(item.quantity || 0), 0));
        publishCustomerDisplay(paymentResultFromSnapshot('success', `Sale ${lastSaleNo} completed successfully.`, snapshot, lastSaleNo));
      } finally {
        sessionStorage.removeItem('aphiwatpos:last-sale-print');
      }
    } else {
      const t = totals(false);
      showSaleResult('success', `Sale ${lastSaleNo} completed successfully.`, t, lastSaleNo);
      publishPaymentResult('success', `Sale ${lastSaleNo} completed successfully.`, t, lastSaleNo);
    }
  }
  if (serverErrorMessage) {
    const rawSnapshot = sessionStorage.getItem('aphiwatpos:last-sale-print');
    let totalsSnapshot = totals();
    let handledSnapshot = false;
    if (rawSnapshot) {
      try {
        const snapshot = JSON.parse(rawSnapshot);
        totalsSnapshot = snapshot.totals || totalsSnapshot;
        showSaleResult('fail', serverErrorMessage, totalsSnapshot);
        by('[data-result-customer]').textContent = snapshot.customer?.name || 'Walk-in Customer';
        by('[data-result-payment-method]').textContent = (snapshot.payments || []).map(p => p.name || 'Payment').join(', ') || '-';
        by('[data-result-items]').textContent = String((snapshot.items || []).reduce((sum, item) => sum + Number(item.quantity || 0), 0));
        publishCustomerDisplay(paymentResultFromSnapshot('fail', serverErrorMessage, snapshot));
        handledSnapshot = true;
      } catch {}
      sessionStorage.removeItem('aphiwatpos:last-sale-print');
    }
    if (!handledSnapshot) failPayment(serverErrorMessage, totalsSnapshot);
  }
})();
</script>
}

