    <script>
    (() => {
      const selectedBill = @Html.Raw(JsonSerializer.Serialize(selectedDisplayPayload, jsonOptions));
      const receiptBill = @Html.Raw(JsonSerializer.Serialize(receiptDisplayPayload, jsonOptions));
      const displayChannelName = 'aphiwatpos-customer-display';
      const displayStorageKey = 'aphiwatpos:customer-display';
      const terminalStorageKey = 'aphiwatpos:terminal-id';
      const customerDisplayUrl = '@Url.Page("/Sales/CustomerDisplay/Index")';
      const by = selector => document.querySelector(selector);
      const terminalId = (() => {
        try {
          let id = localStorage.getItem(terminalStorageKey);
          if (!id) {
            id = (crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random().toString(16).slice(2)}`);
            localStorage.setItem(terminalStorageKey, id);
          }
          return id;
        } catch { return 'default'; }
      })();
      const channel = 'BroadcastChannel' in window ? new BroadcastChannel(displayChannelName) : null;
      let displaySocket = null;
      let displayInvocationId = 0;

      function checkedPaymentMethod() {
        return document.querySelector('input[name="Input.PaymentMethod"]:checked')?.value || 'Cash';
      }

      function paymentMethodText(value) {
        return value === 'Transfer' ? 'Transfer' : 'Cash';
      }

      function creditCheckbox() {
        return document.querySelector('input[name="Input.PayCustomerCredit"]');
      }

      function currentPayload(state = 'RubberBillSelected', event = 'RubberBillSelected', message = 'Please confirm the rubber bill amount before payment.') {
        const bill = selectedBill || receiptBill || {};
        const fullAmount = Number(bill.totalAmount || bill.remainingAmount || 0);
        const outstandingCredit = Number(bill.outstandingCreditAmount || 0);
        const creditDeducted = creditCheckbox()?.checked ? Math.min(fullAmount, Math.max(0, outstandingCredit)) : Number(bill.creditDeductedAmount || 0);
        const amountToSeller = Math.max(0, fullAmount - creditDeducted);
        return {
          type:'rubber-pay-bill',
          terminalId,
          event,
          displayState:state,
          title:'Rubber Bill Payment',
          message,
          receiptNo: bill.receiptNo || '',
          rubberBill: bill,
          payment:{
            method: paymentMethodText(checkedPaymentMethod() || bill.paymentMethod),
            paidAmount: amountToSeller,
            amountToSeller,
            creditDeductedAmount: creditDeducted
          },
          updatedAt:new Date().toISOString()
        };
      }

      function publishDisplay(payload) {
        if (!payload) return;
        try { localStorage.setItem(displayStorageKey, JSON.stringify(payload)); } catch {}
        channel?.postMessage(payload);
        if (displaySocket?.readyState === WebSocket.OPEN) {
          displaySocket.send(JSON.stringify({ type:1, invocationId:String(++displayInvocationId), target:'SendDisplayUpdate', arguments:[terminalId, payload] }) + '\u001e');
        }
      }

      async function startDisplayHub() {
        if (!('WebSocket' in window) || displaySocket) return;
        try {
          const response = await fetch('/pos-display-hub/negotiate?negotiateVersion=1', { method:'POST', credentials:'same-origin' });
          const negotiate = await response.json();
          const token = encodeURIComponent(negotiate.connectionToken || negotiate.connectionId);
          const wsProtocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
          displaySocket = new WebSocket(`${wsProtocol}//${location.host}/pos-display-hub?id=${token}`);
          displaySocket.onopen = () => {
            displaySocket.send('{"protocol":"json","version":1}\u001e');
            displaySocket.send(JSON.stringify({ type:1, invocationId:String(++displayInvocationId), target:'JoinDisplay', arguments:[terminalId] }) + '\u001e');
            publishDisplay(receiptBill
              ? currentPayload('RubberPaymentSuccess', 'RubberPaymentCompleted', 'Rubber bill payment completed successfully.')
              : selectedBill ? currentPayload() : null);
          };
          displaySocket.onclose = () => { displaySocket = null; setTimeout(startDisplayHub, 1500); };
        } catch {
          displaySocket = null;
        }
      }

      function encodeDisplayPayload(payload) {
        if (!payload) return '';
        try {
          return btoa(unescape(encodeURIComponent(JSON.stringify(payload))));
        } catch { return ''; }
      }

      function openCustomerDisplay() {
        const payload = receiptBill
          ? currentPayload('RubberPaymentSuccess', 'RubberPaymentCompleted', 'Rubber bill payment completed successfully.')
          : selectedBill ? currentPayload() : null;
        const separator = customerDisplayUrl.includes('?') ? '&' : '?';
        const language = localStorage.getItem('aphiwatpos.language') === 'th' ? 'th' : 'en';
        const encodedPayload = encodeDisplayPayload(payload);
        const url = `${customerDisplayUrl}${separator}terminalId=${encodeURIComponent(terminalId)}&lang=${encodeURIComponent(language)}${encodedPayload ? `&payload=${encodeURIComponent(encodedPayload)}` : ''}`;
        window.open(url, 'aphiwatposCustomerDisplay', 'popup=yes,width=1200,height=820');
        [150, 600, 1200, 2500, 4500].forEach(delay => setTimeout(() => publishDisplay(payload), delay));
      }

      by('[data-open-rubber-display]')?.addEventListener('click', openCustomerDisplay);
      document.querySelectorAll('input[name="Input.PaymentMethod"]').forEach(input => input.addEventListener('change', () => {
        publishDisplay(currentPayload('RubberBillSelected', 'RubberPaymentMethodChanged'));
      }));
      creditCheckbox()?.addEventListener('change', () => publishDisplay(currentPayload('RubberBillSelected', 'RubberPaymentMethodChanged')));
      by('#confirmRubberPayment')?.addEventListener('show.bs.modal', () => {
        publishDisplay(currentPayload('RubberPaymentConfirming', 'RubberPaymentConfirming', 'Please confirm this full payment.'));
      });
      document.querySelector('.rubber-payment-form')?.addEventListener('submit', () => {
        publishDisplay(currentPayload('RubberPaymentProcessing', 'RubberPaymentProcessing', 'Saving payment and preparing receipt...'));
      });
      if (receiptBill) {
        publishDisplay(currentPayload('RubberPaymentSuccess', 'RubberPaymentCompleted', 'Rubber bill payment completed successfully.'));
      } else if (selectedBill) {
        publishDisplay(currentPayload());
      }
      startDisplayHub();
    })();
    </script>
    @if (receipt is not null && Model.PromptPrint)
    {
        <script>
            (() => {
                const prompt = document.getElementById('printReceiptPrompt');
                if (prompt && window.bootstrap) {
                    window.addEventListener('load', () => new bootstrap.Modal(prompt).show());
                }
            })();
        </script>
    }
}

@functions {
    string PaymentText(string? method) => method == "Transfer" ? "Bank transfer" : "Cash";
}

