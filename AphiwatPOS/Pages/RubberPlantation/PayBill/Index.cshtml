@page
@model AphiwatPOS.Pages.RubberPlantation.PayBill.IndexModel
@using AphiwatPOS.Pages.Customer
@using System.Text.Json
@{
    ViewData["Title"] = "Pay Rubber Bills";
    ViewData["Subtitle"] = "Select a rubber purchase bill, record payment, and print the receipt.";
    ViewData["TitleI18nKey"] = "rubberPay.title";
    ViewData["SubtitleI18nKey"] = "rubberPay.subtitle";
    var selected = Model.SelectedPurchase;
    var receipt = Model.Receipt;
    var fullPaymentAmount = selected?.TotalAmount ?? 0;
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    object? selectedDisplayPayload = selected is null ? null : new
    {
        rubberPurchaseHeaderId = selected.RubberPurchaseHeaderId,
        sellerName = selected.CustomerName,
        sellerCode = selected.CustomerCode,
        phoneNumber = selected.PhoneNumber,
        purchaseDate = CustomerPageHelpers.Date(selected.TransactionDate),
        locationName = selected.RubberAuctionLocationName ?? selected.LocationName,
        weightKg = selected.WeightKg,
        pricePerKg = selected.PricePerKgSnapshot ?? 0,
        deductionPercent = selected.PercentageSnapshot ?? 0,
        totalAmount = selected.TotalAmount ?? 0,
        remainingAmount = AphiwatPOS.Pages.RubberPlantation.PayBill.IndexModel.GetRemainingAmount(selected),
        outstandingCreditAmount = Model.SelectedCreditOutstandingAmount
    };
    object? receiptDisplayPayload = receipt is null ? null : new
    {
        rubberPurchaseHeaderId = receipt.RubberPurchaseHeaderId,
        receiptNo = receipt.ReceiptNo,
        sellerName = receipt.CustomerName,
        sellerCode = receipt.CustomerCode,
        phoneNumber = receipt.PhoneNumber,
        purchaseDate = CustomerPageHelpers.Date(receipt.TransactionDate),
        locationName = receipt.RubberAuctionLocationName ?? receipt.LocationName,
        weightKg = receipt.WeightKg,
        pricePerKg = receipt.PricePerKgSnapshot ?? 0,
        deductionPercent = receipt.PercentageSnapshot ?? 0,
        totalAmount = receipt.TotalAmount ?? 0,
        remainingAmount = AphiwatPOS.Pages.RubberPlantation.PayBill.IndexModel.GetRemainingAmount(receipt),
        paidAmount = receipt.PaidAmount,
        creditDeductedAmount = receipt.CreditDeductedAmount,
        paymentMethod = PaymentText(receipt.PaymentMethod)
    };
    string money(decimal value) => value.ToString("N2");
}

<partial name="/Pages/Customer/Shared/_TempDataAlert.cshtml" model="(Model.StatusMessage, Model.ErrorMessage)" />

<div class="page-header d-flex align-items-start justify-content-between gap-3 no-print">
    <div>
        <h1 data-i18n="rubberPay.title">Pay Rubber Bills</h1>
        <p data-i18n="rubberPay.subtitle">Select a rubber purchase bill, record payment, and print the receipt.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/RubberPlantation/RubberPurchase/Index"><i class="bi bi-box-arrow-in-down me-1"></i><span data-i18n="nav.rubberPurchases">Rubber Purchases</span></a>
</div>

<div class="no-print mb-3">
    <button class="btn btn-outline-primary" type="button" data-open-rubber-display><i class="bi bi-display me-1"></i><span data-i18n="rubberPay.customerDisplay">Customer Display</span></button>
</div>

<div class="summary-grid no-print">
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-receipt"></i></span><div><div class="metric-label" data-i18n="rubberPay.dueBills">Due bills</div><div class="metric-value">@Model.DuePurchases.Count</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-cash-stack"></i></span><div><div class="metric-label" data-i18n="rubberPay.outstandingTotal">Total outstanding</div><div class="metric-value">@money(Model.TotalDueAmount)</div></div></div>
    <div class="summary-card"><span class="metric-icon"><i class="bi bi-printer"></i></span><div><div class="metric-label" data-i18n="rubberPay.latestReceipt">Latest receipt</div><div class="metric-value">@(receipt?.ReceiptNo ?? "-")</div></div></div>
</div>

<div class="rubber-pay-layout no-print">
    <section class="data-card">
        <div class="card-heading">
            <div>
                <h2 data-i18n="rubberPay.billList">Bills to pay</h2>
                <p data-i18n="rubberPay.billListHelp">Search by member code, seller name, or phone number.</p>
            </div>
        </div>
        <form method="get" class="row g-2 mb-3">
            <div class="col"><input asp-for="SearchText" class="form-control" placeholder="Search seller" data-i18n-placeholder="rubberPay.searchSeller" /></div>
            <div class="col-auto"><button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button></div>
            <div class="col-auto"><a class="btn btn-outline-secondary" asp-page="./Index"><i class="bi bi-arrow-counterclockwise"></i></a></div>
        </form>
        <div class="rubber-bill-list">
            @if (!Model.DuePurchases.Any())
            {
                <div class="empty-state"><i class="bi bi-check2-circle"></i><div class="fw-semibold" data-i18n="rubberPay.noDueBills">No due rubber bills.</div></div>
            }
            @foreach (var item in Model.DuePurchases)
            {
                <a class="rubber-bill-card @(selected?.RubberPurchaseHeaderId == item.RubberPurchaseHeaderId ? "active" : "")" asp-page="./Index" asp-route-SearchText="@Model.SearchText" asp-route-HistorySearchText="@Model.HistorySearchText" asp-route-HistoryPaymentMethod="@Model.HistoryPaymentMethod" asp-route-HistoryDateFrom="@Model.HistoryDateFrom?.ToString("yyyy-MM-dd")" asp-route-HistoryDateTo="@Model.HistoryDateTo?.ToString("yyyy-MM-dd")" asp-route-SelectedPurchaseId="@item.RubberPurchaseHeaderId">
                    <span>
                        <strong>@item.CustomerName</strong>
                        <small>@item.CustomerCode &middot; @CustomerPageHelpers.Date(item.TransactionDate) &middot; @(item.RubberAuctionLocationName ?? item.LocationName)</small>
                    </span>
                    <span class="text-end">
                        <strong>@money(AphiwatPOS.Pages.RubberPlantation.PayBill.IndexModel.GetRemainingAmount(item))</strong>
                        <small>@item.WeightKg.ToString("N2") kg</small>
                    </span>
                </a>
            }
        </div>
    </section>

    <section class="data-card">
        <div class="card-heading">
            <div>
                <h2 data-i18n="rubberPay.payment">Payment</h2>
                <p data-i18n="rubberPay.paymentHelp">Review the bill amount, take payment, and print the receipt.</p>
            </div>
        </div>
        @if (selected is null)
        {
            <div class="empty-state"><i class="bi bi-receipt"></i><div class="fw-semibold" data-i18n="rubberPay.noBillSelected">Select a bill to pay.</div></div>
        }
        else
        {
            <div class="rubber-pay-detail">
                <div class="rubber-selected-head">
                    <div>
                        <span data-i18n="rubberPay.rubberSeller">Rubber seller</span>
                        <strong>@selected.CustomerName</strong>
                        <small>@selected.CustomerCode &middot; @(selected.PhoneNumber ?? "-")</small>
                    </div>
                    <div class="text-end">
                        <span data-i18n="rubberPay.fullAmount">Full amount to pay</span>
                        <strong>@money(fullPaymentAmount)</strong>
                        <small data-i18n="rubberPay.baht">baht</small>
                    </div>
                </div>
                <dl>
                    <dt data-i18n="rubberPay.billDate">Purchase date</dt><dd>@CustomerPageHelpers.Date(selected.TransactionDate)</dd>
                    <dt data-i18n="rubberPay.location">Purchase location</dt><dd>@(selected.RubberAuctionLocationName ?? selected.LocationName)</dd>
                    <dt data-i18n="rubberPay.weight">Weight</dt><dd>@selected.WeightKg.ToString("N2") <span data-i18n="rubberPay.kg">kg</span></dd>
                    <dt data-i18n="rubberPay.price">Price</dt><dd>@((selected.PricePerKgSnapshot ?? 0).ToString("N2")) <span data-i18n="rubberPay.bahtPerKg">baht/kg</span></dd>
                    <dt data-i18n="rubberPay.deduction">Deduction</dt><dd>@((selected.PercentageSnapshot ?? 0).ToString("N2"))%</dd>
                    <dt data-i18n="rubberPay.netAmount">Net amount</dt><dd>@money(selected.TotalAmount ?? 0) <span data-i18n="rubberPay.baht">baht</span></dd>
                </dl>
            </div>
            <form method="post" asp-page-handler="Pay" class="rubber-payment-form">
                <input type="hidden" asp-for="Input.RubberPurchaseHeaderId" value="@selected.RubberPurchaseHeaderId" />
                <input asp-for="Input.PaidAmount" type="hidden" value="@fullPaymentAmount" />
                <div class="full-pay-banner">
                    <div>
                        <span data-i18n="rubberPay.fullPaymentOnly">This cashier flow accepts full payment only.</span>
                        <strong>@money(fullPaymentAmount) <span data-i18n="rubberPay.baht">baht</span></strong>
                    </div>
                    <i class="bi bi-shield-check"></i>
                </div>
                <div>
                    <label class="form-label" data-i18n="rubberPay.paymentMethod">Payment method</label>
                    <div class="payment-method-grid" role="radiogroup" aria-label="Payment method">
                        <label class="payment-method-option">
                            <input asp-for="Input.PaymentMethod" type="radio" value="Cash" checked />
                            <span><i class="bi bi-cash-stack"></i><strong data-i18n="rubberPay.cash">Cash</strong><small data-i18n="rubberPay.cashHelp">Receive cash and print receipt immediately.</small></span>
                        </label>
                        <label class="payment-method-option">
                            <input asp-for="Input.PaymentMethod" type="radio" value="Transfer" />
                            <span><i class="bi bi-bank"></i><strong data-i18n="rubberPay.transfer">Bank transfer</strong><small data-i18n="rubberPay.transferHelp">Record the transfer reference in the remark.</small></span>
                        </label>
                    </div>
                </div>
                <div>
                    <label class="form-label" data-i18n="rubberPay.remark">Remark</label>
                    <input asp-for="Input.PaymentRemark" class="form-control" placeholder="Reference number or additional note" data-i18n-placeholder="rubberPay.remarkPlaceholder" />
                </div>
                <div class="payment-review">
                    <div><span data-i18n="rubberPay.seller">Seller</span><strong>@selected.CustomerName</strong></div>
                    <div><span data-i18n="rubberPay.weight">Weight</span><strong>@selected.WeightKg.ToString("N2") <span data-i18n="rubberPay.kg">kg</span></strong></div>
                    <div><span data-i18n="rubberPay.payAmount">Pay amount</span><strong>@money(fullPaymentAmount) <span data-i18n="rubberPay.baht">baht</span></strong></div>
                </div>
                @if (Model.SelectedCustomerHasOutstandingCredit)
                {
                    <div class="credit-due-alert">
                        <i class="bi bi-exclamation-triangle"></i>
                        <div>
                            <span data-i18n="rubberPay.customerCreditDue">Customer has outstanding credit</span>
                            <strong>@money(Model.SelectedCreditOutstandingAmount) <span data-i18n="rubberPay.baht">baht</span></strong>
                        </div>
                    </div>
                }
                <div class="d-flex justify-content-end gap-2">
                    @if (receipt is not null)
                    {
                        <button class="btn btn-outline-secondary" type="button" onclick="window.print()"><i class="bi bi-printer me-1"></i><span data-i18n="rubberPay.printReceipt">Print receipt</span></button>
                    }
                    <button class="btn btn-primary btn-lg" type="button" data-bs-toggle="modal" data-bs-target="#confirmRubberPayment"><i class="bi bi-check2-circle me-1"></i><span data-i18n="rubberPay.payFull">Pay full bill</span></button>
                </div>

                <div class="modal fade app-modal" id="confirmRubberPayment" tabindex="-1" aria-labelledby="confirmRubberPaymentTitle" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h2 class="modal-title h5" id="confirmRubberPaymentTitle" data-i18n="rubberPay.confirm">Confirm payment</h2>
                                <button class="btn-close" data-bs-dismiss="modal" type="button" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="confirm-payment-amount">@money(fullPaymentAmount) <span data-i18n="rubberPay.baht">baht</span></div>
                                <dl class="confirm-payment-list">
                                    <dt data-i18n="rubberPay.seller">Seller</dt><dd>@selected.CustomerName</dd>
                                    <dt data-i18n="rubberPay.billDate">Purchase date</dt><dd>@CustomerPageHelpers.Date(selected.TransactionDate)</dd>
                                    <dt data-i18n="rubberPay.weight">Weight</dt><dd>@selected.WeightKg.ToString("N2") <span data-i18n="rubberPay.kg">kg</span></dd>
                                </dl>
                                @if (Model.SelectedCustomerHasOutstandingCredit)
                                {
                                    <div class="credit-due-modal">
                                        <div class="credit-due-modal-icon"><i class="bi bi-credit-card"></i></div>
                                        <div>
                                            <h3 data-i18n="rubberPay.creditQuestion">Customer has outstanding credit. Pay it now?</h3>
                                            <p><span data-i18n="rubberPay.creditHelp">If selected, the system records the full rubber bill payment and also pays outstanding credit of</span> @money(Model.SelectedCreditOutstandingAmount) <span data-i18n="rubberPay.baht">baht</span></p>
                                        </div>
                                    </div>
                                }
                                @if (Model.SelectedCustomerHasOutstandingCredit)
                                {
                                    <label class="credit-due-choice">
                                        <input class="form-check-input" name="Input.PayCustomerCredit" value="true" type="checkbox" />
                                        <span><span data-i18n="rubberPay.payCreditWithBill">Pay outstanding credit</span> @money(Model.SelectedCreditOutstandingAmount) <span data-i18n="rubberPay.baht">baht</span></span>
                                    </label>
                                }
                            </div>
                            <div class="modal-footer">
                                <button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button" data-i18n="rubberPay.reviewAgain">Review again</button>
                                <button class="btn btn-primary" type="submit"><i class="bi bi-check2-circle me-1"></i><span data-i18n="rubberPay.confirm">Confirm payment</span></button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        }
    </section>
</div>

<section class="data-card mt-3 no-print">
    <div class="card-heading">
        <div>
            <h2 data-i18n="rubberPay.paymentHistory">Payment history</h2>
            <p data-i18n="rubberPay.paymentHistoryHelp">Review paid rubber bills and reprint receipts.</p>
        </div>
    </div>
    <form method="get" class="history-filter-card">
        <input type="hidden" asp-for="SearchText" />
        <div class="row g-2 align-items-end">
            <div class="col-lg-4">
                <label class="form-label" data-i18n="rubberPay.searchHistory">Search history</label>
                <input asp-for="HistorySearchText" class="form-control" placeholder="Receipt no, seller, phone, or location" data-i18n-placeholder="rubberPay.historyPlaceholder" />
            </div>
            <div class="col-lg-2">
                <label class="form-label" data-i18n="rubberPay.paymentMethod">Payment method</label>
                <select asp-for="HistoryPaymentMethod" class="form-select">
                    <option value="" data-i18n="rubberPay.all">All</option>
                    <option value="Cash" data-i18n="rubberPay.cash">Cash</option>
                    <option value="Transfer" data-i18n="rubberPay.transfer">Bank transfer</option>
                </select>
            </div>
            <div class="col-lg-2">
                <label class="form-label" data-i18n="rubberPay.dateFrom">Date from</label>
                <input asp-for="HistoryDateFrom" class="form-control" type="date" />
            </div>
            <div class="col-lg-2">
                <label class="form-label" data-i18n="rubberPay.dateTo">Date to</label>
                <input asp-for="HistoryDateTo" class="form-control" type="date" />
            </div>
            <div class="col-lg-2 d-flex gap-2">
                <button class="btn btn-primary flex-fill" type="submit"><i class="bi bi-funnel"></i></button>
                <a class="btn btn-outline-secondary" asp-page="./Index" asp-route-SearchText="@Model.SearchText"><i class="bi bi-arrow-counterclockwise"></i></a>
            </div>
        </div>
        @if (Model.HasHistoryFilter)
        {
            <div class="history-filter-summary">
                <span>@Model.PaidHistory.Count <span data-i18n="rubberPay.records">records</span></span>
                <a asp-page="./Index" asp-route-SearchText="@Model.SearchText" data-i18n="rubberPay.clearFilters">Clear filters</a>
            </div>
        }
    </form>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th data-i18n="rubberPay.receiptNo">Receipt no</th>
                    <th data-i18n="rubberPay.paidDate">Paid date</th>
                    <th data-i18n="rubberPay.seller">Seller</th>
                    <th data-i18n="rubberPay.weight">Weight</th>
                    <th data-i18n="rubberPay.netAmount">Net amount</th>
                    <th data-i18n="rubberPay.paidAmount">Paid amount</th>
                    <th data-i18n="rubberPay.paymentMethod">Payment method</th>
                    <th class="text-end" data-i18n="rubberPay.print">Print</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.PaidHistory.Any())
            {
                <tr><td colspan="8"><div class="empty-state"><i class="bi bi-clock-history"></i><div class="fw-semibold" data-i18n="rubberPay.noPaymentHistory">No payment history yet.</div></div></td></tr>
            }
            @foreach (var item in Model.PaidHistory)
            {
                <tr>
                    <td><span class="code-badge mono">@(item.ReceiptNo ?? "-")</span></td>
                    <td>@CustomerPageHelpers.DateTimeText(item.PaidDate)</td>
                    <td><span class="fw-semibold d-block">@item.CustomerName</span><span class="text-muted small">@item.CustomerCode &middot; @(item.RubberAuctionLocationName ?? item.LocationName)</span></td>
                    <td>@item.WeightKg.ToString("N2") kg</td>
                    <td>@money(item.TotalAmount ?? 0)</td>
                    <td class="fw-semibold">@money(item.PaidAmount)</td>
                    <td>@PaymentText(item.PaymentMethod)</td>
                    <td class="text-end">
                        <a class="btn btn-outline-secondary btn-sm" asp-page="./Index" asp-route-SearchText="@Model.SearchText" asp-route-HistorySearchText="@Model.HistorySearchText" asp-route-HistoryPaymentMethod="@Model.HistoryPaymentMethod" asp-route-HistoryDateFrom="@Model.HistoryDateFrom?.ToString("yyyy-MM-dd")" asp-route-HistoryDateTo="@Model.HistoryDateTo?.ToString("yyyy-MM-dd")" asp-route-ReceiptId="@item.RubberPurchaseHeaderId" asp-route-PromptPrint="true"><i class="bi bi-printer me-1"></i><span data-i18n="rubberPay.viewPrint">View/print</span></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

@if (receipt is not null)
{
    <section class="data-card mt-3 no-print">
        <div class="card-heading">
            <div>
                <h2 data-i18n="rubberPay.latestReceipt">Latest receipt</h2>
                <p>@receipt.ReceiptNo</p>
            </div>
            <button class="btn btn-primary" type="button" onclick="window.print()"><i class="bi bi-printer me-1"></i><span data-i18n="rubberPay.printReceipt">Print receipt</span></button>
        </div>
        <div class="rubber-receipt-preview">
            <partial name="_RubberBillReceipt" model="receipt" />
        </div>
    </section>

    <div class="modal fade app-modal" id="printReceiptPrompt" tabindex="-1" aria-labelledby="printReceiptPromptTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content print-prompt-modal">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="printReceiptPromptTitle" data-i18n="rubberPay.receiptQuestion">Print receipt?</h2>
                    <button class="btn-close" data-bs-dismiss="modal" type="button" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="print-prompt-icon"><i class="bi bi-printer"></i></div>
                    <div class="print-prompt-receipt">@(receipt.ReceiptNo ?? "-")</div>
                    <dl class="confirm-payment-list">
                        <dt data-i18n="rubberPay.seller">Seller</dt><dd>@receipt.CustomerName</dd>
                        <dt data-i18n="rubberPay.amountPaid">Amount paid</dt><dd>@money(receipt.PaidAmount) <span data-i18n="rubberPay.baht">baht</span></dd>
                        <dt data-i18n="rubberPay.paymentMethod">Payment method</dt><dd>@PaymentText(receipt.PaymentMethod)</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button" data-i18n="rubberPay.notNow">Not now</button>
                    <button class="btn btn-primary" type="button" data-bs-dismiss="modal" onclick="window.print()"><i class="bi bi-printer me-1"></i><span data-i18n="rubberPay.printReceipt">Print receipt</span></button>
                </div>
            </div>
        </div>
    </div>
}

<div class="print-only">
    @if (receipt is not null)
    {
        <partial name="_RubberBillReceipt" model="receipt" />
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (() => {
      const languageKey = 'aphiwatpos.language';
      const copy = {
        en: {
          title: 'Pay Rubber Bills',
          subtitle: 'Select a rubber purchase bill, record payment, and print the receipt.',
          customerDisplay: 'Customer Display',
          dueBills: 'Due bills',
          outstandingTotal: 'Total outstanding',
          latestReceipt: 'Latest receipt',
          billList: 'Bills to pay',
          billListHelp: 'Search by member code, seller name, or phone number.',
          payment: 'Payment',
          paymentHelp: 'Review the bill amount, take payment, and print the receipt.',
          noBillSelected: 'Select a bill to pay.',
          fullPaymentOnly: 'This cashier flow accepts full payment only.',
          paymentMethod: 'Payment method',
          cash: 'Cash',
          cashHelp: 'Receive cash and print receipt immediately.',
          transfer: 'Bank transfer',
          transferHelp: 'Record the transfer reference in the remark.',
          remark: 'Remark',
          payFull: 'Pay full bill',
          history: 'Payment history'
        },
        th: {
          title: 'จ่ายบิลยางพารา',
          subtitle: 'เลือกบิลรับซื้อยาง บันทึกการชำระเงิน และพิมพ์ใบเสร็จรับเงิน',
          customerDisplay: 'จอลูกค้า',
          dueBills: 'บิลรอจ่าย',
          outstandingTotal: 'ยอดค้างรวม',
          latestReceipt: 'ใบเสร็จล่าสุด',
          billList: 'บิลที่รอชำระ',
          billListHelp: 'ค้นหาจากรหัสสมาชิก ชื่อผู้ขาย หรือเบอร์โทร',
          payment: 'ชำระเงิน',
          paymentHelp: 'ตรวจสอบยอดก่อนบันทึกและพิมพ์ใบเสร็จ',
          noBillSelected: 'เลือกบิลเพื่อชำระเงิน',
          fullPaymentOnly: 'ระบบนี้จ่ายเต็มจำนวนเท่านั้น',
          paymentMethod: 'วิธีชำระเงิน',
          cash: 'เงินสด',
          cashHelp: 'รับเงินสดและออกใบเสร็จทันที',
          transfer: 'โอนบัญชี',
          transferHelp: 'บันทึกเลขอ้างอิงในหมายเหตุ',
          remark: 'หมายเหตุ',
          payFull: 'จ่ายบิลเต็มจำนวน',
          history: 'ประวัติการจ่ายเงิน'
        }
      };
      const language = () => localStorage.getItem(languageKey) === 'th' ? 'th' : 'en';
      const set = (selector, value) => {
        const element = document.querySelector(selector);
        if (element) element.textContent = value;
      };
      const setPlaceholder = (selector, value) => {
        const element = document.querySelector(selector);
        if (element) element.placeholder = value;
      };
      function applyRubberPayLanguage() {
        const t = copy[language()];
        set('.page-header h1', t.title);
        set('.page-header p', t.subtitle);
        set('[data-open-rubber-display] span', t.customerDisplay);
        set('.summary-grid .summary-card:nth-child(1) .metric-label', t.dueBills);
        set('.summary-grid .summary-card:nth-child(2) .metric-label', t.outstandingTotal);
        set('.summary-grid .summary-card:nth-child(3) .metric-label', t.latestReceipt);
