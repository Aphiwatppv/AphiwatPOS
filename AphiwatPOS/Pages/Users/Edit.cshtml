@page "{id:int}"
@model AphiwatPOS.Pages.Users.EditModel
@{
    ViewData["Title"] = "Edit user";
}

<h1 class="h3 mb-3">Edit user</h1>

<form method="post" class="row g-3 mb-4">
    <input type="hidden" asp-for="Input.UserId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="Input.DisplayName" class="form-label"></label>
        <input asp-for="Input.DisplayName" class="form-control" />
        <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.Email" class="form-label"></label>
        <input asp-for="Input.Email" class="form-control" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.Roles" class="form-label"></label>
        <input asp-for="Input.Roles" class="form-control" />
        <span asp-validation-for="Input.Roles" class="text-danger"></span>
    </div>
    <div class="col-md-6 d-flex align-items-end">
        <div class="form-check">
            <input asp-for="Input.IsActive" class="form-check-input" />
            <label asp-for="Input.IsActive" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a class="btn btn-outline-secondary" asp-page="/Users/Index">Cancel</a>
    </div>
</form>

<form method="post" asp-page-handler="Password" class="row g-3 border-top pt-4">
    <input type="hidden" asp-for="PasswordInput.UserId" />
    <div class="col-md-6">
        <label asp-for="PasswordInput.Password" class="form-label"></label>
        <input asp-for="PasswordInput.Password" class="form-control" />
        <span asp-validation-for="PasswordInput.Password" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-outline-primary">Reset password</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
