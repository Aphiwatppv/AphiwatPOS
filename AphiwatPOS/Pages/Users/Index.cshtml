@page
@model AphiwatPOS.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Users</h1>
    <a class="btn btn-primary" asp-page="/Users/Create">New user</a>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Username</th>
                <th>Name</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Username</td>
                    <td>@user.DisplayName</td>
                    <td>@user.Email</td>
                    <td>@user.Roles</td>
                    <td>
                        <span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">
                            @(user.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-page="/Users/Edit" asp-route-id="@user.UserId">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
