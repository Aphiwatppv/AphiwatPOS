@page
@model AphiwatPOS.Pages.Users.CreateModel
@{
    ViewData["Title"] = "New user";
}

<h1 class="h3 mb-3">New user</h1>

<form method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="Input.Username" class="form-label"></label>
        <input asp-for="Input.Username" class="form-control" autocomplete="off" />
        <span asp-validation-for="Input.Username" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.DisplayName" class="form-label"></label>
        <input asp-for="Input.DisplayName" class="form-control" />
        <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.Email" class="form-label"></label>
        <input asp-for="Input.Email" class="form-control" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.Roles" class="form-label"></label>
        <input asp-for="Input.Roles" class="form-control" placeholder="Admin, Cashier" />
        <span asp-validation-for="Input.Roles" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.Password" class="form-label"></label>
        <input asp-for="Input.Password" class="form-control" />
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create user</button>
        <a class="btn btn-outline-secondary" asp-page="/Users/Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
