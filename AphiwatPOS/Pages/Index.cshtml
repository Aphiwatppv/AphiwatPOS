ex;gap:12px;justify-content:space-between}.metric-list span,.payment-row span,.rank-row span{color:#64748b;font-weight:800}.metric-list strong{font-weight:900}.metric-list .total{border-top:1px solid #e2e8f0;padding-top:9px}.payment-bars,.rank-list{display:grid;gap:10px}.payment-row div,.rank-row div{background:#e2e8f0;flex:1;height:9px}.payment-row b,.rank-row b{background:#0f766e;display:block;height:100%}.dash-table{font-size:.9rem;width:100%}.dash-table th{color:#64748b;font-size:.75rem;text-transform:uppercase}.dash-table td,.dash-table th{border-bottom:1px solid #e2e8f0;padding:9px 6px;vertical-align:top}.dash-table td div{color:#64748b;font-size:.8rem}.alert-list,.task-list{display:grid;gap:9px}.dash-alert,.task-row{border:1px solid #e2e8f0;color:#0f172a;display:grid;padding:10px;text-decoration:none}.dash-alert span,.task-row span{color:#64748b}.dash-alert.warning,.task-row.warning{background:#fffbeb;border-color:#fde68a}.dash-alert.danger{background:#fef2f2;border-color:#fecaca}.quick-actions{display:grid;gap:10px;grid-template-columns:repeat(7,minmax(0,1fr))}.quick-actions a,.cashier-actions a,.cashier-actions button{align-items:center;background:#f8fafc;border:1px solid #dbe4ee;color:#0f172a;display:flex;font-weight:900;gap:8px;justify-content:center;min-height:58px;padding:10px;text-align:center;text-decoration:none}.quick-actions i,.cashier-actions i{font-size:1.25rem}.cashier-actions{display:grid;gap:12px;grid-template-columns:2fr repeat(5,1fr);margin-bottom:16px}.cashier-actions .primary-action{background:#0f766e;color:#fff;font-size:1.15rem}.cashier-actions button{cursor:not-allowed;opacity:.72}.shift-kpis{display:grid;gap:12px;grid-template-columns:repeat(3,minmax(0,1fr))}.shift-kpis div{background:#f8fafc;border:1px solid #e2e8f0;padding:14px}.shift-kpis span{color:#64748b;font-weight:900}.shift-kpis strong{display:block;font-size:1.5rem;font-weight:900}.display-status-box{display:grid;gap:9px}.notification-row{display:flex;flex-wrap:wrap;gap:10px}.notification-row span{border:1px solid #dbe4ee;font-weight:800;padding:9px 12px}.notification-row .success{background:#ecfdf5;color:#047857}.notification-row .info{background:#eff6ff;color:#1d4ed8}.empty-note{color:#64748b;font-weight:800;padding:12px}.text-warning{color:#b45309!important}.text-danger{color:#dc2626!important}@@media(max-width:1200px){.kpi-grid,.manager-grid,.cashier-grid,.quick-actions,.cashier-actions{grid-template-columns:repeat(2,minmax(0,1fr))}.span-2,.span-3{grid-column:1/-1}.cashier-actions .primary-action{grid-column:1/-1}}@@media(max-width:700px){.kpi-grid,.manager-grid,.cashier-grid,.quick-actions,.cashier-actions,.shift-kpis{grid-template-columns:1fr}.dash-hero{align-items:flex-start;display:grid;gap:10px}.trend-chart{height:180px;overflow:auto}.dash-panel{padding:12px}}
</style>

<style>
:root{--dash-ink:#111827;--dash-muted:#64748b;--dash-line:#dbe4ee;--dash-soft:#f8fafc;--dash-panel:#fff;--dash-teal:#0f766e;--dash-blue:#2563eb;--dash-gold:#b7791f;--dash-red:#b91c1c;--dash-shadow:0 18px 45px rgba(15,23,42,.08)}
.dashboard-switch{background:#eef3f7;border:1px solid #d6e0ea;border-radius:8px;box-shadow:inset 0 1px 0 rgba(255,255,255,.75);gap:4px;padding:4px}
.switch-tab{border-radius:6px;color:#475569;padding:10px 18px}
.switch-tab.active{background:#0f766e;box-shadow:0 8px 22px rgba(15,118,110,.22);color:#fff}
.dash-hero{background:linear-gradient(135deg,#ffffff 0%,#f8fbfc 62%,#eef6f5 100%);border:1px solid var(--dash-line);border-radius:8px;box-shadow:var(--dash-shadow);overflow:hidden;padding:26px 28px;position:relative}
.dash-hero:after{background:linear-gradient(180deg,rgba(15,118,110,.14),rgba(37,99,235,.08));content:"";height:100%;position:absolute;right:0;top:0;width:10px}
.dash-hero h1{color:var(--dash-ink);font-size:1.95rem;letter-spacing:0}
.dash-hero p{color:var(--dash-muted);font-size:.95rem}
.hero-eyebrow{align-items:center;color:#0f766e;display:inline-flex;font-size:.75rem;font-weight:900;gap:7px;letter-spacing:.08em;margin-bottom:8px;text-transform:uppercase}
.manager-hero,.cashier-hero{border-left:0}
.cashier-hero{background:linear-gradient(135deg,#ffffff 0%,#f8fbff 60%,#eff6ff 100%)}
.cashier-hero .hero-eyebrow{color:#1d4ed8}
.hero-date,.status-pill{border:1px solid #dbe4ee;border-radius:999px;color:#334155;padding:9px 13px}
.status-pill.connected{border-color:#bbf7d0}.status-pill.disconnected{border-color:#bfdbfe}
.kpi-grid{gap:16px}
.kpi-card{background:var(--dash-panel);border:1px solid var(--dash-line);border-radius:8px;box-shadow:0 12px 32px rgba(15,23,42,.06);min-height:142px;padding:18px;position:relative}
.kpi-card i{align-items:center;background:#ecfdf5;border:1px solid #ccfbf1;border-radius:8px;color:#0f766e;display:flex;font-size:1.15rem;height:38px;justify-content:center;position:absolute;right:16px;top:16px;width:38px}
.kpi-card.warning i{background:#fffbeb;border-color:#fde68a;color:#b7791f}
.kpi-card span{color:#53637a;display:block;font-size:.82rem;text-transform:uppercase}
.kpi-card strong{color:#07111f;font-size:2rem;line-height:1.05;margin:18px 46px 8px 0}
.kpi-card small{color:#64748b;font-weight:700}
.kpi-card.accent,.kpi-card.warning{border-left:1px solid var(--dash-line)}
.manager-grid,.cashier-grid{gap:18px}
.dash-panel{background:var(--dash-panel);border:1px solid var(--dash-line);border-radius:8px;box-shadow:0 14px 36px rgba(15,23,42,.055);padding:18px}
.panel-head{gap:16px;margin-bottom:16px}
.panel-head h2{color:#101827;font-size:1rem;letter-spacing:0}
.panel-head span{color:#64748b;font-size:.78rem;font-weight:800}
.panel-head a{align-items:center;border:1px solid #cfe1df;border-radius:999px;color:#0f766e;display:inline-flex;font-size:.82rem;font-weight:900;min-height:34px;padding:7px 12px;text-decoration:none;white-space:nowrap}
.trend-chart{background:linear-gradient(180deg,#fbfdff 0%,#fff 100%);border:1px solid #e6edf4;border-radius:8px;display:block;height:300px;overflow:hidden;padding:18px 14px 12px;position:relative}
.trend-grid{bottom:58px;display:grid;gap:0;left:14px;pointer-events:none;position:absolute;right:14px;top:18px}
.trend-grid span{border-top:1px dashed #dbe4ee}
