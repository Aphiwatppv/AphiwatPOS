.trend-bar.is-empty .trend-plot span{background:#cbd5e1;box-shadow:none;opacity:.65}
.trend-bar strong{align-self:center;color:#334155;font-size:.68rem;font-weight:900;line-height:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.trend-bar small{color:#64748b;font-size:.7rem;font-weight:800;line-height:1.1}
.trend-empty{align-items:center;background:rgba(255,255,255,.92);border:1px dashed #cbd5e1;border-radius:8px;display:flex;gap:12px;left:50%;padding:12px 14px;position:absolute;top:48%;transform:translate(-50%,-50%);z-index:2}
