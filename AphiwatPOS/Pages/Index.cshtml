@page
@model IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = Model.IsCashierDashboard ? "Cashier Dashboard" : "Manager Dashboard";
    var manager = Model.ManagerDashboard;
    var cashier = Model.CashierDashboard;
    var salesTrend = manager?.SalesOverview.SalesTrend ?? Array.Empty<AphiwatPOS.Services.DashboardTrendPointModel>();
    var topProducts = manager?.SalesOverview.BestSellingProducts ?? Array.Empty<AphiwatPOS.Services.DashboardProductMetricModel>();
    var paymentSummary = manager?.PaymentSummary;
    decimal maxTrend = Math.Max(1, salesTrend.Any() ? salesTrend.Max(x => x.Value) : 1);
    decimal maxProduct = Math.Max(1, topProducts.Any() ? topProducts.Max(x => x.Quantity) : 1);
    var hasTrendSales = salesTrend.Any(x => x.Value > 0);
    var trendPeak = salesTrend.FirstOrDefault(x => x.Value == (salesTrend.Any() ? salesTrend.Max(point => point.Value) : 0));
    string Money(decimal value) => value.ToString("N2");
}

@if (Model.CanViewManagerDashboard)
{
    <div class="dashboard-switch">
        <a class="switch-tab @(!Model.IsCashierDashboard ? "active" : "")" asp-page="/Index">Manager / Owner</a>
        <a class="switch-tab @(Model.IsCashierDashboard ? "active" : "")" asp-page="/Index" asp-route-viewMode="cashier">Cashier View</a>
    </div>
}

@if (!Model.IsCashierDashboard && manager is not null)
{
    <section class="dash-hero manager-hero">
        <div>
            <span class="hero-eyebrow"><i class="bi bi-stars"></i> Executive workspace</span>
            <h1>Manager / Owner Dashboard</h1>
            <p>Business performance, stock risk, customer credit, and cashier activity.</p>
        </div>
        <div class="hero-date">@DateTime.Now.ToString("dddd, MMM dd yyyy")</div>
    </section>

    <section class="kpi-grid manager-kpis">
        <article class="kpi-card accent"><i class="bi bi-lightning-charge"></i><span>Today's Sales</span><strong>@Money(manager.SalesOverview.TodaySales)</strong><small>@manager.SalesOverview.TotalTransactions transactions this month</small></article>
        <article class="kpi-card"><i class="bi bi-calendar-week"></i><span>This Week</span><strong>@Money(manager.SalesOverview.WeekSales)</strong><small>Average bill @Money(manager.SalesOverview.AverageBillAmount)</small></article>
        <article class="kpi-card"><i class="bi bi-graph-up-arrow"></i><span>This Month</span><strong>@Money(manager.SalesOverview.MonthSales)</strong><small>Net sales after discount</small></article>
        <article class="kpi-card warning"><i class="bi bi-credit-card-2-front"></i><span>Outstanding Credit</span><strong>@Money(manager.CustomerOverview.OutstandingCustomerCredit)</strong><small>@manager.CustomerOverview.CustomersUsingCredit credit customers</small></article>
    </section>

    <section class="manager-grid">
        <article class="dash-panel span-2">
            <div class="panel-head">
                <div>
                    <h2>Sales Trend</h2>
                    <span>Last 14 days@(hasTrendSales && trendPeak is not null ? $" - Peak {trendPeak.Label}" : "")</span>
                </div>
                <a asp-page="/Sales/SalesHistory/Index">View Sales Report</a>
            </div>
            <div class="trend-chart">
                <div class="trend-grid" aria-hidden="true"><span></span><span></span><span></span></div>
                <div class="trend-bars">
                    @foreach (var point in salesTrend)
                    {
                        var height = point.Value <= 0 ? 2 : Math.Max(12, (int)Math.Round(point.Value / maxTrend * 100));
                        <div class="trend-bar @(point.Value <= 0 ? "is-empty" : "")" title="@point.Label: @Money(point.Value)">
                            <div class="trend-plot"><span style="height:@height%;"></span></div>
                            <strong>@Money(point.Value)</strong>
                            <small>@point.Label</small>
                        </div>
                    }
                </div>
                @if (!hasTrendSales)
                {
                    <div class="trend-empty">
                        <i class="bi bi-bar-chart"></i>
                        <div>
                            <strong>No sales in the last 14 days</strong>
                            <span>New completed sales will appear here automatically.</span>
                        </div>
                    </div>
                }
            </div>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Profit / Revenue</h2></div>
            <div class="metric-list">
                <div><span>Gross sales</span><strong>@Money(manager.ProfitSummary.GrossSales)</strong></div>
                <div><span>Discount</span><strong>@Money(manager.ProfitSummary.DiscountAmount)</strong></div>
                <div><span>Net sales</span><strong>@Money(manager.ProfitSummary.NetSales)</strong></div>
                <div><span>COGS</span><strong>@Money(manager.ProfitSummary.CostOfGoodsSold)</strong></div>
                <div><span>VAT In</span><strong>@Money(manager.ProfitSummary.VatInAmount)</strong></div>
                <div><span>VAT Out</span><strong>@Money(manager.ProfitSummary.VatOutAmount)</strong></div>
                <div class="total"><span>Estimated profit</span><strong>@Money(manager.ProfitSummary.EstimatedProfit)</strong></div>
                <div><span>Margin</span><strong>@manager.ProfitSummary.ProfitMarginPercent.ToString("N1")%</strong></div>
            </div>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Payment Summary</h2></div>
            <div class="payment-bars">
                @{
                    var paymentRows = new[] {
                        ("Cash", paymentSummary?.CashSales ?? 0),
                        ("QR", paymentSummary?.QrPaymentSales ?? 0),
                        ("Transfer", paymentSummary?.BankTransferSales ?? 0),
                        ("Credit", paymentSummary?.CreditSales ?? 0),
                        ("Mixed", paymentSummary?.MixedPaymentSales ?? 0)
                    };
                    var maxPayment = Math.Max(1, paymentRows.Max(x => x.Item2));
                }
                @foreach (var row in paymentRows)
                {
                    var width = Math.Max(4, (int)Math.Round(row.Item2 / maxPayment * 100));
                    <div class="payment-row"><span>@row.Item1</span><div><b style="width:@width%"></b></div><strong>@Money(row.Item2)</strong></div>
                }
            </div>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Inventory Overview</h2><a asp-page="/Inventory/Dashboard/Index">Inventory Report</a></div>
            <div class="metric-list">
                <div><span>Total products</span><strong>@manager.InventoryOverview.TotalProducts</strong></div>
                <div><span>Low stock</span><strong class="text-warning">@manager.InventoryOverview.LowStockProducts</strong></div>
                <div><span>Out of stock</span><strong class="text-danger">@manager.InventoryOverview.OutOfStockProducts</strong></div>
                <div><span>Stock value</span><strong>@Money(manager.InventoryOverview.StockValue)</strong></div>
                <div><span>Stock movement</span><strong>@manager.InventoryOverview.StockOutQty.ToString("N0") out</strong></div>
            </div>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Best-Selling Products</h2></div>
            <div class="rank-list">
                @foreach (var product in topProducts)
                {
                    var width = Math.Max(6, (int)Math.Round(product.Quantity / maxProduct * 100));
                    <div class="rank-row"><span>@product.ProductName</span><div><b style="width:@width%"></b></div><strong>@product.Quantity.ToString("N0")</strong></div>
                }
            </div>
        </article>

        <article class="dash-panel span-2">
            <div class="panel-head"><h2>Low Stock Products</h2><a asp-page="/Inventory/LowStock/Index">Manage Stock</a></div>
            <table class="dash-table"><thead><tr><th>Product</th><th>Location</th><th class="text-end">Current</th><th class="text-end">Shortage</th></tr></thead><tbody>
                @foreach (var item in manager.InventoryOverview.LowStockList.Take(6))
                {
                    <tr><td><strong>@item.ProductName</strong><div>@item.ProductCode</div></td><td>@item.LocationName</td><td class="text-end">@item.CurrentQty.ToString("N0")</td><td class="text-end text-danger">@item.ShortageQty.ToString("N0")</td></tr>
                }
            </tbody></table>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Customer Overview</h2><a asp-page="/Customer/CustomerReport/Index">Customer Report</a></div>
            <div class="metric-list">
                <div><span>Total customers</span><strong>@manager.CustomerOverview.TotalCustomers</strong></div>
                <div><span>New this month</span><strong>@manager.CustomerOverview.NewCustomersThisMonth</strong></div>
                <div><span>Members</span><strong>@manager.CustomerOverview.MemberCustomers</strong></div>
                <div><span>Using credit</span><strong>@manager.CustomerOverview.CustomersUsingCredit</strong></div>
            </div>
        </article>

        <article class="dash-panel span-2">
            <div class="panel-head"><h2>Cashier Performance</h2><a asp-page="/Sales/DailyClosing/Index">Cashier Report</a></div>
            <table class="dash-table"><thead><tr><th>Cashier</th><th class="text-end">Sales</th><th class="text-end">Transactions</th><th class="text-end">Discounts</th><th class="text-end">Cash Diff.</th></tr></thead><tbody>
                @foreach (var row in manager.CashierPerformance)
                {
                    <tr><td>@row.CashierName</td><td class="text-end">@Money(row.SalesAmount)</td><td class="text-end">@row.TransactionCount</td><td class="text-end">@Money(row.DiscountAmount)</td><td class="text-end">@Money(row.CashDifferenceAmount)</td></tr>
                }
            </tbody></table>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Alerts / Warnings</h2></div>
            <div class="alert-list">
                @foreach (var alert in manager.Alerts)
                {
                    <a class="dash-alert @alert.Severity" href="@alert.Url"><strong>@alert.Title</strong><span>@alert.Message</span></a>
                }
            </div>
        </article>

        <article class="dash-panel span-3 quick-actions-panel">
            <div class="panel-head"><h2>Quick Actions</h2></div>
            <div class="quick-actions">
                <a asp-page="/Sales/SalesHistory/Index"><i class="bi bi-graph-up"></i>View Sales Report</a>
                <a asp-page="/Inventory/Dashboard/Index"><i class="bi bi-boxes"></i>View Inventory Report</a>
                <a asp-page="/Customer/CustomerReport/Index"><i class="bi bi-people"></i>View Customer Report</a>
                <a asp-page="/Sales/DailyClosing/Index"><i class="bi bi-person-lines-fill"></i>View Cashier Report</a>
                <a asp-page="/Products/Product/Index"><i class="bi bi-tags"></i>Manage Products</a>
                <a asp-page="/Inventory/CurrentStock/Index"><i class="bi bi-clipboard-data"></i>Manage Stock</a>
                <a asp-page="/Customer/CustomerList/Index"><i class="bi bi-person-vcard"></i>Manage Customers</a>
            </div>
        </article>
    </section>
}
else if (cashier is not null)
{
    <section class="dash-hero cashier-hero">
        <div>
            <span class="hero-eyebrow"><i class="bi bi-bag-check"></i> Checkout command center</span>
            <h1>Cashier Dashboard</h1>
            <p>Welcome, @cashier.ShiftSummary.CashierName. Focus on today's sales and next actions.</p>
        </div>
        <span class="status-pill @(cashier.CustomerDisplayStatus.IsConnected ? "connected" : "disconnected")">
            Customer display @(cashier.CustomerDisplayStatus.IsConnected ? "connected" : "ready to open")
        </span>
    </section>

    <section class="cashier-actions">
        <a class="primary-action" asp-page="/Sales/POSCheckout/Index"><i class="bi bi-cart-plus"></i><span>Start New Sale</span></a>
        <a asp-page="/Sales/HeldSales/Index"><i class="bi bi-pause-circle"></i><span>Continue Held Sale</span><strong>@cashier.ShiftSummary.HeldSalesCount</strong></a>
        <a asp-page="/Sales/SalesHistory/Index"><i class="bi bi-clock-history"></i><span>Sales History</span></a>
        <a asp-page="/Sales/ReturnsRefunds/Index"><i class="bi bi-arrow-counterclockwise"></i><span>Return / Refund</span></a>
        <button type="button"><i class="bi bi-cash-coin"></i><span>Open Cash Drawer</span></button>
        <button type="button"><i class="bi bi-printer"></i><span>Print Last Receipt</span></button>
    </section>

    <section class="cashier-grid">
        <article class="dash-panel span-2">
            <div class="panel-head"><h2>Today's Shift Summary</h2><span>Started @cashier.ShiftSummary.ShiftStartTime.ToString("HH:mm")</span></div>
            <div class="shift-kpis">
                <div><span>Today sales</span><strong>@Money(cashier.ShiftSummary.TodaySales)</strong></div>
                <div><span>Transactions</span><strong>@cashier.ShiftSummary.TransactionCount</strong></div>
                <div><span>Cash received</span><strong>@Money(cashier.ShiftSummary.CashReceived)</strong></div>
                <div><span>QR / payment</span><strong>@Money(cashier.ShiftSummary.QrPaymentReceived)</strong></div>
                <div><span>Refunds</span><strong>@Money(cashier.ShiftSummary.RefundAmount)</strong></div>
                <div><span>Held sales</span><strong>@cashier.ShiftSummary.HeldSalesCount</strong></div>
            </div>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Customer Display</h2></div>
            <div class="display-status-box">
                <strong>@(cashier.CustomerDisplayStatus.IsConnected ? "Connected" : "Disconnected")</strong>
                <span>Terminal: @cashier.CustomerDisplayStatus.TerminalId</span>
                <span>Status: @cashier.CustomerDisplayStatus.CurrentSaleStatus</span>
                <a class="btn btn-primary" asp-page="/Sales/CustomerDisplay/Index" asp-route-terminalId="@cashier.CustomerDisplayStatus.TerminalId" target="_blank">Open Customer Display</a>
            </div>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Pending Tasks</h2></div>
            <div class="task-list">
                @foreach (var task in cashier.PendingTasks)
                {
                    <a class="task-row @task.Status" href="@task.Url"><strong>@task.Title</strong><span>@task.Detail</span></a>
                }
            </div>
        </article>

        <article class="dash-panel span-2">
            <div class="panel-head"><h2>Recent Sales</h2><a asp-page="/Sales/SalesHistory/Index">View All</a></div>
            <table class="dash-table"><thead><tr><th>Invoice</th><th>Time</th><th>Customer</th><th>Payment</th><th class="text-end">Total</th><th>Status</th><th></th></tr></thead><tbody>
                @foreach (var sale in cashier.RecentSales)
                {
                    <tr><td>@sale.SaleNo</td><td>@sale.SaleDate.ToString("HH:mm")</td><td>@(sale.CustomerName ?? "Walk-in")</td><td>Recorded</td><td class="text-end">@Money(sale.NetAmount)</td><td><span class="status-badge badge-success">@sale.Status</span></td><td><a asp-page="/Sales/SalesHistory/Index" asp-route-SearchText="@sale.SaleNo">View / Print</a></td></tr>
                }
            </tbody></table>
        </article>

        <article class="dash-panel">
            <div class="panel-head"><h2>Credit Reminder</h2></div>
            <div class="task-list">
                @if (!cashier.CustomerCreditToday.Any())
                {
                    <div class="empty-note">No customer credit sales today.</div>
                }
                @foreach (var credit in cashier.CustomerCreditToday)
                {
                    <div class="task-row warning"><strong>@credit.CustomerName</strong><span>@Money(credit.CreditAmount) credit used - @credit.PaymentStatus</span></div>
                }
            </div>
        </article>

        <article class="dash-panel span-3">
            <div class="panel-head"><h2>Notifications</h2></div>
            <div class="notification-row">
                @foreach (var notification in cashier.Notifications)
                {
                    <span class="@notification.Severity">@notification.Message</span>
                }
            </div>
        </article>
    </section>
}

